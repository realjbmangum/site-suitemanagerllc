---
// Property fact sheet — labeled operational data (alarm codes, utility
// accounts, access instructions). The "Notes / Other" COLLAPSIBLE card of the
// fact-sheet dashboard (FactSheetBoard). Embedded on the property pages.
interface Fact {
  id: string;
  label: string;
  value: string;
}
interface Props {
  propertyId: string;
  facts: Fact[];
  canEdit: boolean;
}
const { propertyId, facts, canEdit } = Astro.props;
const searchText = (f: Fact) => `${f.label} ${f.value}`.toLowerCase();
---

<details open id="fs-notes" class="fs-card break-inside-avoid mb-4 bg-white border border-[var(--color-hairline)] rounded-xl overflow-hidden shadow-sm scroll-mt-28">
  <summary class="fs-head list-none cursor-pointer select-none flex items-center justify-between gap-3 px-4 py-2.5 bg-[var(--color-muted)] text-white">
    <span class="flex items-center gap-2 min-w-0">
      <svg class="fs-chev w-3 h-3 shrink-0 transition-transform duration-150 opacity-80" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M4 2l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span aria-hidden="true" class="text-sm shrink-0">📝</span>
      <h2 class="font-semibold tracking-tight truncate">Notes / Other</h2>
    </span>
    <span class="shrink-0 inline-flex items-center justify-center min-w-[1.5rem] h-5 px-2 text-xs font-bold rounded-full bg-white/20 text-white tabular-nums">{facts.length}</span>
  </summary>

  {facts.length === 0 ? (
    <div class="fs-empty px-4 py-6 text-center text-sm text-[var(--color-muted)]">Nothing here yet.</div>
  ) : (
    <ul class="fs-rows divide-y divide-[var(--color-hairline)]">
      {facts.map((f) => (
        <li class="px-4 py-2.5 hover:bg-[var(--color-cream)]/60 transition-colors" data-fs-row data-fs-text={searchText(f)}>
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brass-dark)]">{f.label}</div>
              <div class="text-sm text-[var(--color-navy)] mt-0.5 whitespace-pre-wrap">{f.value}</div>
            </div>
            {canEdit && (
              <div class="flex items-center gap-3 shrink-0 text-xs relative">
                <details>
                  <summary class="cursor-pointer font-semibold text-[var(--color-navy)] hover:text-[var(--color-brass-dark)] list-none">Edit</summary>
                  <form method="POST" action={`/api/property-facts/${f.id}`} class="absolute right-0 mt-2 z-10 w-72 bg-white border border-[var(--color-hairline)] rounded-lg p-3 shadow-lg space-y-2">
                    <input type="hidden" name="action" value="update" />
                    <input name="label" required value={f.label} class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                    <textarea name="value" required rows="3" class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm">{f.value}</textarea>
                    <button type="submit" class="btn-primary text-xs w-full">Save</button>
                  </form>
                </details>
                <form method="POST" action={`/api/property-facts/${f.id}`} data-confirm={`Delete "${f.label}" from the fact sheet?`}>
                  <input type="hidden" name="action" value="delete" />
                  <button type="submit" class="font-semibold text-red-600 hover:text-red-700">Delete</button>
                </form>
              </div>
            )}
          </div>
        </li>
      ))}
    </ul>
  )}

  {canEdit && (
    <details class="group border-t border-[var(--color-hairline)]" id="fs-notes-add">
      <summary class="px-4 py-2 text-xs font-semibold text-[var(--color-brass-dark)] hover:bg-[var(--color-cream)] cursor-pointer list-none">+ Add a note</summary>
      <form method="POST" action={`/api/properties/${propertyId}/facts`} class="px-4 py-3 bg-[var(--color-cream)] space-y-2">
        <input name="label" required placeholder="Label — e.g. Fire alarm code" class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
        <textarea name="value" required rows="2" placeholder="Value — e.g. 1234, or how-to instructions" class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm"></textarea>
        <button type="submit" class="btn-ghost text-sm w-full">Add to fact sheet</button>
      </form>
    </details>
  )}
</details>

<style>
  .fs-card > summary::-webkit-details-marker { display: none; }
  .fs-card > summary { list-style: none; }
  .fs-card[open] > summary .fs-chev { transform: rotate(90deg); }
</style>
