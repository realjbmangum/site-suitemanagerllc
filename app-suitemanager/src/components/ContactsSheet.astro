---
// Contacts sheet — the "Who-to-Call" half of the red binder. Three clearly
// segmented sub-sections (Key People / Vendors / Emergency & Utilities) so a
// cold GM or traveling VP can scan it fast. Mirrors the property_facts API +
// FactSheet.astro inline-edit (details/summary) pattern.
//
// No-duplication: the GM is shown READ-ONLY from `gmName` (the assigned user),
// never re-entered; address/front-desk phone/fax/email live on the property
// record + Overview, not here.
interface Contact {
  id: string;
  category: 'people' | 'vendors' | 'emergency_utility';
  label: string;
  contact_name: string | null;
  phone: string | null;
  mobile: string | null;
  email: string | null;
  account_number: string | null;
  fax: string | null;
  is_custom: number;
}
interface Props {
  propertyId: string;
  contacts: Contact[];
  gmName: string | null;
  canEdit: boolean;
}
const { propertyId, contacts, gmName, canEdit } = Astro.props;

type Category = Contact['category'];
const byCategory = (cat: Category) =>
  contacts.filter((c) => c.category === cat);

const people = byCategory('people');
const vendors = byCategory('vendors');
const emergency = byCategory('emergency_utility');

// Which typed fields each category shows, in scan order. Drives both the
// read-only row display and the inline edit form so they stay in sync.
const FIELD_SETS: Record<Category, { key: keyof Contact; label: string; type: string }[]> = {
  people: [
    { key: 'contact_name', label: 'Name', type: 'text' },
    { key: 'phone', label: 'Phone', type: 'tel' },
    { key: 'mobile', label: 'Mobile', type: 'tel' },
    { key: 'email', label: 'Email', type: 'email' },
  ],
  vendors: [
    { key: 'account_number', label: 'Account #', type: 'text' },
    { key: 'phone', label: 'Main line', type: 'tel' },
    { key: 'fax', label: 'Fax', type: 'tel' },
  ],
  emergency_utility: [
    { key: 'phone', label: 'Phone', type: 'tel' },
    { key: 'account_number', label: 'Account #', type: 'text' },
  ],
};

const dash = (v: string | null | undefined) => (v && String(v).trim() ? v : '—');
---

<section class="bg-white border border-[var(--color-hairline)] rounded-xl overflow-hidden">
  <header class="px-5 py-3 border-b border-[var(--color-hairline)]">
    <h2 class="font-semibold text-[var(--color-navy)]">Who to call</h2>
    <p class="text-xs text-[var(--color-muted)] mt-0.5">
      Key people, vendors, and emergency / utility contacts — the directory that runs the site.
    </p>
  </header>

  <!-- ===================== KEY PEOPLE ===================== -->
  <div class="border-b border-[var(--color-hairline)]">
    <div class="px-5 py-2.5 bg-[var(--color-navy)]">
      <h3 class="text-xs font-bold uppercase tracking-widest text-white">Key People</h3>
    </div>

    <ul class="divide-y divide-[var(--color-hairline)]">
      <!-- GM: read-only, pulled from the assigned user. Always first. -->
      <li class="px-5 py-3 bg-[var(--color-cream)]">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)]">General Manager</div>
            <div class="text-sm text-[var(--color-navy)] mt-0.5 font-medium">{dash(gmName)}</div>
          </div>
          <span class="shrink-0 text-[10px] font-semibold uppercase tracking-widest text-[var(--color-muted)] bg-white border border-[var(--color-hairline)] rounded-full px-2 py-0.5">
            From record
          </span>
        </div>
      </li>

      {people.length === 0 ? (
        <li class="px-5 py-4 text-center text-xs text-[var(--color-muted)]">
          No other people added yet.
        </li>
      ) : (
        people.map((c) => (
          <li class="px-5 py-3">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)]">{c.label}</div>
                <dl class="mt-1 grid grid-cols-[auto_1fr] gap-x-3 gap-y-0.5 text-sm">
                  {FIELD_SETS.people.map((f) => (
                    <>
                      <dt class="text-[var(--color-muted)]">{f.label}</dt>
                      <dd class="text-[var(--color-navy)] min-w-0 truncate">{dash(c[f.key] as string | null)}</dd>
                    </>
                  ))}
                </dl>
              </div>
              {canEdit && (
                <div class="flex items-center gap-3 shrink-0 text-xs relative">
                  <details>
                    <summary class="cursor-pointer font-semibold text-[var(--color-navy)] hover:text-[var(--color-brass-dark)] list-none">Edit</summary>
                    <form method="POST" action={`/api/contacts/${c.id}`}
                      class="absolute right-0 mt-2 z-10 w-72 bg-white border border-[var(--color-hairline)] rounded-lg p-3 shadow-lg space-y-2">
                      <input type="hidden" name="action" value="update" />
                      <input name="label" required value={c.label} placeholder="Role / title"
                        class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                      {FIELD_SETS.people.map((f) => (
                        <input name={f.key} type={f.type} value={(c[f.key] as string | null) ?? ''} placeholder={f.label}
                          class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                      ))}
                      <button type="submit" class="btn-primary text-xs w-full">Save</button>
                    </form>
                  </details>
                  {c.is_custom === 1 && (
                    <form method="POST" action={`/api/contacts/${c.id}`}
                      data-confirm={`Delete "${c.label}" from key people?`}>
                      <input type="hidden" name="action" value="delete" />
                      <button type="submit" class="font-semibold text-red-600 hover:text-red-700">Delete</button>
                    </form>
                  )}
                </div>
              )}
            </div>
          </li>
        ))
      )}
    </ul>

    {canEdit && (
      <details class="group">
        <summary class="px-5 py-2.5 text-xs font-semibold text-[var(--color-brass-dark)] hover:bg-[var(--color-cream)] cursor-pointer list-none">
          + Add a person
        </summary>
        <form method="POST" action={`/api/properties/${propertyId}/contacts`}
          class="px-5 py-4 bg-[var(--color-cream)] space-y-2">
          <input type="hidden" name="category" value="people" />
          <input name="label" required placeholder="Role / title — e.g. Housekeeper, Maintenance"
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          {FIELD_SETS.people.map((f) => (
            <input name={f.key} type={f.type} placeholder={f.label}
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          ))}
          <button type="submit" class="btn-ghost text-sm w-full">Add person</button>
        </form>
      </details>
    )}
  </div>

  <!-- ===================== VENDORS ===================== -->
  <div class="border-b border-[var(--color-hairline)]">
    <div class="px-5 py-2.5 bg-[var(--color-brass)]">
      <h3 class="text-xs font-bold uppercase tracking-widest text-white">Vendors</h3>
    </div>

    {vendors.length === 0 ? (
      <div class="px-5 py-4 text-center text-xs text-[var(--color-muted)]">
        No vendors added yet.
      </div>
    ) : (
      <ul class="divide-y divide-[var(--color-hairline)]">
        {vendors.map((c) => (
          <li class="px-5 py-3">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)]">{c.label}</div>
                <dl class="mt-1 grid grid-cols-[auto_1fr] gap-x-3 gap-y-0.5 text-sm">
                  {FIELD_SETS.vendors.map((f) => (
                    <>
                      <dt class="text-[var(--color-muted)]">{f.label}</dt>
                      <dd class="text-[var(--color-navy)] min-w-0 truncate">{dash(c[f.key] as string | null)}</dd>
                    </>
                  ))}
                </dl>
              </div>
              {canEdit && (
                <div class="flex items-center gap-3 shrink-0 text-xs relative">
                  <details>
                    <summary class="cursor-pointer font-semibold text-[var(--color-navy)] hover:text-[var(--color-brass-dark)] list-none">Edit</summary>
                    <form method="POST" action={`/api/contacts/${c.id}`}
                      class="absolute right-0 mt-2 z-10 w-72 bg-white border border-[var(--color-hairline)] rounded-lg p-3 shadow-lg space-y-2">
                      <input type="hidden" name="action" value="update" />
                      <input name="label" required value={c.label} placeholder="Vendor / service"
                        class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                      {FIELD_SETS.vendors.map((f) => (
                        <input name={f.key} type={f.type} value={(c[f.key] as string | null) ?? ''} placeholder={f.label}
                          class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                      ))}
                      <button type="submit" class="btn-primary text-xs w-full">Save</button>
                    </form>
                  </details>
                  {c.is_custom === 1 && (
                    <form method="POST" action={`/api/contacts/${c.id}`}
                      data-confirm={`Delete "${c.label}" from vendors?`}>
                      <input type="hidden" name="action" value="delete" />
                      <button type="submit" class="font-semibold text-red-600 hover:text-red-700">Delete</button>
                    </form>
                  )}
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
    )}

    {canEdit && (
      <details class="group">
        <summary class="px-5 py-2.5 text-xs font-semibold text-[var(--color-brass-dark)] hover:bg-[var(--color-cream)] cursor-pointer list-none">
          + Add a vendor
        </summary>
        <form method="POST" action={`/api/properties/${propertyId}/contacts`}
          class="px-5 py-4 bg-[var(--color-cream)] space-y-2">
          <input type="hidden" name="category" value="vendors" />
          <input name="label" required placeholder="Vendor / service — e.g. Plumber, Linen company"
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          {FIELD_SETS.vendors.map((f) => (
            <input name={f.key} type={f.type} placeholder={f.label}
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          ))}
          <button type="submit" class="btn-ghost text-sm w-full">Add vendor</button>
        </form>
      </details>
    )}
  </div>

  <!-- ===================== EMERGENCY & UTILITIES ===================== -->
  <div>
    <div class="px-5 py-2.5 bg-[var(--color-brass-dark)]">
      <h3 class="text-xs font-bold uppercase tracking-widest text-white">Emergency &amp; Utilities</h3>
    </div>

    {emergency.length === 0 ? (
      <div class="px-5 py-4 text-center text-xs text-[var(--color-muted)]">
        No emergency or utility contacts added yet.
      </div>
    ) : (
      <ul class="divide-y divide-[var(--color-hairline)]">
        {emergency.map((c) => (
          <li class="px-5 py-3">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)]">{c.label}</div>
                <dl class="mt-1 grid grid-cols-[auto_1fr] gap-x-3 gap-y-0.5 text-sm">
                  {FIELD_SETS.emergency_utility.map((f) => (
                    <>
                      <dt class="text-[var(--color-muted)]">{f.label}</dt>
                      <dd class="text-[var(--color-navy)] min-w-0 truncate">{dash(c[f.key] as string | null)}</dd>
                    </>
                  ))}
                </dl>
              </div>
              {canEdit && (
                <div class="flex items-center gap-3 shrink-0 text-xs relative">
                  <details>
                    <summary class="cursor-pointer font-semibold text-[var(--color-navy)] hover:text-[var(--color-brass-dark)] list-none">Edit</summary>
                    <form method="POST" action={`/api/contacts/${c.id}`}
                      class="absolute right-0 mt-2 z-10 w-72 bg-white border border-[var(--color-hairline)] rounded-lg p-3 shadow-lg space-y-2">
                      <input type="hidden" name="action" value="update" />
                      <input name="label" required value={c.label} placeholder="Service / agency"
                        class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                      {FIELD_SETS.emergency_utility.map((f) => (
                        <input name={f.key} type={f.type} value={(c[f.key] as string | null) ?? ''} placeholder={f.label}
                          class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                      ))}
                      <button type="submit" class="btn-primary text-xs w-full">Save</button>
                    </form>
                  </details>
                  {c.is_custom === 1 && (
                    <form method="POST" action={`/api/contacts/${c.id}`}
                      data-confirm={`Delete "${c.label}" from emergency & utilities?`}>
                      <input type="hidden" name="action" value="delete" />
                      <button type="submit" class="font-semibold text-red-600 hover:text-red-700">Delete</button>
                    </form>
                  )}
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
    )}

    {canEdit && (
      <details class="group">
        <summary class="px-5 py-2.5 text-xs font-semibold text-[var(--color-brass-dark)] hover:bg-[var(--color-cream)] cursor-pointer list-none">
          + Add an emergency / utility contact
        </summary>
        <form method="POST" action={`/api/properties/${propertyId}/contacts`}
          class="px-5 py-4 bg-[var(--color-cream)] space-y-2">
          <input type="hidden" name="category" value="emergency_utility" />
          <input name="label" required placeholder="Service / agency — e.g. Electric company, Police (non-emer)"
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          {FIELD_SETS.emergency_utility.map((f) => (
            <input name={f.key} type={f.type} placeholder={f.label}
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          ))}
          <button type="submit" class="btn-ghost text-sm w-full">Add contact</button>
        </form>
      </details>
    )}
  </div>
</section>
