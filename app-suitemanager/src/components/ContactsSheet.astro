---
// Contacts sheet — ONE category of the "Who-to-Call" half of the red binder,
// rendered as a single dashboard card (Key People / Vendors / Emergency &
// Utilities). FactSheetBoard renders three instances, one per category, so a
// cold GM or traveling VP can scan + search fast. Mirrors the property_facts
// API + FactSheet.astro inline-edit (details/summary) pattern.
//
// No-duplication: the GM is shown READ-ONLY from `gmName` (the assigned user),
// never re-entered; address/front-desk phone/fax/email live on the property
// record + Overview, not here. Only the 'people' card shows the GM row.
interface Contact {
  id: string;
  category: 'people' | 'vendors' | 'emergency_utility';
  label: string;
  contact_name: string | null;
  phone: string | null;
  mobile: string | null;
  email: string | null;
  account_number: string | null;
  fax: string | null;
  is_custom: number;
}
type Category = Contact['category'];
interface Props {
  propertyId: string;
  category: Category;
  title: string;
  contacts: Contact[];
  gmName: string | null;
  canEdit: boolean;
}
const { propertyId, category, title, contacts, gmName, canEdit } = Astro.props;

// Caller should already filter, but guard anyway so a single instance only
// ever shows its own category.
const rows = contacts.filter((c) => c.category === category);

// Which typed fields each category shows, in scan order. Drives both the
// read-only row display and the inline edit form so they stay in sync.
const FIELD_SETS: Record<Category, { key: keyof Contact; label: string; type: string }[]> = {
  people: [
    { key: 'contact_name', label: 'Name', type: 'text' },
    { key: 'phone', label: 'Phone', type: 'tel' },
    { key: 'mobile', label: 'Mobile', type: 'tel' },
    { key: 'email', label: 'Email', type: 'email' },
  ],
  vendors: [
    { key: 'account_number', label: 'Account #', type: 'text' },
    { key: 'phone', label: 'Main line', type: 'tel' },
    { key: 'fax', label: 'Fax', type: 'tel' },
  ],
  emergency_utility: [
    { key: 'phone', label: 'Phone', type: 'tel' },
    { key: 'account_number', label: 'Account #', type: 'text' },
  ],
};
const fields = FIELD_SETS[category];

const LABEL_PLACEHOLDER: Record<Category, string> = {
  people: 'Role / title',
  vendors: 'Vendor / service',
  emergency_utility: 'Service / agency',
};
const ADD_LABEL_PLACEHOLDER: Record<Category, string> = {
  people: 'Role / title — e.g. Housekeeper, Maintenance',
  vendors: 'Vendor / service — e.g. Plumber, Linen company',
  emergency_utility: 'Service / agency — e.g. Electric company, Police (non-emer)',
};
const ADD_LABEL: Record<Category, string> = {
  people: 'Add person',
  vendors: 'Add vendor',
  emergency_utility: 'Add contact',
};
const DELETE_SUFFIX: Record<Category, string> = {
  people: 'key people',
  vendors: 'vendors',
  emergency_utility: 'emergency & utilities',
};
const EMPTY_TEXT: Record<Category, string> = {
  people: 'No other people added yet.',
  vendors: 'No vendors added yet.',
  emergency_utility: 'No emergency or utility contacts added yet.',
};

const ANCHOR_ID: Record<Category, string> = {
  people: 'fs-people',
  vendors: 'fs-vendors',
  emergency_utility: 'fs-emergency',
};
const anchorId = ANCHOR_ID[category];

const isPeople = category === 'people';
// Count badge: include the read-only GM row on the People card.
const count = rows.length + (isPeople && gmName ? 1 : 0);

const dash = (v: string | null | undefined) => (v && String(v).trim() ? v : '—');

// Lowercased searchable text for a contact row (label + every typed field).
const searchText = (c: Contact) =>
  [c.label, c.contact_name, c.phone, c.mobile, c.email, c.account_number, c.fax]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();
---

<section
  id={anchorId}
  class="fs-card bg-white border border-[var(--color-hairline)] rounded-xl overflow-hidden scroll-mt-28"
>
  <header class="px-5 py-3 border-b border-[var(--color-hairline)] flex items-center justify-between gap-3">
    <div class="flex items-center gap-2 min-w-0">
      <h2 class="font-semibold text-[var(--color-navy)] truncate">{title}</h2>
      <span class="shrink-0 inline-flex items-center justify-center min-w-[1.5rem] h-6 px-2 text-xs font-semibold rounded-full bg-[var(--color-cream)] border border-[var(--color-hairline)] text-[var(--color-muted)] tabular-nums">
        {count}
      </span>
    </div>
    {canEdit && (
      <a href={`#${anchorId}-add`} class="fs-add-link shrink-0 text-xs font-semibold text-[var(--color-brass-dark)] hover:text-[var(--color-brass)]">
        + Add
      </a>
    )}
  </header>

  <ul class="fs-rows divide-y divide-[var(--color-hairline)]">
    {isPeople && gmName && (
      <!-- GM: read-only, pulled from the assigned user. Always first. -->
      <li
        class="px-5 py-3 bg-[var(--color-cream)]"
        data-fs-row
        data-fs-text={`general manager ${gmName}`.toLowerCase()}
      >
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)]">General Manager</div>
            <div class="text-sm text-[var(--color-navy)] mt-0.5 font-medium">{dash(gmName)}</div>
          </div>
          <span class="shrink-0 text-[10px] font-semibold uppercase tracking-widest text-[var(--color-muted)] bg-white border border-[var(--color-hairline)] rounded-full px-2 py-0.5">
            From record
          </span>
        </div>
      </li>
    )}

    {rows.length === 0 ? (
      <li class="fs-empty px-5 py-4 text-center text-xs text-[var(--color-muted)]">
        {EMPTY_TEXT[category]}
      </li>
    ) : (
      rows.map((c) => (
        <li class="px-5 py-3" data-fs-row data-fs-text={searchText(c)}>
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)]">{c.label}</div>
              <dl class="mt-1 grid grid-cols-[auto_1fr] gap-x-3 gap-y-0.5 text-sm">
                {fields.map((f) => (
                  <>
                    <dt class="text-[var(--color-muted)]">{f.label}</dt>
                    <dd class="text-[var(--color-navy)] min-w-0 truncate">{dash(c[f.key] as string | null)}</dd>
                  </>
                ))}
              </dl>
            </div>
            {canEdit && (
              <div class="flex items-center gap-3 shrink-0 text-xs relative">
                <details>
                  <summary class="cursor-pointer font-semibold text-[var(--color-navy)] hover:text-[var(--color-brass-dark)] list-none">Edit</summary>
                  <form method="POST" action={`/api/contacts/${c.id}`}
                    class="absolute right-0 mt-2 z-10 w-72 bg-white border border-[var(--color-hairline)] rounded-lg p-3 shadow-lg space-y-2">
                    <input type="hidden" name="action" value="update" />
                    <input name="label" required value={c.label} placeholder={LABEL_PLACEHOLDER[category]}
                      class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                    {fields.map((f) => (
                      <input name={f.key} type={f.type} value={(c[f.key] as string | null) ?? ''} placeholder={f.label}
                        class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                    ))}
                    <button type="submit" class="btn-primary text-xs w-full">Save</button>
                  </form>
                </details>
                {c.is_custom === 1 && (
                  <form method="POST" action={`/api/contacts/${c.id}`}
                    data-confirm={`Delete "${c.label}" from ${DELETE_SUFFIX[category]}?`}>
                    <input type="hidden" name="action" value="delete" />
                    <button type="submit" class="font-semibold text-red-600 hover:text-red-700">Delete</button>
                  </form>
                )}
              </div>
            )}
          </div>
        </li>
      ))
    )}
  </ul>

  {canEdit && (
    <details class="group border-t border-[var(--color-hairline)]" id={`${anchorId}-add`}>
      <summary class="px-5 py-2.5 text-xs font-semibold text-[var(--color-brass-dark)] hover:bg-[var(--color-cream)] cursor-pointer list-none">
        + {ADD_LABEL[category]}
      </summary>
      <form method="POST" action={`/api/properties/${propertyId}/contacts`}
        class="px-5 py-4 bg-[var(--color-cream)] space-y-2">
        <input type="hidden" name="category" value={category} />
        <input name="label" required placeholder={ADD_LABEL_PLACEHOLDER[category]}
          class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
        {fields.map((f) => (
          <input name={f.key} type={f.type} placeholder={f.label}
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
        ))}
        <button type="submit" class="btn-ghost text-sm w-full">{ADD_LABEL[category]}</button>
      </form>
    </details>
  )}
</section>
