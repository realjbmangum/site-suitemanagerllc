---
// Credentials vault — the secure half of the red binder. Vendor logins, the
// fire-alarm code, lock-box codes, etc. Passwords are stored ENCRYPTED
// (AES-GCM) and are NEVER server-rendered: each row shows ••••••• with a
// Reveal button that fetches the plaintext from the audited
// /api/credentials/:id/reveal endpoint, displays it briefly, then re-masks.
//
// Mirrors ContactsSheet.astro / FactSheet.astro for styling + inline edit, and
// the property_facts API conventions for create/update/delete. Delete is gated
// to is_custom rows so the seeded template backbone stays intact (same rule as
// ContactsSheet). The `data-confirm` attribute is handled by the page-level
// confirm script that already wraps these components.
interface Credential {
  id: string;
  label: string;
  account_number: string | null;
  username: string | null;
  sort_order: number;
  is_custom: number;
  // NOTE: no password / ciphertext field — secrets never reach the client.
}
interface Props {
  propertyId: string;
  credentials: Credential[];
  canEdit: boolean;
}
const { propertyId, credentials, canEdit } = Astro.props;

const dash = (v: string | null | undefined) => (v && String(v).trim() ? v : '—');
const sorted = [...credentials].sort((a, b) => a.sort_order - b.sort_order);

// Lowercased searchable text — label + account # + username. Never the secret.
const searchText = (c: Credential) =>
  [c.label, c.account_number, c.username].filter(Boolean).join(' ').toLowerCase();
---

<section
  id="fs-credentials"
  class="fs-card bg-white border border-[var(--color-hairline)] rounded-xl overflow-hidden scroll-mt-28"
>
  <header class="px-5 py-3 border-b border-[var(--color-hairline)] flex items-center justify-between gap-3">
    <div class="flex items-center gap-2 min-w-0">
      <span aria-hidden="true" class="text-base leading-6 shrink-0">🔒</span>
      <h2 class="font-semibold text-[var(--color-navy)] truncate">Credentials</h2>
      <span class="shrink-0 inline-flex items-center justify-center min-w-[1.5rem] h-6 px-2 text-xs font-semibold rounded-full bg-[var(--color-cream)] border border-[var(--color-hairline)] text-[var(--color-muted)] tabular-nums">
        {sorted.length}
      </span>
    </div>
    {canEdit && (
      <a href="#fs-credentials-add" class="fs-add-link shrink-0 text-xs font-semibold text-[var(--color-brass-dark)] hover:text-[var(--color-brass)]">
        + Add
      </a>
    )}
  </header>

  {sorted.length === 0 ? (
    <div class="fs-empty px-5 py-8 text-center text-sm text-[var(--color-muted)]">
      No credentials saved yet.
    </div>
  ) : (
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-[var(--color-cream)] text-left">
            <th class="px-5 py-2 text-[10px] font-bold uppercase tracking-widest text-[var(--color-muted)]">System</th>
            <th class="px-5 py-2 text-[10px] font-bold uppercase tracking-widest text-[var(--color-muted)]">Account #</th>
            <th class="px-5 py-2 text-[10px] font-bold uppercase tracking-widest text-[var(--color-muted)]">Username</th>
            <th class="px-5 py-2 text-[10px] font-bold uppercase tracking-widest text-[var(--color-muted)]">Password</th>
            {canEdit && <th class="px-5 py-2 text-[10px] font-bold uppercase tracking-widest text-[var(--color-muted)] text-right">Manage</th>}
          </tr>
        </thead>
        <tbody class="fs-rows divide-y divide-[var(--color-hairline)]">
          {sorted.map((c) => (
            <tr class="align-top" data-fs-row data-fs-text={searchText(c)}>
              <td class="px-5 py-3 font-medium text-[var(--color-navy)] whitespace-nowrap">{c.label}</td>
              <td class="px-5 py-3 text-[var(--color-navy)]">{dash(c.account_number)}</td>
              <td class="px-5 py-3 text-[var(--color-navy)] break-all">{dash(c.username)}</td>
              <td class="px-5 py-3">
                <div class="flex items-center gap-2">
                  <code
                    class="cred-value font-mono text-[var(--color-navy)] tracking-wider select-all"
                    data-cred-id={c.id}
                    data-masked="•••••••"
                  >•••••••</code>
                  <button
                    type="button"
                    class="cred-reveal btn-ghost text-xs px-2 py-1"
                    data-cred-id={c.id}
                    aria-label={`Reveal password for ${c.label}`}
                  >Reveal</button>
                </div>
              </td>
              {canEdit && (
                <td class="px-5 py-3">
                  <div class="flex items-center justify-end gap-3 text-xs relative">
                    <details>
                      <summary class="cursor-pointer font-semibold text-[var(--color-navy)] hover:text-[var(--color-brass-dark)] list-none">Edit</summary>
                      <form method="POST" action={`/api/credentials/${c.id}`}
                        class="absolute right-0 mt-2 z-10 w-72 bg-white border border-[var(--color-hairline)] rounded-lg p-3 shadow-lg space-y-2 text-left">
                        <input type="hidden" name="action" value="update" />
                        <input name="label" required value={c.label} placeholder="System / vendor"
                          class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                        <input name="account_number" value={c.account_number ?? ''} placeholder="Account #"
                          class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                        <input name="username" value={c.username ?? ''} placeholder="Username"
                          autocomplete="off"
                          class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                        <input name="password" type="password" placeholder="New password (leave blank to keep)"
                          autocomplete="new-password"
                          class="w-full rounded-lg border border-[var(--color-hairline)] px-2 py-1.5 text-sm" />
                        <button type="submit" class="btn-primary text-xs w-full">Save</button>
                      </form>
                    </details>
                    {c.is_custom === 1 && (
                      <form method="POST" action={`/api/credentials/${c.id}`}
                        data-confirm={`Delete "${c.label}" from credentials?`}>
                        <input type="hidden" name="action" value="delete" />
                        <button type="submit" class="font-semibold text-red-600 hover:text-red-700">Delete</button>
                      </form>
                    )}
                  </div>
                </td>
              )}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {canEdit && (
    <details class="group border-t border-[var(--color-hairline)]" id="fs-credentials-add">
      <summary class="px-5 py-2.5 text-xs font-semibold text-[var(--color-brass-dark)] hover:bg-[var(--color-cream)] cursor-pointer list-none">
        + Add a credential
      </summary>
      <form method="POST" action={`/api/properties/${propertyId}/credentials`}
        class="px-5 py-4 bg-[var(--color-cream)] space-y-2">
        <input type="hidden" name="action" value="create" />
        <input name="label" required placeholder="System / vendor — e.g. Expedia, Onity key machine, Fire alarm code"
          class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
        <input name="account_number" placeholder="Account # (optional)"
          class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
        <input name="username" placeholder="Username (optional)" autocomplete="off"
          class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
        <input name="password" type="password" placeholder="Password / code" autocomplete="new-password"
          class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
        <button type="submit" class="btn-ghost text-sm w-full">Add credential</button>
      </form>
    </details>
  )}
</section>

<script is:inline>
  (function () {
    var REVEAL_MS = 15000; // auto re-mask after ~15s.

    document.querySelectorAll(".cred-reveal").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var id = btn.getAttribute("data-cred-id");
        if (!id) return;
        var cell = document.querySelector('.cred-value[data-cred-id="' + id + '"]');
        if (!cell) return;

        // Already revealed → re-mask immediately (toggle).
        if (cell.getAttribute("data-revealed") === "1") {
          maskCell(cell, btn);
          return;
        }

        btn.disabled = true;
        var prevLabel = btn.textContent;
        btn.textContent = "…";

        fetch("/api/credentials/" + encodeURIComponent(id) + "/reveal", {
          method: "POST",
          headers: { "x-requested-with": "fetch" },
        })
          .then(function (res) {
            if (!res.ok) throw new Error("reveal failed");
            return res.json();
          })
          .then(function (data) {
            cell.textContent = data && data.value != null ? String(data.value) : "—";
            cell.setAttribute("data-revealed", "1");
            btn.textContent = "Hide";
            btn.disabled = false;

            // Auto re-mask after the window, unless toggled off sooner.
            if (cell._maskTimer) clearTimeout(cell._maskTimer);
            cell._maskTimer = setTimeout(function () {
              maskCell(cell, btn);
            }, REVEAL_MS);
          })
          .catch(function () {
            btn.textContent = prevLabel || "Reveal";
            btn.disabled = false;
            cell.textContent = cell.getAttribute("data-masked") || "•••••••";
            alert("Could not reveal this credential.");
          });
      });
    });

    function maskCell(cell, btn) {
      if (cell._maskTimer) {
        clearTimeout(cell._maskTimer);
        cell._maskTimer = null;
      }
      cell.textContent = cell.getAttribute("data-masked") || "•••••••";
      cell.removeAttribute("data-revealed");
      btn.textContent = "Reveal";
      btn.disabled = false;
    }
  })();
</script>
