---
import "../styles/global.css";

interface Props {
  title: string;
  /** Property name shown right side (for GMs) */
  context?: string;
  /** Initials for the avatar circle */
  initials?: string;
  /** User's name shown next to avatar */
  userName?: string;
  /** Hide the chrome (login page uses bare layout) */
  bare?: boolean;
}

const {
  title,
  context,
  initials,
  userName,
  bare = false,
} = Astro.props;

const user = Astro.locals.user ?? null;
const initialsOf = (name: string) =>
  name.split(/\s+/).filter(Boolean).slice(0, 2).map((w) => w[0]?.toUpperCase() ?? "").join("");
const displayName = user?.name ?? userName;
const displayInitials = user ? initialsOf(user.name) : initials;

const role = user?.role;

// Pending-approval count for the admin nav badge.
let pendingApprovals = 0;
if (role === "admin" && Astro.locals.runtime?.env?.DB) {
  const r = await Astro.locals.runtime.env.DB
    .prepare("SELECT COUNT(*) AS n FROM documents WHERE approval_status = 'pending'")
    .first<{ n: number }>();
  pendingApprovals = r?.n ?? 0;
}

// Role-aware nav. Admin sees everything. Approvals live as a Dashboard tab
// (the badge rides the Dashboard item); account + portal settings live in
// the avatar menu, not the nav.
const navItems: { href: string; label: string; badge?: number }[] = [];
if (role === "gm") navItems.push({ href: "/my-property", label: "My Property" });
if (role === "strand" || role === "admin")
  navItems.push({
    href: "/dashboard",
    label: "Dashboard",
    badge: role === "admin" ? pendingApprovals : undefined,
  });
if (role === "strand" || role === "admin") navItems.push({ href: "/admin/financials", label: "Financials" });
// One "Resources" per role: GMs get the read view, Strand/admin get the
// management view. (Replaces the old split of "Resources" + "HR Templates".)
if (role === "gm") navItems.push({ href: "/resources", label: "Resources" });
if (role === "strand" || role === "admin") navItems.push({ href: "/admin/templates", label: "Resources" });
if (role === "admin") navItems.push({ href: "/admin/properties", label: "Properties" });
if (role === "admin") navItems.push({ href: "/admin/users", label: "Users" });
// /admin/email-preview still exists (reachable by URL) but is unlinked —
// it's a preview tool, not a feature, until Microsoft Graph mail is wired.

const currentPath = new URL(Astro.request.url).pathname;
const isActive = (href: string) =>
  href === currentPath || (href !== "/" && currentPath.startsWith(href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} · Suite Manager</title>
  </head>
  <body>
    {!bare && (
      <header class="bg-[var(--color-navy)] text-white border-b-2 border-[var(--color-brass)]">
        <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between gap-4 flex-wrap">
          <a href="/" class="flex items-center gap-3">
            <img
              src="/logo.png"
              alt="Suite Manager"
              class="h-10 w-auto brightness-0 invert"
            />
            <span class="hidden md:inline-block text-xs uppercase tracking-widest text-[var(--color-brass-light)] border-l border-white/20 pl-3 leading-snug">
              Document<br />portal
            </span>
          </a>

          {navItems.length > 0 && (
            <nav class="order-3 sm:order-2 w-full sm:w-auto sm:flex-1 sm:flex sm:justify-center">
              <ul class="flex items-center gap-1 sm:gap-2 flex-wrap">
                {navItems.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class={`px-3 py-1.5 rounded-md text-sm font-semibold transition-colors inline-flex items-center gap-1.5 ${
                        isActive(item.href)
                          ? "bg-[var(--color-brass)] text-[var(--color-navy)]"
                          : "text-[var(--color-brass-light)] hover:text-white hover:bg-white/10"
                      }`}
                    >
                      {item.label}
                      {item.badge ? (
                        <span class="inline-flex items-center justify-center min-w-[1.1rem] h-[1.1rem] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold">
                          {item.badge}
                        </span>
                      ) : null}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )}
          <div class="order-2 sm:order-3 flex items-center gap-3 text-right">
            {context && (
              <div class="hidden sm:flex flex-col leading-tight text-right">
                <span class="text-xs text-[var(--color-brass-light)]">{context}</span>
              </div>
            )}
            {user && (
              <details id="account-menu" class="relative">
                <summary class="list-none cursor-pointer" aria-label="Account menu">
                  <span class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--color-brass)] text-[var(--color-navy)] font-bold text-sm hover:ring-2 hover:ring-white/40 transition">
                    {displayInitials}
                  </span>
                </summary>
                <div class="absolute right-0 mt-2 w-60 bg-white rounded-xl border border-[var(--color-hairline)] shadow-xl overflow-hidden z-50 text-left">
                  <div class="px-4 py-3 border-b border-[var(--color-hairline)]">
                    <div class="font-semibold text-sm text-[var(--color-navy)]">{displayName}</div>
                    <div class="text-xs text-[var(--color-muted)] truncate">{user.email}</div>
                  </div>
                  <a href="/account" class="block px-4 py-2.5 text-sm text-[var(--color-navy)] hover:bg-[var(--color-cream)]">
                    Account &amp; password
                  </a>
                  <form method="POST" action="/api/auth/logout" class="border-t border-[var(--color-hairline)]">
                    <button type="submit" class="block w-full text-left px-4 py-2.5 text-sm font-semibold text-red-600 hover:bg-[var(--color-cream)]">
                      Sign out
                    </button>
                  </form>
                </div>
              </details>
            )}
          </div>
        </div>
      </header>
    )}

    <main class={bare ? "min-h-screen flex items-center justify-center px-4" : "max-w-6xl mx-auto px-6 py-10"}>
      <slot />
    </main>

    {!bare && (
      <!-- In-app file viewer. Any element with data-viewer-url opens it. -->
      <div id="file-viewer" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-black/70" data-viewer-close></div>
        <div class="relative mx-auto my-6 flex flex-col rounded-xl bg-white shadow-2xl overflow-hidden"
             style="height:calc(100vh - 3rem);width:min(1100px,94vw);">
          <header class="flex items-center justify-between gap-3 border-b border-[var(--color-hairline)] px-5 py-3 shrink-0">
            <span id="viewer-name" class="font-semibold text-[var(--color-navy)] truncate"></span>
            <div class="flex items-center gap-2 shrink-0">
              <a id="viewer-download" class="btn-ghost text-xs" download>Download</a>
              <button type="button" data-viewer-close aria-label="Close"
                class="text-[var(--color-muted)] hover:text-[var(--color-navy)] text-2xl leading-none px-2">&times;</button>
            </div>
          </header>
          <div id="viewer-body" class="flex-1 bg-[var(--color-cream)] overflow-auto"></div>
        </div>
      </div>
    )}

    <script is:inline>
      // In-app file viewer — modal preview for PDFs and images.
      (function () {
        var modal = document.getElementById("file-viewer");
        if (!modal) return;
        var nameEl = document.getElementById("viewer-name");
        var dlEl = document.getElementById("viewer-download");
        var bodyEl = document.getElementById("viewer-body");

        function openViewer(url, downloadUrl, name, type) {
          nameEl.textContent = name || "File";
          dlEl.href = downloadUrl || url;
          bodyEl.innerHTML = "";
          if (type === "pdf") {
            var f = document.createElement("iframe");
            f.src = url;
            f.style.cssText = "width:100%;height:100%;border:0;display:block;";
            bodyEl.appendChild(f);
          } else if (type === "image") {
            var wrap = document.createElement("div");
            wrap.style.cssText = "display:flex;align-items:center;justify-content:center;min-height:100%;padding:24px;";
            var img = document.createElement("img");
            img.src = url;
            img.alt = name || "";
            img.style.cssText = "max-width:100%;max-height:100%;border-radius:6px;box-shadow:0 2px 16px rgba(0,0,0,.15);";
            wrap.appendChild(img);
            bodyEl.appendChild(wrap);
          } else {
            var msg = document.createElement("div");
            msg.style.cssText = "display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100%;gap:12px;color:#6B6B78;text-align:center;padding:24px;";
            var p = document.createElement("p");
            p.textContent = "This file type can't preview in the browser.";
            var a = document.createElement("a");
            a.href = downloadUrl || url;
            a.textContent = "Download to open";
            a.className = "btn-primary text-sm";
            a.setAttribute("download", "");
            msg.appendChild(p);
            msg.appendChild(a);
            bodyEl.appendChild(msg);
          }
          modal.classList.remove("hidden");
          document.body.style.overflow = "hidden";
        }
        function closeViewer() {
          modal.classList.add("hidden");
          bodyEl.innerHTML = "";
          document.body.style.overflow = "";
        }

        document.querySelectorAll("[data-viewer-url]").forEach(function (el) {
          el.addEventListener("click", function (e) {
            e.preventDefault();
            openViewer(
              el.getAttribute("data-viewer-url"),
              el.getAttribute("data-viewer-download"),
              el.getAttribute("data-viewer-name"),
              el.getAttribute("data-viewer-type")
            );
          });
        });
        modal.querySelectorAll("[data-viewer-close]").forEach(function (el) {
          el.addEventListener("click", closeViewer);
        });
        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && !modal.classList.contains("hidden")) closeViewer();
        });
      })();
    </script>

    <script is:inline>
      // Drag-and-drop wiring for every [data-dropzone] on the page.
      // Each dropzone wraps an <input type="file">; an optional element with
      // [data-dropzone-label] shows the chosen filename.
      (function () {
        // Stop the browser from navigating away when a file is dropped
        // outside a zone.
        window.addEventListener("dragover", function (e) { e.preventDefault(); });
        window.addEventListener("drop", function (e) { e.preventDefault(); });

        document.querySelectorAll("[data-dropzone]").forEach(function (zone) {
          var input = zone.querySelector('input[type="file"]');
          if (!input) return;
          var label = zone.querySelector("[data-dropzone-label]");
          var defaultText = label ? label.textContent : "";

          function showName() {
            if (!label) return;
            var f = input.files && input.files[0];
            label.textContent = f ? f.name : defaultText;
          }
          input.addEventListener("change", showName);

          ["dragenter", "dragover"].forEach(function (ev) {
            zone.addEventListener(ev, function (e) {
              e.preventDefault();
              zone.classList.add("dropzone-active");
            });
          });
          ["dragleave", "dragend"].forEach(function (ev) {
            zone.addEventListener(ev, function () {
              zone.classList.remove("dropzone-active");
            });
          });
          zone.addEventListener("drop", function (e) {
            e.preventDefault();
            zone.classList.remove("dropzone-active");
            var files = e.dataTransfer && e.dataTransfer.files;
            if (files && files.length > 0) {
              input.files = files;
              showName();
            }
          });
        });
      })();
    </script>

    <script is:inline>
      // Close the account menu when clicking outside it.
      (function () {
        var menu = document.getElementById("account-menu");
        if (!menu) return;
        document.addEventListener("click", function (e) {
          if (menu.open && !menu.contains(e.target)) menu.open = false;
        });
      })();
    </script>
  </body>
</html>
