---
import PortalLayout from "../../layouts/PortalLayout.astro";
export const prerender = false;

const { token } = Astro.params;
const env = Astro.locals.runtime.env;

const url = new URL(Astro.request.url);
const error = url.searchParams.get("error");

let user: { name: string; email: string; role: string; expires: string | null; activated: boolean } | null = null;
let expired = false;

if (token) {
  const row = await env.DB
    .prepare(
      `SELECT name, email, role, invite_expires_at, password_hash IS NOT NULL AS activated FROM users
       WHERE invite_token = ? AND active = 1`
    )
    .bind(token)
    .first<{ name: string; email: string; role: string; invite_expires_at: string | null; activated: number }>();
  if (row) {
    user = {
      name: row.name,
      email: row.email,
      role: row.role,
      expires: row.invite_expires_at,
      activated: row.activated === 1,
    };
    if (row.invite_expires_at && new Date(row.invite_expires_at) < new Date()) {
      expired = true;
    }
  }
}

// A user who already has a password is resetting it (link came from
// "Forgot password?" or an admin reset); a fresh user is activating an invite.
const isReset = user?.activated ?? false;
---

<PortalLayout title={user ? (isReset ? "Reset your password" : "Set your password") : "Link not found"} bare>
  <div class="w-full max-w-sm">
    <div class="bg-white border border-[var(--color-hairline)] rounded-2xl shadow-sm overflow-hidden">
      <div class="bg-[var(--color-navy)] text-white px-8 py-7 border-b-2 border-[var(--color-brass)] flex flex-col items-center">
        <img
          src="/logo.png"
          alt="Suite Manager"
          class="h-12 w-auto brightness-0 invert"
        />
        <div class="text-[10px] uppercase tracking-[0.25em] text-[var(--color-brass-light)] mt-3">
          Document portal
        </div>
      </div>

      {!user ? (
        <div class="px-8 py-7 text-center">
          <h1 class="text-xl font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">
            Link not found
          </h1>
          <p class="text-sm text-[var(--color-muted)] mt-2">
            This link is invalid or has already been used. Request a new one from the sign-in page or your admin.
          </p>
          <a href="/login" class="btn-ghost mt-5 inline-flex">Back to sign in</a>
        </div>
      ) : expired ? (
        <div class="px-8 py-7 text-center">
          <h1 class="text-xl font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">
            Link expired
          </h1>
          <p class="text-sm text-[var(--color-muted)] mt-2">
            The link for <strong>{user.email}</strong> has expired. {isReset ? "Request a new one from the “Forgot password?” link on the sign-in page." : "Ask your admin to send a new one."}
          </p>
          <a href={isReset ? "/forgot" : "/login"} class="btn-ghost mt-5 inline-flex">{isReset ? "Request a new link" : "Back to sign in"}</a>
        </div>
      ) : (
        <form method="POST" action="/api/auth/activate" class="px-8 py-7 space-y-5">
          <input type="hidden" name="token" value={token} />

          <div>
            <h1 class="text-2xl font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">
              {isReset ? "Reset your password" : `Welcome, ${user.name.split(" ")[0]}`}
            </h1>
            <p class="text-sm text-[var(--color-muted)] mt-1">
              {isReset ? "Choose a new password for" : "Set a password for"} <strong>{user.email}</strong> to {isReset ? "get back into" : "access"} the Suite Manager portal.
            </p>
          </div>

          {error && (
            <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-2.5 text-sm text-red-700">
              {error}
            </div>
          )}

          <div>
            <label for="password" class="block text-xs font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
              New password
            </label>
            <input id="password" name="password" type="password" minlength="8" required autocomplete="new-password"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-3 text-[var(--color-navy)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brass)]/40 focus:border-[var(--color-brass)]" />
          </div>

          <div>
            <label for="confirm" class="block text-xs font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
              Confirm
            </label>
            <input id="confirm" name="confirm" type="password" minlength="8" required autocomplete="new-password"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-3 text-[var(--color-navy)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brass)]/40 focus:border-[var(--color-brass)]" />
          </div>

          <button type="submit" class="btn-primary w-full">{isReset ? "Reset password & sign in" : "Set password & sign in"}</button>
        </form>
      )}
    </div>
  </div>
</PortalLayout>
