---
import PortalLayout from "../layouts/PortalLayout.astro";
import { categoryLabel } from "../lib/files";
export const prerender = false;

const env = Astro.locals.runtime.env;
const me = Astro.locals.user!;
const url = new URL(Astro.request.url);

// Primary view tab. Admins default to the approvals queue; others to Inbox.
const defaultTab = me.role === "admin" ? "approvals" : "new";
const tab = url.searchParams.get("tab") || defaultTab; // approvals | new | reviewed | all

// Filters / view state via URL params.
const category = url.searchParams.get("category") || "all"; // all | invoice | statement | other | expense | mileage
const filter = url.searchParams.get("filter") || "";        // '' | pending | today | week
const propertyId = url.searchParams.get("property") || "";  // '' = all, 'corporate' = Corporate only, else a property id
const q = (url.searchParams.get("q") || "").trim();
const payment = url.searchParams.get("payment") || "";     // '' | unpaid | paid
const sort = url.searchParams.get("sort") || "date";        // date | property | vendor | amount
const dir = (url.searchParams.get("dir") || "desc") === "asc" ? "asc" : "desc";

// All active properties for the selector.
const propertyOptions = await env.DB
  .prepare("SELECT id, name, address_state FROM properties WHERE active = 1 ORDER BY name")
  .all<{ id: string; name: string; address_state: string | null }>();
const selectedProperty = propertyId && propertyId !== "corporate"
  ? propertyOptions.results.find((p) => p.id === propertyId) || null
  : null;
const corporateSelected = propertyId === "corporate";

// Tile aggregates — always over ALL documents, not the filtered view.
const tiles = await env.DB.batch([
  env.DB.prepare("SELECT COUNT(*) AS n FROM documents WHERE created_at >= datetime('now','-1 day')"),
  env.DB.prepare("SELECT COUNT(*) AS n FROM documents WHERE created_at >= datetime('now','-7 day')"),
  env.DB.prepare("SELECT COUNT(*) AS n FROM documents WHERE category = 'invoice' AND payment_status = 'unpaid'"),
  env.DB.prepare(
    `SELECT
      (SELECT COALESCE(SUM(size_bytes), 0) FROM documents) +
      (SELECT COALESCE(SUM(size_bytes), 0) FROM resources WHERE archived_at IS NULL) AS bytes`
  ),
]);
const today = (tiles[0].results[0] as any).n as number;
const week = (tiles[1].results[0] as any).n as number;
const unpaid = (tiles[2].results[0] as any).n as number;
const storageBytes = (tiles[3].results[0] as any).bytes as number;

const fmtBytes = (b: number) => {
  if (b < 1024) return `${b} B`;
  if (b < 1024 * 1024) return `${(b / 1024).toFixed(1)} KB`;
  if (b < 1024 * 1024 * 1024) return `${(b / (1024 * 1024)).toFixed(1)} MB`;
  return `${(b / (1024 * 1024 * 1024)).toFixed(2)} GB`;
};

// Category counts across all documents.
const catCountRows = await env.DB
  .prepare("SELECT category, COUNT(*) AS n FROM documents GROUP BY category")
  .all<{ category: string; n: number }>();
const countByCat: Record<string, number> = {};
for (const r of catCountRows.results) countByCat[r.category] = r.n;

// Build the doc-list query.
const where: string[] = [];
const args: unknown[] = [];
if (tab === "approvals") {
  where.push("d.approval_status = 'pending'");
} else if (tab === "new") {
  where.push("d.status = 'new'");
} else if (tab === "reviewed") {
  where.push("d.status = 'reviewed'");
}
// tab === "all" → no status/approval filter
if (category !== "all") {
  where.push("d.category = ?");
  args.push(category);
}
if (propertyId === "corporate") {
  where.push("d.property_id IS NULL");
} else if (propertyId) {
  where.push("d.property_id = ?");
  args.push(propertyId);
}
if (payment === "unpaid" || payment === "paid") {
  where.push("d.payment_status = ?");
  args.push(payment);
}
if (filter === "pending") {
  where.push("d.category = 'invoice' AND d.payment_status = 'unpaid'");
} else if (filter === "today") {
  where.push("d.created_at >= datetime('now','-1 day')");
} else if (filter === "week") {
  where.push("d.created_at >= datetime('now','-7 day')");
}
if (q) {
  where.push("(LOWER(d.filename) LIKE ? OR LOWER(COALESCE(d.vendor,'')) LIKE ? OR LOWER(p.name) LIKE ?)");
  const like = `%${q.toLowerCase()}%`;
  args.push(like, like, like);
}
const whereSql = where.length ? `WHERE ${where.join(" AND ")}` : "";

const sortColumn: Record<string, string> = {
  date: "d.created_at",
  property: "p.name",
  vendor: "d.vendor",
  amount: "d.amount_cents",
};
const orderSql = `ORDER BY ${sortColumn[sort] ?? "d.created_at"} ${dir === "asc" ? "ASC" : "DESC"}, d.created_at DESC`;

const rows = await env.DB
  .prepare(
    `SELECT d.id, d.filename, d.category, d.vendor, d.amount_cents, d.note,
            d.flagged, d.status, d.payment_status, d.check_number, d.check_date,
            d.approval_status, d.created_at, d.reviewed_at, d.property_id,
            p.name AS property_name, u.name AS gm_name
     FROM documents d
     LEFT JOIN properties p ON p.id = d.property_id
     LEFT JOIN users u ON u.id = d.uploaded_by
     ${whereSql}
     ${orderSql}
     LIMIT 100`
  )
  .bind(...args)
  .all<{
    id: string; filename: string; category: string;
    vendor: string | null; amount_cents: number | null; note: string | null;
    flagged: number; status: string;
    payment_status: string; check_number: string | null; check_date: string | null;
    approval_status: string;
    created_at: string; reviewed_at: string | null; property_id: string;
    property_name: string | null; gm_name: string | null;
  }>();

const fmtTime = (iso: string) => {
  const d = new Date(iso + "Z");
  const diff = (Date.now() - d.getTime()) / 60000;
  if (diff < 1) return "just now";
  if (diff < 60) return `${Math.round(diff)} min ago`;
  if (diff < 1440) return `${Math.round(diff / 60)} hr ago`;
  return d.toLocaleDateString();
};

const fmtMoney = (cents: number | null) =>
  cents != null ? `$${(cents / 100).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "—";

const pillClass = (cat: string) =>
  cat === "invoice" ? "pill-invoice" :
  cat === "statement" ? "pill-statement" :
  cat === "expense" ? "pill-other" :
  cat === "mileage" ? "pill-other" :
  "pill-other";

// URL builders.
const buildHref = (overrides: Record<string, string | null>) => {
  const u = new URL(url);
  for (const [k, v] of Object.entries(overrides)) {
    if (v === null || v === "") u.searchParams.delete(k);
    else u.searchParams.set(k, v);
  }
  return u.pathname + (u.search || "");
};

const tileHref = (key: string, active: boolean) =>
  buildHref({ filter: active ? null : key });

const catHref = (cat: string) =>
  buildHref({ category: cat === "all" ? null : cat });

const tabHref = (t: string) => buildHref({ tab: t });

const tabOptions =
  me.role === "admin"
    ? [
        { v: "approvals", label: "Awaiting approval" },
        { v: "new", label: "Inbox" },
        { v: "reviewed", label: "Reviewed" },
        { v: "all", label: "All" },
      ]
    : [
        { v: "new", label: "Inbox" },
        { v: "reviewed", label: "Reviewed" },
        { v: "all", label: "All" },
      ];

const sortHref = (col: string) => {
  const sameCol = sort === col;
  const nextDir = sameCol && dir === "desc" ? "asc" : "desc";
  return buildHref({ sort: col === "date" ? null : col, dir: nextDir === "desc" ? null : "asc" });
};

const sortIndicator = (col: string) => (sort === col ? (dir === "asc" ? "↑" : "↓") : "");
---

<PortalLayout title="Incoming documents" context="Strand Hospitality">
  <div class="flex items-end justify-between mb-6 flex-wrap gap-4">
    <div>
      <h1 class="text-3xl font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">
        Incoming documents
      </h1>
      <p class="text-sm text-[var(--color-muted)] mt-1">
        {corporateSelected
          ? "Corporate — expense reports, mileage, special invoices"
          : selectedProperty
          ? `${selectedProperty.name}${selectedProperty.address_state ? ", " + selectedProperty.address_state : ""}`
          : "Strand Hospitality back-office inbox"} · {rows.results.length} {rows.results.length === 1 ? "match" : "matches"}
      </p>
    </div>
    <a
      href={"/api/documents/export" + (url.search || "")}
      class="btn-ghost text-sm"
      title="Download the current view as a CSV (opens in Excel)"
    >
      Export to Excel
    </a>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
    <a href={tileHref("today", filter === "today")} class={`rounded-xl border p-4 transition-colors ${
      filter === "today" ? "border-[var(--color-navy)] bg-white shadow-sm" : "bg-white border-[var(--color-hairline)] hover:border-[var(--color-navy)]"
    }`}>
      <div class="text-xs font-semibold text-[var(--color-muted)] uppercase tracking-widest">Today</div>
      <div class="text-2xl font-bold text-[var(--color-navy)] mt-1">{today}</div>
    </a>
    <a href={tileHref("week", filter === "week")} class={`rounded-xl border p-4 transition-colors ${
      filter === "week" ? "border-[var(--color-navy)] bg-white shadow-sm" : "bg-white border-[var(--color-hairline)] hover:border-[var(--color-navy)]"
    }`}>
      <div class="text-xs font-semibold text-[var(--color-muted)] uppercase tracking-widest">This week</div>
      <div class="text-2xl font-bold text-[var(--color-navy)] mt-1">{week}</div>
    </a>
    <a href={tileHref("pending", filter === "pending")} class={`rounded-xl border p-4 transition-colors ${
      filter === "pending"
        ? "border-[var(--color-brass)] bg-[var(--color-brass-light)]/30"
        : "bg-[var(--color-brass-light)]/20 border-[var(--color-brass)] hover:bg-[var(--color-brass-light)]/30"
    }`}>
      <div class="text-xs font-semibold text-[var(--color-brass-dark)] uppercase tracking-widest">Unpaid invoices</div>
      <div class="text-2xl font-bold text-[var(--color-navy)] mt-1">{unpaid}</div>
    </a>
    <div class="rounded-xl border bg-white border-[var(--color-hairline)] p-4" title="Sum of GM uploads + HR templates in R2">
      <div class="text-xs font-semibold text-[var(--color-muted)] uppercase tracking-widest">Storage used</div>
      <div class="text-2xl font-bold text-[var(--color-navy)] mt-1">{fmtBytes(storageBytes)}</div>
    </div>
  </div>

  <!-- View tabs -->
  <div class="border-b border-[var(--color-hairline)] mb-4">
    <nav class="flex gap-1 flex-wrap">
      {tabOptions.map((t) => (
        <a
          href={tabHref(t.v)}
          class={`px-4 py-2.5 text-sm font-semibold transition-colors border-b-2 -mb-px ${
            tab === t.v
              ? "border-[var(--color-brass)] text-[var(--color-navy)]"
              : "border-transparent text-[var(--color-muted)] hover:text-[var(--color-navy)]"
          }`}
        >
          {t.label}
        </a>
      ))}
    </nav>
  </div>

  <div class="flex items-center gap-2 mb-3 flex-wrap">
    {[
      { v: "all", label: "All categories", count: null },
      { v: "invoice", label: "Invoices", count: countByCat.invoice ?? 0 },
      { v: "statement", label: "Statements", count: countByCat.statement ?? 0 },
      { v: "expense", label: "Expenses", count: countByCat.expense ?? 0 },
      { v: "mileage", label: "Mileage", count: countByCat.mileage ?? 0 },
      { v: "deposit_slip", label: "Deposit Slips", count: countByCat.deposit_slip ?? 0 },
      { v: "other", label: "Other", count: countByCat.other ?? 0 },
    ].map((f) => (
      <a href={catHref(f.v)} class={`pill ${
        category === f.v
          ? f.v === "invoice" ? "pill-invoice"
          : f.v === "statement" ? "pill-statement"
          : "pill-other"
          : "bg-white border border-[var(--color-hairline)] text-[var(--color-navy)] hover:bg-[var(--color-cream)]"
      }`}>
        {f.label}{f.count !== null ? ` · ${f.count}` : ""}
      </a>
    ))}
  </div>

  <form method="GET" class="mb-4 flex flex-wrap items-center gap-2">
    <input type="hidden" name="tab" value={tab} />
    {category !== "all" && <input type="hidden" name="category" value={category} />}
    {filter && <input type="hidden" name="filter" value={filter} />}
    {sort !== "date" && <input type="hidden" name="sort" value={sort} />}
    {dir !== "desc" && <input type="hidden" name="dir" value={dir} />}
    <input
      type="search"
      name="q"
      value={q}
      placeholder="Search property, file, or vendor"
      class="flex-1 min-w-[220px] sm:max-w-96 rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-2.5 text-sm text-[var(--color-navy)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brass)]/40 focus:border-[var(--color-brass)]"
    />
    <select
      name="property"
      class="rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2.5 text-sm text-[var(--color-navy)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brass)]/40 focus:border-[var(--color-brass)] min-w-[200px]"
      onchange="this.form.submit()"
    >
      <option value="">All properties + Corporate</option>
      <option value="corporate" selected={corporateSelected}>Corporate</option>
      {propertyOptions.results.map((p) => (
        <option value={p.id} selected={propertyId === p.id}>
          {p.name}{p.address_state ? `, ${p.address_state}` : ""}
        </option>
      ))}
    </select>
    <button type="submit" class="btn-ghost text-sm">Apply</button>
    {(selectedProperty || corporateSelected) && (
      <a
        href={buildHref({ property: null })}
        class="text-xs text-[var(--color-muted)] hover:text-[var(--color-navy)]"
      >
        Clear property filter
      </a>
    )}
  </form>

  <script is:inline>
    // Row click → navigate to detail. Skip when the click originated on a
    // button, link, form, or the actions cell.
    document.querySelectorAll("tr[data-href]").forEach((row) => {
      row.addEventListener("click", (e) => {
        const t = e.target;
        if (
          t.closest("a") ||
          t.closest("button") ||
          t.closest("form") ||
          t.closest("[data-no-row-click]")
        ) return;
        window.location.href = row.dataset.href;
      });
    });
  </script>

  <div class="bg-white border border-[var(--color-hairline)] rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-[var(--color-cream)] text-xs font-semibold uppercase tracking-widest text-[var(--color-muted)]">
        <tr>
          <th class="text-left px-5 py-3">
            <a href={sortHref("property")} class="inline-flex items-center gap-1 hover:text-[var(--color-navy)]">
              Property / GM <span class="text-[var(--color-brass)]">{sortIndicator("property")}</span>
            </a>
          </th>
          <th class="text-left px-5 py-3">
            <a href={sortHref("vendor")} class="inline-flex items-center gap-1 hover:text-[var(--color-navy)]">
              File / Vendor <span class="text-[var(--color-brass)]">{sortIndicator("vendor")}</span>
            </a>
          </th>
          <th class="text-left px-5 py-3">Category</th>
          <th class="text-right px-5 py-3">
            <a href={sortHref("amount")} class="inline-flex items-center gap-1 hover:text-[var(--color-navy)]">
              Amount <span class="text-[var(--color-brass)]">{sortIndicator("amount")}</span>
            </a>
          </th>
          <th class="text-left px-5 py-3">
            <a href={sortHref("date")} class="inline-flex items-center gap-1 hover:text-[var(--color-navy)]">
              Received <span class="text-[var(--color-brass)]">{sortIndicator("date")}</span>
            </a>
          </th>
          <th class="text-right px-5 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        {rows.results.length === 0 && (
          <tr>
            <td colspan="6" class="px-5 py-10 text-center text-[var(--color-muted)]">
              {tab === "approvals"
                ? "Nothing awaiting approval — you're clear."
                : tab === "new"
                ? "Inbox is clear — no new documents."
                : "No documents match this view."}
            </td>
          </tr>
        )}
        {rows.results.map((r) => (
          <tr
            data-href={`/dashboard/${r.id}`}
            class={`border-t border-[var(--color-hairline)] cursor-pointer transition-colors hover:bg-[var(--color-cream)] ${
              r.flagged && r.status === "new" ? "bg-[var(--color-brass-light)]/10" : ""
            }`}
          >
            <td class="px-5 py-3">
              {r.property_id ? (
                <a href={`/admin/properties/${r.property_id}`}
                  class="font-semibold text-[var(--color-navy)] hover:text-[var(--color-brass-dark)]">
                  {r.property_name || "—"}
                </a>
              ) : (
                <span class="inline-flex items-center gap-1 font-semibold text-[var(--color-brass-dark)]">
                  <span class="pill bg-[var(--color-brass-light)]/30 text-[var(--color-brass-dark)] border border-[var(--color-brass)] text-xs">Corporate</span>
                </span>
              )}
              <div class="text-xs text-[var(--color-muted)]">{r.gm_name || ""}</div>
            </td>
            <td class="px-5 py-3 text-[var(--color-navy)]">
              <div class="flex items-center gap-2">
                <a href={`/dashboard/${r.id}`} class="hover:text-[var(--color-brass-dark)]">{r.filename}</a>
                {r.note && (
                  <span title={r.note} class="inline-flex items-center text-[var(--color-brass-dark)] text-sm" aria-label="Has note">
                    💬
                  </span>
                )}
              </div>
              {r.vendor && <div class="text-xs text-[var(--color-muted)]">{r.vendor}</div>}
              {r.note && (
                <div class="text-xs italic text-[var(--color-muted)] mt-0.5 truncate max-w-md">
                  “{r.note}”
                </div>
              )}
            </td>
            <td class="px-5 py-3">
              <div class="flex flex-col gap-1 items-start">
                <span class={`pill ${pillClass(r.category)}`}>{categoryLabel(r.category)}</span>
                {r.approval_status === "pending" && (
                  <span class="pill bg-amber-100 text-amber-800 border border-amber-300">Awaiting approval</span>
                )}
                {r.approval_status === "denied" && (
                  <span class="pill bg-red-100 text-red-700 border border-red-200">Denied</span>
                )}
                {r.category === "invoice" && (
                  r.payment_status === "paid" ? (
                    <span class="pill bg-green-100 text-green-800 border border-green-200" title={`Check #${r.check_number || "?"} · ${r.check_date || "?"}`}>Paid</span>
                  ) : (
                    <span class="pill bg-[var(--color-brass-light)]/30 text-[var(--color-brass-dark)] border border-[var(--color-brass)]">Unpaid</span>
                  )
                )}
              </div>
            </td>
            <td class="px-5 py-3 text-right tabular-nums text-[var(--color-navy)]">{fmtMoney(r.amount_cents)}</td>
            <td class="px-5 py-3 text-[var(--color-muted)]">
              {fmtTime(r.created_at)}
              {r.status === "reviewed" && r.reviewed_at && (
                <div class="text-[10px] text-green-700 mt-0.5">
                  Reviewed {fmtTime(r.reviewed_at)}
                </div>
              )}
            </td>
            <td class="px-3 py-3" data-no-row-click>
              <div class="flex items-center justify-end gap-2">
                <a
                  href={`/dashboard/${r.id}`}
                  class="text-xs font-semibold px-2.5 py-1.5 rounded-md text-[var(--color-navy)] hover:bg-white border border-[var(--color-hairline)]"
                >
                  Open
                </a>
                <a
                  href={`/api/documents/${r.id}/download`}
                  title="Download"
                  class="inline-flex items-center justify-center w-8 h-8 rounded-md hover:bg-white text-[var(--color-navy)]"
                >
                  ↓
                </a>
                <form method="POST" action={`/api/documents/${r.id}/review`} class="inline">
                  <input type="hidden" name="status" value={r.status === "new" ? "reviewed" : "new"} />
                  <button
                    type="submit"
                    class={`text-xs font-semibold px-2.5 py-1.5 rounded-md transition-colors ${
                      r.status === "new"
                        ? "bg-[var(--color-navy)] text-white hover:bg-[var(--color-navy-700)]"
                        : "text-[var(--color-muted)] hover:bg-white"
                    }`}
                  >
                    {r.status === "new" ? "Mark reviewed" : "Reopen"}
                  </button>
                </form>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</PortalLayout>
