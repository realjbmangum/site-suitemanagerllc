---
import PortalLayout from "../layouts/PortalLayout.astro";
export const prerender = false;

const url = new URL(Astro.request.url);
const error = url.searchParams.get("error");
const sent = url.searchParams.get("sent") === "1";

// If already signed in, there's nothing to reset from here.
if (Astro.locals.user) {
  const { roleHome } = await import("../lib/session");
  return Astro.redirect(roleHome(Astro.locals.user.role));
}
---

<PortalLayout title="Reset password" bare>
  <div class="w-full max-w-sm">
    <div class="bg-white border border-[var(--color-hairline)] rounded-2xl shadow-sm overflow-hidden">
      <div class="bg-[var(--color-navy)] text-white px-8 py-7 border-b-2 border-[var(--color-brass)] flex flex-col items-center">
        <img
          src="/logo.png"
          alt="Suite Manager"
          class="h-12 w-auto brightness-0 invert"
        />
        <div class="text-[10px] uppercase tracking-[0.25em] text-[var(--color-brass-light)] mt-3">
          Document portal
        </div>
      </div>

      {sent ? (
        <div class="px-8 py-7">
          <h1 class="text-2xl font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">
            Check your email
          </h1>
          <p class="text-sm text-[var(--color-muted)] mt-2">
            If that address has a Suite Manager account, we just sent a link to
            reset your password. It expires in 2 hours.
          </p>
          <p class="text-sm text-[var(--color-muted)] mt-3">
            Didn't get it? Check spam, or contact your Suite Manager admin and
            they can reset it for you.
          </p>
          <a href="/login" class="btn-ghost mt-5 inline-flex">Back to sign in</a>
        </div>
      ) : (
        <form method="POST" action="/api/auth/forgot" class="px-8 py-7 space-y-5">
          <div>
            <h1 class="text-2xl font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">
              Forgot your password?
            </h1>
            <p class="text-sm text-[var(--color-muted)] mt-1">
              Enter your email and we'll send you a link to choose a new one.
            </p>
          </div>

          {error && (
            <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-2.5 text-sm text-red-700">
              {error}
            </div>
          )}

          <div>
            <label for="email" class="block text-xs font-semibold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
              Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-3 text-[var(--color-navy)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brass)]/40 focus:border-[var(--color-brass)]"
            />
          </div>

          <button type="submit" class="btn-primary w-full">Send reset link</button>

          <p class="text-xs text-center text-[var(--color-muted)]">
            <a href="/login" class="font-semibold text-[var(--color-navy)] hover:text-[var(--color-brass-dark)]">
              Back to sign in
            </a>
          </p>
        </form>
      )}
    </div>

    <p class="text-center text-xs text-[var(--color-muted)] mt-6">
      &copy; {new Date().getFullYear()} Suite Manager LLC
    </p>
  </div>
</PortalLayout>
