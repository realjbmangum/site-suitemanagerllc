---
import PortalLayout from "../layouts/PortalLayout.astro";
export const prerender = false;

const env = Astro.locals.runtime.env;
const user = Astro.locals.user!;
const url = new URL(Astro.request.url);
const uploaded = url.searchParams.get("uploaded") === "1";
const error = url.searchParams.get("error");

let propertyName: string | null = null;
let propertyId: string | null = user.propertyId;

if (propertyId) {
  const p = await env.DB
    .prepare("SELECT name FROM properties WHERE id = ?")
    .bind(propertyId)
    .first<{ name: string }>();
  propertyName = p?.name ?? null;
}

// Admin testing: list properties so they can pick one.
let adminProperties: { id: string; name: string }[] = [];
if (user.role === "admin") {
  const list = await env.DB
    .prepare("SELECT id, name FROM properties WHERE active = 1 ORDER BY name")
    .all<{ id: string; name: string }>();
  adminProperties = list.results;
}

// Recent uploads strip.
const recent = await env.DB
  .prepare(
    `SELECT id, filename, category, created_at FROM documents
     WHERE uploaded_by = ?
     ORDER BY created_at DESC LIMIT 5`
  )
  .bind(user.id)
  .all<{ id: string; filename: string; category: string; created_at: string }>();

const fmtTime = (iso: string) => {
  const d = new Date(iso + "Z");
  const diff = (Date.now() - d.getTime()) / 60000;
  if (diff < 1) return "just now";
  if (diff < 60) return `${Math.round(diff)} min ago`;
  if (diff < 1440) return `${Math.round(diff / 60)} hr ago`;
  return d.toLocaleDateString();
};

const recipientFor = (cat: string) =>
  cat === "invoice" || cat === "statement" ? "Strand Accounting" : "Suite Manager";
---

<PortalLayout title="Upload" context={propertyName || (user.role === "admin" ? "Admin · pick a property" : "No property assigned")}>
  <section class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold text-[var(--color-navy)] mb-1" style="font-family: var(--font-display);">
      Send a document to Strand
    </h1>
    <p class="text-[var(--color-muted)] mb-6">
      Invoices, statements, and operating documents go straight to the right team.
    </p>

    {uploaded && (
      <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-5 py-4 text-sm text-green-800">
        Sent. It's now in the back-office inbox.
      </div>
    )}

    {error && (
      <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700">
        {error}
      </div>
    )}

    {user.role !== "admin" && !propertyId && (
      <div class="mb-6 rounded-xl border border-[var(--color-brass)] bg-[var(--color-brass-light)]/15 px-5 py-4 text-sm text-[var(--color-navy)]">
        Your account is not assigned to a property yet. Ask your admin to assign you before uploading.
      </div>
    )}

    <form
      method="POST"
      action="/api/upload"
      enctype="multipart/form-data"
      class="bg-white border border-[var(--color-hairline)] rounded-2xl p-6 sm:p-8 space-y-6"
    >
      {user.role === "admin" && (
        <div>
          <label for="property_id" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
            Property (admin test)
          </label>
          <select id="property_id" name="property_id" required
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-3 text-[var(--color-navy)]">
            <option value="">— pick one —</option>
            {adminProperties.map((p) => (
              <option value={p.id}>{p.name}</option>
            ))}
          </select>
          {adminProperties.length === 0 && (
            <p class="text-xs text-[var(--color-muted)] mt-1">
              No properties exist yet. Create one in <a href="/admin/users" class="underline">Users → add a property</a> (coming soon) or insert via SQL.
            </p>
          )}
        </div>
      )}

      <label class="block border-2 border-dashed border-[var(--color-brass)] rounded-xl bg-[var(--color-brass-light)]/15 px-6 py-10 text-center cursor-pointer hover:bg-[var(--color-brass-light)]/25 transition-colors">
        <input type="file" name="file" class="hidden" required
          accept="application/pdf,image/jpeg,image/png,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel"
          id="file-input" />
        <div class="text-[var(--color-brass-dark)] font-semibold" id="file-label">
          Drag a file here, or click to browse
        </div>
        <div class="text-xs text-[var(--color-muted)] mt-1">
          PDF, JPG, PNG, or Excel · up to 25 MB
        </div>
      </label>

      <div>
        <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-2">
          What kind of document?
        </div>
        <div class="grid grid-cols-3 gap-2">
          {[
            { value: "invoice", label: "Invoice" },
            { value: "statement", label: "Statement" },
            { value: "other", label: "Other" },
          ].map((opt) => (
            <label class="flex items-center justify-center cursor-pointer rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-3 has-[:checked]:bg-[var(--color-navy)] has-[:checked]:text-white has-[:checked]:border-[var(--color-navy)] transition-colors">
              <input type="radio" name="category" value={opt.value} class="hidden" required />
              <span class="font-semibold text-sm">{opt.label}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="amount" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
            Invoice amount
          </label>
          <input id="amount" name="amount" type="number" step="0.01" min="0" placeholder="$ 0.00"
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-3 text-[var(--color-navy)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brass)]/40 focus:border-[var(--color-brass)]" />
        </div>
        <div>
          <label for="vendor" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
            Vendor
          </label>
          <input id="vendor" name="vendor" type="text" placeholder="Cintas, Ecolab, …"
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-3 text-[var(--color-navy)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brass)]/40 focus:border-[var(--color-brass)]" />
        </div>
      </div>

      <div>
        <label for="note" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
          Note for Strand (optional)
        </label>
        <textarea id="note" name="note" rows="3"
          class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-3 text-[var(--color-navy)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brass)]/40 focus:border-[var(--color-brass)]"></textarea>
      </div>

      <div class="flex justify-end gap-3">
        <button type="reset" class="btn-ghost">Cancel</button>
        <button type="submit" class="btn-primary">Send to Strand</button>
      </div>
    </form>

    <div class="mt-8 bg-white border border-[var(--color-hairline)] rounded-2xl p-6">
      <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-3">
        Your recent uploads
      </div>
      {recent.results.length === 0 ? (
        <p class="text-sm text-[var(--color-muted)]">
          Nothing uploaded yet.
        </p>
      ) : (
        <ul class="space-y-2">
          {recent.results.map((r) => (
            <li class="flex items-center justify-between text-sm">
              <span class="font-medium text-[var(--color-navy)]">{r.filename}</span>
              <span class="text-[var(--color-muted)]">
                Received by {recipientFor(r.category)} · {fmtTime(r.created_at)}
              </span>
            </li>
          ))}
        </ul>
      )}
    </div>

    <script is:inline>
      const inp = document.getElementById("file-input");
      const lab = document.getElementById("file-label");
      if (inp && lab) {
        inp.addEventListener("change", () => {
          const f = inp.files && inp.files[0];
          lab.textContent = f ? f.name : "Drag a file here, or click to browse";
        });
      }
    </script>
  </section>
</PortalLayout>
