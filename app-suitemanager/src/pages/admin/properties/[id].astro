---
import PortalLayout from "../../../layouts/PortalLayout.astro";
import { STATEMENT_TYPES, typeLabel, periodLabel, MONTH_LABELS } from "../../../lib/financials";
import FactSheet from "../../../components/FactSheet.astro";
import PropertyFiles from "../../../components/PropertyFiles.astro";
export const prerender = false;

const env = Astro.locals.runtime.env;
const { id } = Astro.params;
const url = new URL(Astro.request.url);
const uploaded = url.searchParams.get("uploaded") === "1";
const errorMsg = url.searchParams.get("error");
const now = new Date();
const defaultYear = now.getFullYear();
const defaultMonth = now.getMonth() + 1;

const p = await env.DB
  .prepare(
    `SELECT id, name, code, brand, owner_group,
            address_street, address_city, address_state, address_zip,
            room_count, phone, fax, emergency_phone, property_email,
            active, created_at
     FROM properties WHERE id = ?`
  )
  .bind(id)
  .first<{
    id: string; name: string; code: string | null; brand: string | null;
    owner_group: string | null;
    address_street: string | null; address_city: string | null;
    address_state: string | null; address_zip: string | null;
    room_count: number | null; phone: string | null;
    fax: string | null; emergency_phone: string | null;
    property_email: string | null;
    active: number; created_at: string;
  }>();

if (!p) return Astro.redirect("/admin/properties?error=Not+found");

const gms = await env.DB
  .prepare(
    `SELECT id, name, email, password_hash IS NOT NULL AS activated
     FROM users WHERE property_id = ? AND role = 'gm' ORDER BY active DESC, name`
  )
  .bind(id)
  .all<{ id: string; name: string; email: string; activated: number }>();

const recent = await env.DB
  .prepare(
    `SELECT id, filename, category, vendor, amount_cents, status, payment_status, created_at
     FROM documents WHERE property_id = ? ORDER BY created_at DESC`
  )
  .bind(id)
  .all<{
    id: string; filename: string; category: string;
    vendor: string | null; amount_cents: number | null;
    status: string; payment_status: string; created_at: string;
  }>();

const stats = await env.DB
  .prepare(
    `SELECT
      (SELECT COUNT(*) FROM documents WHERE property_id = ?) AS total,
      (SELECT COUNT(*) FROM documents WHERE property_id = ? AND status = 'new') AS new_count,
      (SELECT COALESCE(SUM(amount_cents), 0) FROM documents WHERE property_id = ? AND category = 'invoice' AND created_at >= datetime('now','-30 day')) AS invoice_30d`
  )
  .bind(id, id, id)
  .first<{ total: number; new_count: number; invoice_30d: number }>();

const financials = await env.DB
  .prepare(
    `SELECT id, statement_type, period_year, period_month, title, filename, mime_type, created_at
     FROM financial_statements
     WHERE property_id = ? AND archived_at IS NULL
     ORDER BY period_year DESC, period_month DESC, created_at DESC`
  )
  .bind(id)
  .all<{ id: string; statement_type: string; period_year: number; period_month: number | null; title: string; filename: string; mime_type: string; created_at: string }>();

const facts = await env.DB
  .prepare("SELECT id, label, value FROM property_facts WHERE property_id = ? ORDER BY sort_order, created_at")
  .bind(id)
  .all<{ id: string; label: string; value: string }>();

const propertyFiles = await env.DB
  .prepare(
    `SELECT id, category, title, description, expires_at, filename, mime_type, created_at
     FROM property_files WHERE property_id = ? AND archived_at IS NULL
     ORDER BY created_at DESC`
  )
  .bind(id)
  .all<{ id: string; category: string; title: string; description: string | null; expires_at: string | null; filename: string; mime_type: string; created_at: string }>();

const viewerType = (mime: string) =>
  mime.includes("pdf") ? "pdf" : mime.startsWith("image/") ? "image" : "other";
const fmtMoney = (cents: number | null) =>
  cents != null ? `$${(cents / 100).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "—";
const fmtRel = (iso: string) => {
  const d = new Date(iso + "Z");
  const diff = (Date.now() - d.getTime()) / 60000;
  if (diff < 1) return "just now";
  if (diff < 60) return `${Math.round(diff)} min ago`;
  if (diff < 1440) return `${Math.round(diff / 60)} hr ago`;
  if (diff < 1440 * 30) return `${Math.round(diff / 1440)} days ago`;
  return d.toLocaleDateString();
};

const brandLabel =
  p.brand === "asa" ? "Affordable Suites of America" :
  p.brand === "acs" ? "Affordable Corporate Suites" :
  "Unbranded";
const fullAddress = [p.address_street, p.address_city, p.address_state, p.address_zip]
  .filter(Boolean)
  .join(", ");
const pillClass = (cat: string) =>
  cat === "invoice" ? "pill-invoice" :
  cat === "statement" ? "pill-statement" : "pill-other";

const tabs = [
  { id: "overview", label: "Overview" },
  { id: "documents", label: "Documents", count: recent.results.length },
  { id: "financials", label: "Financials", count: financials.results.length },
  { id: "factsheet", label: "Fact Sheet", count: facts.results.length },
  { id: "records", label: "Records", count: propertyFiles.results.length },
];
---

<PortalLayout title={p.name}>
  <a href="/admin/properties" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-navy)] mb-4 inline-flex items-center gap-1">
    ← Back to properties
  </a>

  <!-- Header (pinned above the tabs) -->
  <div class="flex items-start justify-between gap-4 flex-wrap mb-5">
    <div>
      <div class="flex items-center gap-3 mb-2">
        {p.code && <span class="font-mono text-xs px-2 py-1 rounded bg-[var(--color-hairline)] text-[var(--color-muted)]">{p.code}</span>}
        <span class="text-xs uppercase tracking-widest text-[var(--color-muted)]">{brandLabel}</span>
      </div>
      <h1 class="text-3xl font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">{p.name}</h1>
      {fullAddress && <p class="text-sm text-[var(--color-muted)] mt-1">{fullAddress}</p>}
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      <a href={`/my-property?property=${p.id}`} class="btn-ghost text-sm">Preview as GM</a>
      <a href={`/dashboard?property=${p.id}`} class="btn-ghost text-sm">View documents</a>
      <a href={`/admin/users?property=${p.id}`} class="btn-primary text-sm">Invite a GM</a>
    </div>
  </div>

  {uploaded && (
    <div class="mb-4 rounded-xl border border-green-200 bg-green-50 px-5 py-3 text-sm text-green-800">
      Uploaded.
    </div>
  )}
  {errorMsg && (
    <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-5 py-3 text-sm text-red-700">
      {errorMsg}
    </div>
  )}

  <!-- Tab bar -->
  <div class="border-b border-[var(--color-hairline)] mb-6">
    <nav class="flex gap-1 flex-wrap" id="prop-tabs">
      {tabs.map((t, i) => (
        <button
          type="button"
          data-tab={t.id}
          class={`tab-btn px-4 py-2.5 text-sm font-semibold transition-colors border-b-2 -mb-px ${
            i === 0
              ? "border-[var(--color-brass)] text-[var(--color-navy)]"
              : "border-transparent text-[var(--color-muted)] hover:text-[var(--color-navy)]"
          }`}
        >
          {t.label}
          {t.count !== undefined && (
            <span class="ml-1.5 text-xs text-[var(--color-muted)]">{t.count}</span>
          )}
        </button>
      ))}
    </nav>
  </div>

  <!-- ─── Overview ─── -->
  <section data-panel="overview">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
      <div class="rounded-xl border bg-white border-[var(--color-hairline)] p-4">
        <div class="text-xs font-semibold text-[var(--color-muted)] uppercase tracking-widest">Rooms</div>
        <div class="text-2xl font-bold text-[var(--color-navy)] mt-1">{p.room_count ?? "—"}</div>
      </div>
      <div class="rounded-xl border bg-white border-[var(--color-hairline)] p-4">
        <div class="text-xs font-semibold text-[var(--color-muted)] uppercase tracking-widest">Documents</div>
        <div class="text-2xl font-bold text-[var(--color-navy)] mt-1">{stats?.total ?? 0}</div>
      </div>
      <div class={`rounded-xl border p-4 ${(stats?.new_count ?? 0) > 0 ? "bg-[var(--color-brass-light)]/20 border-[var(--color-brass)]" : "bg-white border-[var(--color-hairline)]"}`}>
        <div class={`text-xs font-semibold uppercase tracking-widest ${(stats?.new_count ?? 0) > 0 ? "text-[var(--color-brass-dark)]" : "text-[var(--color-muted)]"}`}>In Inbox</div>
        <div class="text-2xl font-bold text-[var(--color-navy)] mt-1">{stats?.new_count ?? 0}</div>
      </div>
      <div class="rounded-xl border bg-white border-[var(--color-hairline)] p-4">
        <div class="text-xs font-semibold text-[var(--color-muted)] uppercase tracking-widest">Invoices 30d</div>
        <div class="text-2xl font-bold text-[var(--color-navy)] mt-1">{fmtMoney(stats?.invoice_30d ?? 0)}</div>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- Contact -->
      <section class="bg-white border border-[var(--color-hairline)] rounded-xl p-5">
        <h2 class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-3">Contact</h2>
        <dl class="space-y-3 text-sm">
          {p.phone && (
            <div>
              <dt class="text-xs text-[var(--color-muted)]">Front desk</dt>
              <dd class="text-[var(--color-navy)]"><a href={`tel:${p.phone}`} class="hover:text-[var(--color-brass-dark)]">{p.phone}</a></dd>
            </div>
          )}
          {p.emergency_phone && (
            <div>
              <dt class="text-xs text-[var(--color-muted)]">Emergency / GM cell</dt>
              <dd class="text-[var(--color-navy)]"><a href={`tel:${p.emergency_phone}`} class="hover:text-[var(--color-brass-dark)]">{p.emergency_phone}</a></dd>
            </div>
          )}
          {p.fax && (
            <div>
              <dt class="text-xs text-[var(--color-muted)]">Fax</dt>
              <dd class="text-[var(--color-navy)]">{p.fax}</dd>
            </div>
          )}
          {p.property_email && (
            <div>
              <dt class="text-xs text-[var(--color-muted)]">Email</dt>
              <dd><a href={`mailto:${p.property_email}`} class="text-[var(--color-brass-dark)] hover:text-[var(--color-brass)] break-all">{p.property_email}</a></dd>
            </div>
          )}
          {!p.phone && !p.emergency_phone && !p.fax && !p.property_email && (
            <p class="text-sm text-[var(--color-muted)]">No contact info on file.</p>
          )}
        </dl>
      </section>

      <!-- Details -->
      <section class="bg-white border border-[var(--color-hairline)] rounded-xl p-5">
        <h2 class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-3">Details</h2>
        <dl class="space-y-3 text-sm">
          <div>
            <dt class="text-xs text-[var(--color-muted)]">Owner group</dt>
            <dd class="text-[var(--color-navy)]">{p.owner_group || "—"}</dd>
          </div>
          <div>
            <dt class="text-xs text-[var(--color-muted)]">Brand</dt>
            <dd class="text-[var(--color-navy)]">{brandLabel}</dd>
          </div>
          <div>
            <dt class="text-xs text-[var(--color-muted)]">Added</dt>
            <dd class="text-[var(--color-navy)]">{new Date(p.created_at + "Z").toLocaleDateString()}</dd>
          </div>
        </dl>
      </section>

      <!-- General managers -->
      <section class="bg-white border border-[var(--color-hairline)] rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)]">General managers</h2>
          <span class="text-xs text-[var(--color-muted)]">{gms.results.length}</span>
        </div>
        {gms.results.length === 0 ? (
          <p class="text-sm text-[var(--color-muted)]">
            No GM assigned. <a href={`/admin/users?property=${p.id}`} class="text-[var(--color-brass-dark)] hover:text-[var(--color-brass)] underline">Invite one</a>.
          </p>
        ) : (
          <ul class="space-y-3">
            {gms.results.map((g) => (
              <li class="flex items-center justify-between gap-2">
                <div class="min-w-0">
                  <div class="font-semibold text-sm text-[var(--color-navy)] truncate">{g.name}</div>
                  <div class="text-xs text-[var(--color-muted)] truncate">{g.email}</div>
                </div>
                {g.activated ? (
                  <span class="text-xs text-green-700 font-semibold shrink-0">Active</span>
                ) : (
                  <span class="text-xs text-[var(--color-brass-dark)] font-semibold shrink-0">Pending</span>
                )}
              </li>
            ))}
          </ul>
        )}
      </section>
    </div>
  </section>

  <!-- ─── Documents ─── -->
  <section data-panel="documents" hidden>
    <div class="grid lg:grid-cols-[1fr_360px] gap-6">
      <div class="bg-white border border-[var(--color-hairline)] rounded-xl overflow-hidden">
        <header class="px-5 py-3 border-b border-[var(--color-hairline)] flex items-center justify-between">
          <h2 class="font-semibold text-[var(--color-navy)]">Documents from this property</h2>
          <a href={`/dashboard?property=${p.id}`} class="text-xs text-[var(--color-brass-dark)] hover:text-[var(--color-brass)] font-semibold">Open in dashboard →</a>
        </header>
        {recent.results.length === 0 ? (
          <div class="px-5 py-10 text-center text-[var(--color-muted)] text-sm">
            No documents from this property yet.
          </div>
        ) : (
          <ul class="divide-y divide-[var(--color-hairline)]">
            {recent.results.map((d) => (
              <li>
                <a href={`/dashboard/${d.id}`} class="flex items-center justify-between gap-3 px-5 py-3 hover:bg-[var(--color-cream)]">
                  <div class="min-w-0">
                    <div class="flex items-center gap-2">
                      <span class={`pill ${pillClass(d.category)} capitalize`}>{d.category}</span>
                      {d.category === "invoice" && d.payment_status === "paid" && (
                        <span class="pill bg-green-100 text-green-800 border border-green-200">Paid</span>
                      )}
                      <span class="text-sm text-[var(--color-navy)] truncate">{d.filename}</span>
                    </div>
                    <div class="text-xs text-[var(--color-muted)] mt-1">
                      {d.vendor || "—"} · {fmtRel(d.created_at)}
                    </div>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-sm font-semibold text-[var(--color-navy)] tabular-nums">{fmtMoney(d.amount_cents)}</div>
                    <div class="text-[10px] uppercase tracking-widest text-[var(--color-muted)] mt-0.5">{d.status}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>

      <aside>
        <form
          method="POST"
          action="/api/upload"
          enctype="multipart/form-data"
          class="bg-white border border-[var(--color-hairline)] rounded-xl p-5 space-y-4 sticky top-4"
        >
          <h2 class="font-semibold text-[var(--color-navy)]">Upload a document</h2>
          <p class="text-xs text-[var(--color-muted)]">Invoice, statement, or other operating doc for {p.name}.</p>
          <input type="hidden" name="property_id" value={p.id} />

          <div>
            <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-2">Category</div>
            <div class="grid grid-cols-3 gap-2">
              {[
                { value: "invoice", label: "Invoice" },
                { value: "statement", label: "Statement" },
                { value: "other", label: "Other" },
              ].map((opt) => (
                <label class="flex items-center justify-center cursor-pointer rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 has-[:checked]:bg-[var(--color-navy)] has-[:checked]:text-white has-[:checked]:border-[var(--color-navy)] transition-colors">
                  <input type="radio" name="category" value={opt.value} class="hidden" required />
                  <span class="font-semibold text-sm">{opt.label}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="amount" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Amount</label>
              <input id="amount" name="amount" type="number" step="0.01" min="0" placeholder="$ 0.00"
                class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
            </div>
            <div>
              <label for="vendor" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Vendor</label>
              <input id="vendor" name="vendor" type="text" placeholder="Cintas, Ecolab, …"
                class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
            </div>
          </div>

          <div>
            <label for="invoice_number" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
              Invoice # <span class="text-[var(--color-muted)] font-normal normal-case tracking-normal">(optional)</span>
            </label>
            <input id="invoice_number" name="invoice_number" type="text" placeholder="e.g. INV-10472"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          </div>

          <div>
            <label for="note" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Note (optional)</label>
            <textarea id="note" name="note" rows="2"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm"></textarea>
          </div>

          <label data-dropzone class="block border-2 border-dashed border-[var(--color-brass)] rounded-xl bg-[var(--color-brass-light)]/15 px-4 py-5 text-center cursor-pointer hover:bg-[var(--color-brass-light)]/25 transition-colors">
            <input type="file" name="file" required class="hidden"
              accept="application/pdf,image/jpeg,image/png,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel" />
            <div data-dropzone-label class="text-sm font-semibold text-[var(--color-brass-dark)]">
              Drag a file here, or click to browse
            </div>
            <div class="text-xs text-[var(--color-muted)] mt-1">PDF, image, or Excel · up to 25 MB</div>
          </label>

          <button type="submit" class="btn-primary w-full">Send to Strand</button>
        </form>
      </aside>
    </div>
  </section>

  <!-- ─── Financials ─── -->
  <section data-panel="financials" hidden>
    <div class="grid lg:grid-cols-[1fr_360px] gap-6">
      <div class="bg-white border border-[var(--color-hairline)] rounded-xl overflow-hidden">
        <header class="px-5 py-3 border-b border-[var(--color-hairline)]">
          <h2 class="font-semibold text-[var(--color-navy)]">Financial statements</h2>
        </header>
        {financials.results.length === 0 ? (
          <div class="px-5 py-10 text-center text-[var(--color-muted)] text-sm">
            No financial statements yet. Upload one on the right.
          </div>
        ) : (
          <ul class="divide-y divide-[var(--color-hairline)]">
            {financials.results.map((f) => (
              <li class="px-5 py-3 flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="pill pill-statement">{typeLabel(f.statement_type)}</span>
                    <span class="text-xs text-[var(--color-muted)]">{periodLabel(f.period_year, f.period_month)}</span>
                  </div>
                  <div class="text-sm font-semibold text-[var(--color-navy)] truncate">{f.title}</div>
                </div>
                <div class="flex gap-2 shrink-0">
                  <a class="btn-ghost text-xs"
                    href={`/api/financials/${f.id}/download?inline=1`}
                    target="_blank" rel="noopener"
                    data-viewer-url={`/api/financials/${f.id}/download?inline=1`}
                    data-viewer-download={`/api/financials/${f.id}/download`}
                    data-viewer-name={f.filename}
                    data-viewer-type={viewerType(f.mime_type)}>View</a>
                  <a class="btn-primary text-xs" href={`/api/financials/${f.id}/download`} download>Download</a>
                </div>
              </li>
            ))}
          </ul>
        )}
      </div>

      <aside>
        <form
          method="POST"
          action="/api/financials"
          enctype="multipart/form-data"
          class="bg-white border border-[var(--color-hairline)] rounded-xl p-5 space-y-4 sticky top-4"
        >
          <h2 class="font-semibold text-[var(--color-navy)]">Upload a statement</h2>
          <p class="text-xs text-[var(--color-muted)]">P&L, balance sheet, budget, or other for {p.name}.</p>
          <input type="hidden" name="property_id" value={p.id} />

          <div>
            <label for="statement_type" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Type</label>
            <select id="statement_type" name="statement_type" required
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm">
              {STATEMENT_TYPES.map((t) => (
                <option value={t.value} selected={t.value === "profit_loss"}>{t.label}</option>
              ))}
            </select>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="period_year" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Year</label>
              <input id="period_year" name="period_year" type="number" required min="2000" max="2100" value={defaultYear}
                class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
            </div>
            <div>
              <label for="period_month" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Period</label>
              <select id="period_month" name="period_month"
                class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm">
                {MONTH_LABELS.map((label, i) => (
                  <option value={i === 0 ? "" : i} selected={i === defaultMonth}>{label}</option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label for="title" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
              Title <span class="text-[var(--color-muted)] font-normal normal-case tracking-normal">(optional)</span>
            </label>
            <input id="title" name="title" type="text" placeholder="Auto-generated if blank"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          </div>

          <div>
            <label for="description" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
              Notes <span class="text-[var(--color-muted)] font-normal normal-case tracking-normal">(optional)</span>
            </label>
            <textarea id="description" name="description" rows="2"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm"></textarea>
          </div>

          <label data-dropzone class="block border-2 border-dashed border-[var(--color-brass)] rounded-xl bg-[var(--color-brass-light)]/15 px-4 py-5 text-center cursor-pointer hover:bg-[var(--color-brass-light)]/25 transition-colors">
            <input type="file" name="file" required class="hidden"
              accept="application/pdf,image/jpeg,image/png,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel" />
            <div data-dropzone-label class="text-sm font-semibold text-[var(--color-brass-dark)]">
              Drag a file here, or click to browse
            </div>
            <div class="text-xs text-[var(--color-muted)] mt-1">PDF, image, or Excel · up to 25 MB</div>
          </label>

          <button type="submit" class="btn-primary w-full">Upload</button>
        </form>
      </aside>
    </div>
  </section>

  <!-- ─── Fact sheet ─── -->
  <section data-panel="factsheet" hidden>
    <div class="max-w-2xl">
      <FactSheet propertyId={id!} facts={facts.results} canEdit={true} />
    </div>
  </section>

  <!-- ─── Records ─── -->
  <section data-panel="records" hidden>
    <div class="max-w-2xl">
      <PropertyFiles propertyId={id!} files={propertyFiles.results} canEdit={true} />
    </div>
  </section>

  <script is:inline>
    (function () {
      var tabs = document.querySelectorAll("#prop-tabs .tab-btn");
      var panels = document.querySelectorAll("[data-panel]");
      function activate(name) {
        tabs.forEach(function (t) {
          var on = t.getAttribute("data-tab") === name;
          t.classList.toggle("border-[var(--color-brass)]", on);
          t.classList.toggle("text-[var(--color-navy)]", on);
          t.classList.toggle("border-transparent", !on);
          t.classList.toggle("text-[var(--color-muted)]", !on);
        });
        panels.forEach(function (p) {
          p.hidden = p.getAttribute("data-panel") !== name;
        });
      }
      tabs.forEach(function (t) {
        t.addEventListener("click", function () {
          var name = t.getAttribute("data-tab");
          activate(name);
          history.replaceState(null, "", "#" + name);
        });
      });
      var initial = (location.hash || "").replace("#", "");
      if (initial && document.querySelector('[data-panel="' + initial + '"]')) {
        activate(initial);
      }

      document.querySelectorAll("form[data-confirm]").forEach(function (form) {
        form.addEventListener("submit", function (e) {
          if (!confirm(form.dataset.confirm || "Are you sure?")) e.preventDefault();
        });
      });

      document.querySelectorAll("[data-dropzone]").forEach(function (dz) {
        var input = dz.querySelector('input[type="file"]');
        var label = dz.querySelector("[data-dropzone-label]");
        function setName(name) { if (label && name) label.textContent = name; }
        if (input) input.addEventListener("change", function () {
          if (input.files && input.files[0]) setName(input.files[0].name);
        });
        ["dragenter", "dragover"].forEach(function (ev) {
          dz.addEventListener(ev, function (e) {
            e.preventDefault();
            dz.classList.add("ring-2", "ring-[var(--color-brass)]");
          });
        });
        ["dragleave", "drop"].forEach(function (ev) {
          dz.addEventListener(ev, function (e) {
            e.preventDefault();
            dz.classList.remove("ring-2", "ring-[var(--color-brass)]");
          });
        });
        dz.addEventListener("drop", function (e) {
          var f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
          if (f && input) {
            var dt = new DataTransfer();
            dt.items.add(f);
            input.files = dt.files;
            setName(f.name);
          }
        });
      });
    })();
  </script>
</PortalLayout>
