---
import PortalLayout from "../../layouts/PortalLayout.astro";
import { getApprovalThresholdCents } from "../../lib/settings";
export const prerender = false;

const env = Astro.locals.runtime.env;
const url = new URL(Astro.request.url);
const saved = url.searchParams.get("saved") === "1";
const error = url.searchParams.get("error");

const thresholdCents = await getApprovalThresholdCents(env.DB);
const thresholdDollars = (thresholdCents / 100).toFixed(2);
---

<PortalLayout title="Settings">
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">
      Settings
    </h1>
    <p class="text-sm text-[var(--color-muted)] mt-1">Portal-wide configuration.</p>
  </div>

  {saved && (
    <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-5 py-3 text-sm text-green-800">
      Settings saved.
    </div>
  )}
  {error && (
    <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-5 py-3 text-sm text-red-700">
      {error}
    </div>
  )}

  <form method="POST" action="/api/settings"
    class="bg-white border border-[var(--color-hairline)] rounded-xl p-6 max-w-md space-y-4">
    <div>
      <h2 class="font-semibold text-[var(--color-navy)]">Invoice approval threshold</h2>
      <p class="text-sm text-[var(--color-muted)] mt-1">
        Invoices uploaded at or above this amount require an admin to approve them
        before payment. Set to 0 to require approval on every invoice.
      </p>
    </div>
    <div>
      <label for="approval_threshold" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
        Threshold (USD)
      </label>
      <div class="flex items-center gap-2">
        <span class="text-[var(--color-muted)]">$</span>
        <input id="approval_threshold" name="approval_threshold" type="number"
          step="0.01" min="0" value={thresholdDollars}
          class="w-40 rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
      </div>
    </div>
    <button type="submit" class="btn-primary text-sm">Save</button>
  </form>
</PortalLayout>
