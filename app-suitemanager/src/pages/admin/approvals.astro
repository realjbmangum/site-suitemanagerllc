---
import PortalLayout from "../../layouts/PortalLayout.astro";
import { getApprovalThresholdCents } from "../../lib/settings";
export const prerender = false;

const env = Astro.locals.runtime.env;
const url = new URL(Astro.request.url);
const view = url.searchParams.get("view") === "decided" ? "decided" : "pending";
const error = url.searchParams.get("error");

const threshold = await getApprovalThresholdCents(env.DB);

const pendingCount = (
  await env.DB
    .prepare("SELECT COUNT(*) AS n FROM documents WHERE approval_status = 'pending'")
    .first<{ n: number }>()
)?.n ?? 0;

const rows = await env.DB
  .prepare(
    `SELECT d.id, d.filename, d.vendor, d.invoice_number, d.amount_cents, d.note,
            d.created_at, d.approval_status, d.approval_reason, d.approval_decided_at,
            p.name AS property_name, u.name AS gm_name,
            db.name AS decided_by_name
     FROM documents d
     LEFT JOIN properties p ON p.id = d.property_id
     LEFT JOIN users u ON u.id = d.uploaded_by
     LEFT JOIN users db ON db.id = d.approval_decided_by
     WHERE d.approval_status ${view === "pending" ? "= 'pending'" : "IN ('approved','denied')"}
     ORDER BY ${view === "pending" ? "d.created_at ASC" : "d.approval_decided_at DESC"}
     LIMIT 200`
  )
  .all<{
    id: string; filename: string; vendor: string | null;
    invoice_number: string | null; amount_cents: number | null; note: string | null;
    created_at: string; approval_status: string;
    approval_reason: string | null; approval_decided_at: string | null;
    property_name: string | null; gm_name: string | null;
    decided_by_name: string | null;
  }>();

const fmtMoney = (cents: number | null) =>
  cents != null
    ? `$${(cents / 100).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`
    : "—";
const fmtRel = (iso: string) => {
  const d = new Date(iso + "Z");
  const diff = (Date.now() - d.getTime()) / 60000;
  if (diff < 1) return "just now";
  if (diff < 60) return `${Math.round(diff)} min ago`;
  if (diff < 1440) return `${Math.round(diff / 60)} hr ago`;
  return d.toLocaleDateString();
};
---

<PortalLayout title="Approvals">
  <div class="flex items-end justify-between mb-6 flex-wrap gap-4">
    <div>
      <h1 class="text-3xl font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">
        Approvals
      </h1>
      <p class="text-sm text-[var(--color-muted)] mt-1">
        Invoices at or above {fmtMoney(threshold)} need sign-off before payment.
        <a href="/admin/settings" class="text-[var(--color-brass-dark)] hover:text-[var(--color-brass)] underline">Change threshold</a>
      </p>
    </div>
  </div>

  {error && (
    <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-5 py-3 text-sm text-red-700">
      {error}
    </div>
  )}

  <div class="border-b border-[var(--color-hairline)] mb-5">
    <nav class="flex gap-1">
      <a href="/admin/approvals" class={`px-4 py-2.5 text-sm font-semibold border-b-2 -mb-px ${
        view === "pending"
          ? "border-[var(--color-brass)] text-[var(--color-navy)]"
          : "border-transparent text-[var(--color-muted)] hover:text-[var(--color-navy)]"
      }`}>
        Awaiting approval{pendingCount > 0 ? ` · ${pendingCount}` : ""}
      </a>
      <a href="/admin/approvals?view=decided" class={`px-4 py-2.5 text-sm font-semibold border-b-2 -mb-px ${
        view === "decided"
          ? "border-[var(--color-brass)] text-[var(--color-navy)]"
          : "border-transparent text-[var(--color-muted)] hover:text-[var(--color-navy)]"
      }`}>
        Decided
      </a>
    </nav>
  </div>

  {rows.results.length === 0 ? (
    <div class="bg-white border border-[var(--color-hairline)] rounded-xl p-12 text-center text-[var(--color-muted)]">
      {view === "pending"
        ? "Nothing is awaiting approval. You're clear."
        : "No decisions recorded yet."}
    </div>
  ) : (
    <div class="space-y-3">
      {rows.results.map((r) => (
        <article class="bg-white border border-[var(--color-hairline)] rounded-xl p-5">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <span class="pill pill-invoice">Invoice</span>
                <span class="text-lg font-bold text-[var(--color-navy)] tabular-nums">{fmtMoney(r.amount_cents)}</span>
                {view === "decided" && (
                  r.approval_status === "approved" ? (
                    <span class="pill bg-green-100 text-green-800 border border-green-200">Approved</span>
                  ) : (
                    <span class="pill bg-red-100 text-red-700 border border-red-200">Denied</span>
                  )
                )}
              </div>
              <div class="font-semibold text-[var(--color-navy)]">
                {r.property_name || "—"}
                {r.vendor && <span class="text-[var(--color-muted)] font-normal"> · {r.vendor}</span>}
              </div>
              <div class="text-xs text-[var(--color-muted)] mt-0.5">
                {r.gm_name ? `Submitted by ${r.gm_name}` : ""}
                {r.invoice_number ? ` · Invoice #${r.invoice_number}` : ""}
                {" · "}{fmtRel(r.created_at)}
              </div>
              {r.note && (
                <p class="text-sm text-[var(--color-muted)] italic mt-1">“{r.note}”</p>
              )}
              {view === "decided" && (
                <p class="text-xs text-[var(--color-navy)] mt-2">
                  {r.approval_status === "approved" ? "Approved" : "Denied"} by {r.decided_by_name}
                  {r.approval_decided_at ? ` · ${fmtRel(r.approval_decided_at)}` : ""}
                  {r.approval_reason ? ` — “${r.approval_reason}”` : ""}
                </p>
              )}
            </div>
            <a
              href={`/dashboard/${r.id}`}
              class="btn-ghost text-xs shrink-0"
            >Open document</a>
          </div>

          {view === "pending" && (
            <form method="POST" action={`/api/documents/${r.id}/approval`}
              class="mt-4 pt-4 border-t border-[var(--color-hairline)] flex flex-wrap items-end gap-3">
              <div class="flex-1 min-w-[220px]">
                <label class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1">
                  Reason <span class="font-normal normal-case tracking-normal">(required to deny)</span>
                </label>
                <input name="reason" type="text" placeholder="Optional note / reason for denial"
                  class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
              </div>
              <div class="flex gap-2">
                <button type="submit" name="decision" value="deny"
                  class="text-sm font-semibold px-4 py-2 rounded-lg border border-red-300 text-red-600 hover:bg-red-50">
                  Deny
                </button>
                <button type="submit" name="decision" value="approve" class="btn-primary text-sm">
                  Approve
                </button>
              </div>
            </form>
          )}
        </article>
      ))}
    </div>
  )}
</PortalLayout>
