---
import PortalLayout from "../layouts/PortalLayout.astro";
import { typeLabel, periodLabel } from "../lib/financials";
import FactSheet from "../components/FactSheet.astro";
import PropertyFiles from "../components/PropertyFiles.astro";
export const prerender = false;

const env = Astro.locals.runtime.env;
const user = Astro.locals.user!;
const url = new URL(Astro.request.url);
const uploaded = url.searchParams.get("uploaded") === "1";
const error = url.searchParams.get("error");
const ptoRequested = url.searchParams.get("pto") === "requested";

// Admin testers can pass ?property=<id> to view any property in this mode.
const overrideId = user.role === "admin" ? url.searchParams.get("property") : null;
const targetPropertyId = overrideId || user.propertyId;

if (!targetPropertyId) {
  return Astro.redirect("/dashboard");
}

const p = await env.DB
  .prepare(
    `SELECT id, name, code, brand,
            address_street, address_city, address_state, address_zip,
            room_count, phone, fax, emergency_phone, property_email
     FROM properties WHERE id = ?`
  )
  .bind(targetPropertyId)
  .first<{
    id: string; name: string; code: string | null; brand: string | null;
    address_street: string | null; address_city: string | null;
    address_state: string | null; address_zip: string | null;
    room_count: number | null; phone: string | null;
    fax: string | null; emergency_phone: string | null;
    property_email: string | null;
  }>();

if (!p) return Astro.redirect("/dashboard?error=Property+not+found");

// Documents for this property — recent first.
const docs = await env.DB
  .prepare(
    `SELECT id, filename, category, vendor, amount_cents, note, status,
            payment_status, check_number, check_date, approval_status, created_at
     FROM documents
     WHERE property_id = ?
     ORDER BY created_at DESC LIMIT 30`
  )
  .bind(targetPropertyId)
  .all<{
    id: string; filename: string; category: string;
    vendor: string | null; amount_cents: number | null; note: string | null;
    status: string;
    payment_status: string; check_number: string | null; check_date: string | null;
    approval_status: string;
    created_at: string;
  }>();

const stats = await env.DB
  .prepare(
    `SELECT
      (SELECT COUNT(*) FROM documents WHERE property_id = ?) AS total,
      (SELECT COUNT(*) FROM documents WHERE property_id = ? AND category = 'invoice' AND payment_status = 'unpaid') AS unpaid_count,
      (SELECT COALESCE(SUM(amount_cents), 0) FROM documents WHERE property_id = ? AND category = 'invoice' AND payment_status = 'unpaid') AS unpaid_total`
  )
  .bind(targetPropertyId, targetPropertyId, targetPropertyId)
  .first<{ total: number; unpaid_count: number; unpaid_total: number }>();

// Fact sheet + property document library.
const facts = await env.DB
  .prepare("SELECT id, label, value FROM property_facts WHERE property_id = ? ORDER BY sort_order, created_at")
  .bind(targetPropertyId)
  .all<{ id: string; label: string; value: string }>();

const propertyFiles = await env.DB
  .prepare(
    `SELECT id, category, title, description, expires_at, filename, mime_type, created_at
     FROM property_files WHERE property_id = ? AND archived_at IS NULL
     ORDER BY created_at DESC`
  )
  .bind(targetPropertyId)
  .all<{ id: string; category: string; title: string; description: string | null; expires_at: string | null; filename: string; mime_type: string; created_at: string }>();

// Financial statements for this property.
const financials = await env.DB
  .prepare(
    `SELECT id, statement_type, period_year, period_month, title, filename, mime_type, created_at
     FROM financial_statements
     WHERE property_id = ? AND archived_at IS NULL
     ORDER BY period_year DESC, period_month DESC, created_at DESC
     LIMIT 12`
  )
  .bind(targetPropertyId)
  .all<{ id: string; statement_type: string; period_year: number; period_month: number | null; title: string; filename: string; mime_type: string; created_at: string }>();

// This GM's own PTO requests — pending, approved, denied.
const ptoEvents = await env.DB
  .prepare(
    `SELECT id, kind, starts_at, ends_at, notes,
            approval_status, approval_reason, decided_at
     FROM calendar_events
     WHERE owner_user_id = ? AND source = 'gm_pto'
     ORDER BY starts_at DESC LIMIT 20`
  )
  .bind(user.id)
  .all<{
    id: string; kind: string; starts_at: string; ends_at: string;
    notes: string | null;
    approval_status: string; approval_reason: string | null;
    decided_at: string | null;
  }>();

const todayLocal = new Date();
const todayIsoLocal =
  `${todayLocal.getFullYear()}-${String(todayLocal.getMonth() + 1).padStart(2, "0")}-${String(todayLocal.getDate()).padStart(2, "0")}`;

const fmtPtoDate = (iso: string) => {
  const [y, m, d] = iso.split("-").map(Number);
  if (!y || !m || !d) return iso;
  return new Date(y, m - 1, d).toLocaleDateString(undefined, {
    weekday: "short", month: "short", day: "numeric"
  });
};
const ptoKindLabel = (k: string) =>
  k === "vacation" ? "Vacation" :
  k === "sick" ? "Sick" :
  k === "personal" ? "Personal" : k;
const ptoPillClass = (status: string) =>
  status === "pending" ? "bg-amber-100 text-amber-800 border border-amber-300" :
  status === "approved" ? "bg-green-100 text-green-800 border border-green-200" :
  "bg-red-100 text-red-700 border border-red-200";

const fmtMoney = (cents: number | null) =>
  cents != null ? `$${(cents / 100).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "—";
const fmtRel = (iso: string) => {
  const d = new Date(iso + "Z");
  const diff = (Date.now() - d.getTime()) / 60000;
  if (diff < 1) return "just now";
  if (diff < 60) return `${Math.round(diff)} min ago`;
  if (diff < 1440) return `${Math.round(diff / 60)} hr ago`;
  if (diff < 1440 * 30) return `${Math.round(diff / 1440)} d ago`;
  return d.toLocaleDateString();
};

const fullAddress = [p.address_street, p.address_city, p.address_state, p.address_zip]
  .filter(Boolean)
  .join(", ");

const pillClass = (cat: string) =>
  cat === "invoice" ? "pill-invoice" :
  cat === "statement" ? "pill-statement" : "pill-other";
const viewerType = (mime: string) =>
  mime.includes("pdf") ? "pdf" : mime.startsWith("image/") ? "image" : "other";
---

<PortalLayout title={p.name} context={p.name}>
  {user.role === "admin" && (
    <div class="mb-4 rounded-lg border border-[var(--color-brass)] bg-[var(--color-brass-light)]/15 px-4 py-2 text-xs text-[var(--color-navy)]">
      Admin preview — viewing as the GM at <strong>{p.name}</strong>.
      <a href="/dashboard" class="underline ml-2">Back to dashboard</a>
    </div>
  )}

  <!-- Property header -->
  <div class="bg-white border border-[var(--color-hairline)] rounded-2xl p-6 mb-6">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <div class="flex items-center gap-2 mb-2">
          {p.code && <span class="font-mono text-xs px-2 py-1 rounded bg-[var(--color-hairline)] text-[var(--color-muted)]">{p.code}</span>}
        </div>
        <h1 class="text-3xl font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">{p.name}</h1>
        {fullAddress && <p class="text-sm text-[var(--color-muted)] mt-1">{fullAddress}</p>}
      </div>
      <div class="text-sm space-y-1 text-right">
        {p.phone && <div><span class="text-[var(--color-muted)] mr-2">Front desk</span><a href={`tel:${p.phone}`} class="text-[var(--color-navy)] font-medium">{p.phone}</a></div>}
        {p.emergency_phone && <div><span class="text-[var(--color-muted)] mr-2">Emergency</span><a href={`tel:${p.emergency_phone}`} class="text-[var(--color-navy)] font-medium">{p.emergency_phone}</a></div>}
        {p.property_email && <div><span class="text-[var(--color-muted)] mr-2">Email</span><a href={`mailto:${p.property_email}`} class="text-[var(--color-brass-dark)] hover:text-[var(--color-brass)]">{p.property_email}</a></div>}
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3 mt-5 pt-5 border-t border-[var(--color-hairline)]">
      <div>
        <div class="text-xs text-[var(--color-muted)] uppercase tracking-widest font-semibold">Rooms</div>
        <div class="text-xl font-bold text-[var(--color-navy)] mt-0.5">{p.room_count ?? "—"}</div>
      </div>
      <div>
        <div class="text-xs text-[var(--color-muted)] uppercase tracking-widest font-semibold">Documents</div>
        <div class="text-xl font-bold text-[var(--color-navy)] mt-0.5">{stats?.total ?? 0}</div>
      </div>
      <div class={(stats?.unpaid_count ?? 0) > 0 ? "rounded-lg bg-[var(--color-brass-light)]/20 px-3 -mx-3" : ""}>
        <div class={`text-xs uppercase tracking-widest font-semibold ${(stats?.unpaid_count ?? 0) > 0 ? "text-[var(--color-brass-dark)]" : "text-[var(--color-muted)]"}`}>Unpaid invoices</div>
        <div class="text-xl font-bold text-[var(--color-navy)] mt-0.5">
          {stats?.unpaid_count ?? 0}
          {(stats?.unpaid_total ?? 0) > 0 && (
            <span class="text-xs text-[var(--color-muted)] font-normal ml-2 tabular-nums">{fmtMoney(stats?.unpaid_total ?? 0)}</span>
          )}
        </div>
      </div>
    </div>
  </div>

  {uploaded && (
    <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-5 py-4 text-sm text-green-800">
      Sent. Strand's accounting team has it in their inbox.
    </div>
  )}
  {ptoRequested && (
    <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-5 py-4 text-sm text-green-800">
      Time-off request submitted. You'll get an email when Suite Manager makes a decision.
    </div>
  )}
  {error && (
    <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700">
      {error}
    </div>
  )}

  <!-- Upload + recent docs -->
  <div class="grid lg:grid-cols-[1fr_1fr] gap-6">
    <section>
      <h2 class="text-lg font-bold text-[var(--color-navy)] mb-2" style="font-family: var(--font-display);">
        Send a document to Strand
      </h2>
      <p class="text-sm text-[var(--color-muted)] mb-4">
        Invoices, statements, and operating documents.
      </p>

      <form
        method="POST"
        action="/api/upload"
        enctype="multipart/form-data"
        class="bg-white border border-[var(--color-hairline)] rounded-2xl p-5 space-y-5"
      >
        {user.role === "admin" && (
          <input type="hidden" name="property_id" value={targetPropertyId} />
        )}

        <label data-dropzone class="block border-2 border-dashed border-[var(--color-brass)] rounded-xl bg-[var(--color-brass-light)]/15 px-6 py-8 text-center cursor-pointer hover:bg-[var(--color-brass-light)]/25 transition-colors">
          <input type="file" name="file" class="hidden" required
            accept="application/pdf,image/jpeg,image/png,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel" />
          <div data-dropzone-label class="text-[var(--color-brass-dark)] font-semibold text-sm">
            Drag a file here, or click to browse
          </div>
          <div class="text-xs text-[var(--color-muted)] mt-1">
            PDF, JPG, PNG, or Excel · up to 25 MB
          </div>
        </label>

        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-2">Category</div>
          <div class="grid grid-cols-3 gap-2">
            {[
              { value: "invoice", label: "Invoice" },
              { value: "statement", label: "Statement" },
              { value: "other", label: "Other" },
            ].map((opt) => (
              <label class="flex items-center justify-center cursor-pointer rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-2.5 has-[:checked]:bg-[var(--color-navy)] has-[:checked]:text-white has-[:checked]:border-[var(--color-navy)] transition-colors">
                <input type="radio" name="category" value={opt.value} class="hidden" required />
                <span class="font-semibold text-sm">{opt.label}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="amount" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Amount</label>
            <input id="amount" name="amount" type="number" step="0.01" min="0" placeholder="$ 0.00"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          </div>
          <div>
            <label for="vendor" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Vendor</label>
            <input id="vendor" name="vendor" type="text" placeholder="Cintas, Ecolab, …"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          </div>
        </div>

        <div>
          <label for="invoice_number" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
            Invoice number <span class="text-[var(--color-muted)] font-normal normal-case tracking-normal">(optional)</span>
          </label>
          <input id="invoice_number" name="invoice_number" type="text" placeholder="e.g. INV-10472"
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
        </div>

        <div>
          <label for="note" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Note (optional)</label>
          <textarea id="note" name="note" rows="2"
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm"></textarea>
        </div>

        <button type="submit" class="btn-primary w-full">Send to Strand</button>
      </form>
    </section>

    <section>
      <h2 class="text-lg font-bold text-[var(--color-navy)] mb-2" style="font-family: var(--font-display);">
        Your property's documents
      </h2>
      <p class="text-sm text-[var(--color-muted)] mb-4">
        Click any document for details and payment status.
      </p>

      <div class="bg-white border border-[var(--color-hairline)] rounded-2xl overflow-hidden">
        {docs.results.length === 0 ? (
          <div class="px-5 py-10 text-center text-[var(--color-muted)] text-sm">
            No documents yet. Use the form on the left to send your first.
          </div>
        ) : (
          <ul class="divide-y divide-[var(--color-hairline)]">
            {docs.results.map((d) => (
              <li>
                <a href={`/dashboard/${d.id}`} class="block px-5 py-3 hover:bg-[var(--color-cream)]">
                  <div class="flex items-center justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                        <span class={`pill ${pillClass(d.category)} capitalize`}>{d.category}</span>
                        {d.approval_status === "pending" && (
                          <span class="pill bg-amber-100 text-amber-800 border border-amber-300">Awaiting approval</span>
                        )}
                        {d.approval_status === "approved" && (
                          <span class="pill bg-green-100 text-green-800 border border-green-200">Approved</span>
                        )}
                        {d.approval_status === "denied" && (
                          <span class="pill bg-red-100 text-red-700 border border-red-200">Denied</span>
                        )}
                        {d.category === "invoice" && (
                          d.payment_status === "paid" ? (
                            <span class="pill bg-green-100 text-green-800 border border-green-200">Paid</span>
                          ) : (
                            <span class="pill bg-[var(--color-brass-light)]/30 text-[var(--color-brass-dark)] border border-[var(--color-brass)]">Unpaid</span>
                          )
                        )}
                      </div>
                      <div class="text-sm text-[var(--color-navy)] truncate">{d.filename}</div>
                      <div class="text-xs text-[var(--color-muted)] mt-0.5">
                        {d.vendor || "—"} · {fmtRel(d.created_at)}
                        {d.payment_status === "paid" && d.check_number && (
                          <span class="ml-2 text-green-700">· Check #{d.check_number} {d.check_date}</span>
                        )}
                      </div>
                    </div>
                    <div class="text-right shrink-0">
                      <div class="text-sm font-semibold text-[var(--color-navy)] tabular-nums">{fmtMoney(d.amount_cents)}</div>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </div>

  <!-- Financials -->
  <section class="mt-8">
    <div class="flex items-end justify-between mb-3">
      <div>
        <h2 class="text-lg font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">
          Financial statements
        </h2>
        <p class="text-sm text-[var(--color-muted)] mt-1">
          P&Ls, balance sheets, and budgets from Strand and Suite Manager.
        </p>
      </div>
    </div>

    <div class="bg-white border border-[var(--color-hairline)] rounded-2xl overflow-hidden">
      {financials.results.length === 0 ? (
        <div class="px-5 py-10 text-center text-[var(--color-muted)] text-sm">
          No financial statements have been published for this property yet.
        </div>
      ) : (
        <ul class="divide-y divide-[var(--color-hairline)]">
          {financials.results.map((f) => (
            <li class="px-5 py-3 flex items-center justify-between gap-3">
              <div class="min-w-0">
                <div class="flex items-center gap-2 mb-0.5">
                  <span class="pill pill-statement">{typeLabel(f.statement_type)}</span>
                  <span class="text-xs text-[var(--color-muted)]">{periodLabel(f.period_year, f.period_month)}</span>
                </div>
                <div class="text-sm font-semibold text-[var(--color-navy)] truncate">{f.title}</div>
                <div class="text-xs text-[var(--color-muted)] mt-0.5 font-mono truncate">{f.filename}</div>
              </div>
              <div class="flex gap-2 shrink-0">
                <a class="btn-ghost text-xs"
                  href={`/api/financials/${f.id}/download?inline=1`}
                  target="_blank" rel="noopener"
                  data-viewer-url={`/api/financials/${f.id}/download?inline=1`}
                  data-viewer-download={`/api/financials/${f.id}/download`}
                  data-viewer-name={f.filename}
                  data-viewer-type={viewerType(f.mime_type)}>View</a>
                <a class="btn-primary text-xs" href={`/api/financials/${f.id}/download`} download>Download</a>
              </div>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <!-- Time off -->
  <section class="mt-8">
    <div class="flex items-end justify-between mb-3">
      <div>
        <h2 class="text-lg font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">
          Time off
        </h2>
        <p class="text-sm text-[var(--color-muted)] mt-1">
          Request vacation, sick, or personal time. Suite Manager will review and you'll get an email with the decision.
        </p>
      </div>
    </div>

    <div class="grid lg:grid-cols-[1fr_1fr] gap-6">

      <!-- Request form -->
      <form method="POST" action="/api/calendar/events"
        class="bg-white border border-[var(--color-hairline)] rounded-2xl p-5 space-y-4">
        <input type="hidden" name="source" value="gm_pto" />
        <h3 class="font-semibold text-[var(--color-navy)]">Request time off</h3>

        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-2">Type</div>
          <div class="grid grid-cols-3 gap-2">
            {[
              { value: "vacation", label: "Vacation" },
              { value: "sick", label: "Sick" },
              { value: "personal", label: "Personal" },
            ].map((opt, i) => (
              <label class="flex items-center justify-center cursor-pointer rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2.5 has-[:checked]:bg-[var(--color-navy)] has-[:checked]:text-white has-[:checked]:border-[var(--color-navy)] transition-colors">
                <input type="radio" name="kind" value={opt.value} class="hidden" required checked={i === 0} />
                <span class="font-semibold text-sm">{opt.label}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="pto_start" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">First day</label>
            <input id="pto_start" name="starts_at" type="date" required value={todayIsoLocal}
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          </div>
          <div>
            <label for="pto_end" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Last day</label>
            <input id="pto_end" name="ends_at" type="date" required value={todayIsoLocal}
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          </div>
        </div>

        <div>
          <label for="pto_notes" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
            Reason / context <span class="font-normal normal-case tracking-normal text-[var(--color-muted)]">(optional)</span>
          </label>
          <textarea id="pto_notes" name="notes" rows="2" placeholder="Anything Suite Manager should know"
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm"></textarea>
        </div>

        <button type="submit" class="btn-primary w-full">Submit request</button>
      </form>

      <!-- Recent requests -->
      <div>
        <h3 class="font-semibold text-[var(--color-navy)] mb-3">Your recent requests</h3>
        <div class="bg-white border border-[var(--color-hairline)] rounded-2xl overflow-hidden">
          {ptoEvents.results.length === 0 ? (
            <div class="px-5 py-10 text-center text-[var(--color-muted)] text-sm">
              No time-off requests yet.
            </div>
          ) : (
            <ul class="divide-y divide-[var(--color-hairline)]">
              {ptoEvents.results.map((e) => (
                <li class="px-5 py-3">
                  <div class="flex items-center gap-2 mb-1 flex-wrap">
                    <span class={`pill ${ptoPillClass(e.approval_status)} capitalize`}>
                      {e.approval_status}
                    </span>
                    <span class="text-xs text-[var(--color-muted)]">{ptoKindLabel(e.kind)}</span>
                  </div>
                  <div class="text-sm font-semibold text-[var(--color-navy)]">
                    {fmtPtoDate(e.starts_at)}{e.starts_at !== e.ends_at && <> → {fmtPtoDate(e.ends_at)}</>}
                  </div>
                  {e.notes && (
                    <p class="text-xs italic text-[var(--color-muted)] mt-1">"{e.notes}"</p>
                  )}
                  {e.approval_status === "denied" && e.approval_reason && (
                    <p class="text-xs text-red-700 bg-red-50 border border-red-100 rounded-md px-2 py-1.5 mt-2">
                      <strong>Denied:</strong> {e.approval_reason}
                    </p>
                  )}
                  {e.approval_status === "pending" && (
                    <form method="POST" action={`/api/calendar/events/${e.id}`} class="mt-2">
                      <input type="hidden" name="action" value="delete" />
                      <button type="submit" class="text-xs text-[var(--color-muted)] hover:text-red-600 font-semibold"
                        data-confirm={`Withdraw this ${ptoKindLabel(e.kind).toLowerCase()} request?`}>
                        Withdraw request
                      </button>
                    </form>
                  )}
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Fact sheet + property document library -->
  <div class="grid lg:grid-cols-2 gap-6 mt-8">
    <FactSheet propertyId={targetPropertyId} facts={facts.results} canEdit={true} />
    <PropertyFiles propertyId={targetPropertyId} files={propertyFiles.results} canEdit={true} />
  </div>

  <script is:inline>
    document.querySelectorAll("form[data-confirm]").forEach((form) => {
      form.addEventListener("submit", (e) => {
        if (!confirm(form.dataset.confirm || "Are you sure?")) e.preventDefault();
      });
    });
  </script>
</PortalLayout>
