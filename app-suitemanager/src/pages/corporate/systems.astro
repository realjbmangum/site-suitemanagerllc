---
import PortalLayout from "../../layouts/PortalLayout.astro";
import CorporateNav from "../../components/CorporateNav.astro";
import { SERVICE_TYPES, serviceLabel, fmtMoney, type PropertySystem } from "../../lib/systems";

export const prerender = false;

const env = Astro.locals.runtime.env;
const url = new URL(Astro.request.url);
const saved = url.searchParams.get("saved") === "1";
const errorMsg = url.searchParams.get("error");

// ── Data (always live from D1; nothing hardcoded) ──────
const propsRes = await env.DB
  .prepare("SELECT id, name, code, address_state FROM properties WHERE active = 1 ORDER BY name")
  .all<{ id: string; name: string; code: string | null; address_state: string | null }>();
const properties = propsRes.results;

const sysRes = await env.DB
  .prepare(
    `SELECT s.id, s.property_id, s.service_type, s.vendor_name, s.account_number,
            s.contact_name, s.contact_phone, s.contact_email, s.monthly_cost_cents,
            s.contract_end, s.cancel_notice, s.status, s.notes
       FROM property_systems s JOIN properties p ON p.id = s.property_id
      WHERE p.active = 1 ORDER BY s.service_type, s.vendor_name`
  )
  .all<PropertySystem>();
const systems = sysRes.results;

// ── Grid + per-property metrics ────────────────────────
type Cell = { active: PropertySystem[] };
const byProp = new Map<string, Map<string, Cell>>();
for (const p of properties) byProp.set(p.id, new Map());
for (const s of systems) {
  if (s.status !== "active") continue;
  const m = byProp.get(s.property_id); if (!m) continue;
  let c = m.get(s.service_type); if (!c) { c = { active: [] }; m.set(s.service_type, c); }
  c.active.push(s);
}
const cellFor = (pid: string, t: string) => byProp.get(pid)?.get(t)?.active ?? [];

const activeSystems = systems.filter((s) => s.status === "active");
const monthlySpend = activeSystems.reduce((s, x) => s + (x.monthly_cost_cents ?? 0), 0);

let gaps = 0;
type DoublePay = { propertyId: string; propertyName: string; type: string; vendors: string[]; combined: number };
const doublePays: DoublePay[] = [];
const propMeta = properties.map((p) => {
  let spend = 0, gapCount = 0, dblCount = 0;
  for (const st of SERVICE_TYPES) {
    const a = cellFor(p.id, st.value);
    spend += a.reduce((s, x) => s + (x.monthly_cost_cents ?? 0), 0);
    if (a.length === 0) { gaps++; gapCount++; }
    if (a.length >= 2) {
      dblCount++;
      doublePays.push({ propertyId: p.id, propertyName: p.name, type: st.value,
        vendors: a.map((x) => x.vendor_name), combined: a.reduce((s, x) => s + (x.monthly_cost_cents ?? 0), 0) });
    }
  }
  return { ...p, spend, gapCount, dblCount, sysCount: SERVICE_TYPES.reduce((n, st) => n + cellFor(p.id, st.value).length, 0) };
});

const propById = new Map(properties.map((p) => [p.id, p]));
const listRows = systems
  .map((s) => ({ s, p: propById.get(s.property_id)! })).filter((r) => r.p)
  .sort((a, b) => a.p.name.localeCompare(b.p.name) || a.s.service_type.localeCompare(b.s.service_type));

// Full client payload (powers the slide-over drawer + add/edit modal + CSV — all client-side).
const payload = {
  properties: properties.map((p) => ({ id: p.id, name: p.name, code: p.code, state: p.address_state })),
  types: SERVICE_TYPES.map((t) => ({ value: t.value, label: t.label, short: t.short })),
  systems: systems.map((s) => ({
    id: s.id, property_id: s.property_id, service_type: s.service_type, vendor_name: s.vendor_name,
    account_number: s.account_number, contact_name: s.contact_name, contact_phone: s.contact_phone,
    contact_email: s.contact_email, monthly_cents: s.monthly_cost_cents, contract_end: s.contract_end,
    cancel_notice: s.cancel_notice, status: s.status, notes: s.notes,
  })),
};

const input = "w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm text-[var(--color-navy)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brass)]/40 focus:border-[var(--color-brass)]";
const lbl = "block text-xs font-semibold text-[var(--color-muted)] mb-1";
---

<PortalLayout title="Systems">
  <CorporateNav
    active="systems"
    systemsCount={doublePays.length}
    description="Technology & systems vendors across every property — your termination legend (who to cancel when a property drops) and a double-pay check (two vendors billing for one service)."
  />

  {errorMsg && <div class="mb-4 rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700">{errorMsg}</div>}
  {saved && <div id="saved-banner" class="mb-4 rounded-lg border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">Saved.</div>}

  <!-- ───── Overview tiles ───── -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-5">
    <div class="rounded-xl border bg-white border-[var(--color-hairline)] p-4">
      <div class="text-xs font-semibold text-[var(--color-muted)] uppercase tracking-widest">Active systems</div>
      <div class="text-2xl font-bold text-[var(--color-navy)] mt-1">{activeSystems.length}</div>
      <div class="text-xs text-[var(--color-muted)] mt-1">across {properties.length} properties</div>
    </div>
    <div class="rounded-xl border bg-white border-[var(--color-hairline)] p-4">
      <div class="text-xs font-semibold text-[var(--color-muted)] uppercase tracking-widest">Monthly spend</div>
      <div class="text-2xl font-bold text-[var(--color-navy)] mt-1">{fmtMoney(monthlySpend)}</div>
      <div class="text-xs text-[var(--color-muted)] mt-1">where cost is on file</div>
    </div>
    <div class={`rounded-xl border p-4 ${doublePays.length ? "bg-red-50 border-red-300" : "bg-white border-[var(--color-hairline)]"}`}>
      <div class={`text-xs font-semibold uppercase tracking-widest ${doublePays.length ? "text-red-700" : "text-[var(--color-muted)]"}`}>Double-pay flags</div>
      <div class={`text-2xl font-bold mt-1 ${doublePays.length ? "text-red-700" : "text-[var(--color-navy)]"}`}>{doublePays.length}</div>
      <div class="text-xs text-[var(--color-muted)] mt-1">2+ vendors, 1 service</div>
    </div>
    <div class={`rounded-xl border p-4 ${gaps ? "bg-amber-50 border-amber-300" : "bg-white border-[var(--color-hairline)]"}`}>
      <div class={`text-xs font-semibold uppercase tracking-widest ${gaps ? "text-amber-700" : "text-[var(--color-muted)]"}`}>Coverage gaps</div>
      <div class={`text-2xl font-bold mt-1 ${gaps ? "text-amber-700" : "text-[var(--color-navy)]"}`}>{gaps}</div>
      <div class="text-xs text-[var(--color-muted)] mt-1">no vendor on file</div>
    </div>
  </div>

  <!-- ───── Double-pay alert (collapsible) ───── -->
  {doublePays.length > 0 && (
    <details open class="mb-5 rounded-xl border border-red-300 bg-red-50 overflow-hidden group">
      <summary class="px-5 py-3 flex items-center gap-2 cursor-pointer select-none list-none">
        <span class="text-red-700">⚠</span>
        <h2 class="font-semibold text-red-800 flex-1">{doublePays.length} possible double-pay{doublePays.length === 1 ? "" : "s"} — two active vendors for one service</h2>
        <span class="text-red-700 text-xs group-open:rotate-180 transition-transform">▾</span>
      </summary>
      <ul class="divide-y divide-red-100 border-t border-red-200">
        {doublePays.map((d) => (
          <li class="px-5 py-3 flex items-center justify-between gap-4 flex-wrap">
            <div>
              <button type="button" class="open-prop font-semibold text-[var(--color-navy)] hover:text-red-700" data-prop={d.propertyId}>{d.propertyName}</button>
              <span class="text-[var(--color-muted)]"> · {serviceLabel(d.type)}</span>
              <div class="text-sm text-red-700 mt-0.5">{d.vendors.join("  vs.  ")}</div>
            </div>
            <div class="text-right"><div class="text-xs text-[var(--color-muted)] uppercase tracking-widest">combined / mo</div><div class="font-bold text-red-700 tabular-nums">{fmtMoney(d.combined)}</div></div>
          </li>
        ))}
      </ul>
    </details>
  )}

  <!-- ───── Workspace card ───── -->
  <section class="rounded-2xl border border-[var(--color-hairline)] bg-white overflow-hidden">
    <!-- card header: title + view toggle -->
    <header class="px-5 py-3.5 flex items-center justify-between gap-4 flex-wrap border-b border-[var(--color-hairline)]">
      <h2 class="font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">Vendor systems</h2>
      <div class="inline-flex rounded-lg border border-[var(--color-hairline)] overflow-hidden">
        <button id="view-list-btn" data-view="list" class="view-btn px-3.5 py-1.5 text-sm font-semibold">List</button>
        <button id="view-matrix-btn" data-view="matrix" class="view-btn px-3.5 py-1.5 text-sm font-semibold border-l border-[var(--color-hairline)]">Matrix</button>
      </div>
    </header>

    <!-- sticky toolbar -->
    <div class="sticky top-0 z-20 bg-[var(--color-cream)]/95 backdrop-blur px-5 py-3 border-b border-[var(--color-hairline)] flex flex-wrap items-center gap-2">
      <div class="relative flex-1 min-w-[200px]">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[var(--color-muted)] text-sm">⌕</span>
        <input id="sys-search" type="search" placeholder="Filter by property, vendor, account…" class={`${input} pl-8`} />
      </div>
      <select id="type-filter" class="rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm">
        <option value="all">All systems</option>
        {SERVICE_TYPES.map((s) => <option value={s.value}>{s.label}</option>)}
      </select>
      <select id="matrix-sort" class="rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" style="display:none">
        <option value="name">Property A–Z</option>
        <option value="spend">Monthly spend ↓</option>
        <option value="gaps">Most gaps ↓</option>
        <option value="dbl">Most double-pays ↓</option>
      </select>
      <button type="button" id="export-btn" class="btn-ghost text-sm">Export</button>
      <button type="button" id="add-btn" class="pill pill-statement text-sm font-semibold">+ Add system</button>
    </div>

    <p id="result-count" class="px-5 pt-3 text-xs text-[var(--color-muted)]"></p>

    <!-- LIST view (default) -->
    <div id="view-list" class="px-2 pb-2">
      <div class="overflow-x-auto">
        <table class="sys-table sys-list w-full" id="list-table">
          <thead>
            <tr>
              <th data-sort data-type="text">Property <span class="arw">⇅</span></th>
              <th data-sort data-type="text">System <span class="arw">⇅</span></th>
              <th data-sort data-type="text">Vendor <span class="arw">⇅</span></th>
              <th data-sort data-type="text">Account # <span class="arw">⇅</span></th>
              <th data-sort data-type="num" class="num">Monthly <span class="arw">⇅</span></th>
              <th data-sort data-type="text">Status <span class="arw">⇅</span></th>
            </tr>
          </thead>
          <tbody id="list-body">
            {listRows.map(({ s, p }) => (
              <tr class="l-row cursor-pointer" data-search={`${p.name} ${serviceLabel(s.service_type)} ${s.vendor_name} ${s.account_number ?? ""}`.toLowerCase()} data-type-key={s.service_type} data-prop={p.id}>
                <td class="font-semibold text-[var(--color-navy)]">{p.name}{p.address_state && <span class="pst">· {p.address_state}</span>}</td>
                <td>{serviceLabel(s.service_type)}</td>
                <td>{s.vendor_name}</td>
                <td class="acct">{s.account_number || "—"}</td>
                <td class="num" data-sort-value={s.monthly_cost_cents ?? 0}>{fmtMoney(s.monthly_cost_cents)}</td>
                <td data-sort-value={s.status}>{s.status === "cancelled" ? <span class="badge-neutral">Cancelled</span> : <span class="badge-active">Active</span>}</td>
              </tr>
            ))}
            {listRows.length === 0 && (
              <tr><td colspan="6" class="empty">
                <div class="mx-auto max-w-[420px]">
                  <div class="text-[var(--color-navy)] font-bold text-base mb-1">No systems recorded yet</div>
                  <p class="mb-4">All {properties.length} properties are already loaded. Add each one's phone, internet, WiFi, cameras and the rest — the double-pay and gap checks start working the moment you do.</p>
                  <button type="button" id="empty-add-btn" class="pill pill-statement text-sm font-semibold">+ Add your first system</button>
                </div>
              </td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- MATRIX view -->
    <div id="view-matrix" class="hidden px-2 pb-2">
      <div class="overflow-auto" style="max-height:64vh">
        <table class="sys-table sys-matrix w-full">
          <thead>
            <tr>
              <th class="sticky-col" data-sort data-type="text">Property <span class="arw">⇅</span></th>
              {SERVICE_TYPES.map((t) => <th data-col={t.value} class="col-head"><span title={t.label}>{t.short}</span></th>)}
            </tr>
          </thead>
          <tbody id="matrix-body">
            {propMeta.map((p) => (
              <tr class="m-row" data-search={`${p.name} ${p.code ?? ""} ${p.address_state ?? ""}`.toLowerCase()} data-prop={p.id}
                data-name={p.name.toLowerCase()} data-spend={p.spend} data-gaps={p.gapCount} data-dbl={p.dblCount}>
                <td class="sticky-col">
                  <button type="button" class="open-prop pname" data-prop={p.id}>{p.name}</button>
                  {p.address_state && <span class="pst">· {p.address_state}</span>}
                </td>
                {SERVICE_TYPES.map((t) => {
                  const a = cellFor(p.id, t.value);
                  if (a.length >= 2) return <td data-col={t.value} class="cell-dbl"><button type="button" class="open-prop block w-full text-left" data-prop={p.id}><span class="dbl-flag">⚠ {a.length}</span>{a.map((x) => <span class="dbl-v">{x.vendor_name}</span>)}</button></td>;
                  if (a.length === 1) return <td data-col={t.value} class="cell-one">{a[0].vendor_name}</td>;
                  return <td data-col={t.value} class="cell-gap" title="No vendor on file">—</td>;
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="key px-3">
        <span class="sw gap"></span> gap · <span class="sw dbl"></span> double-pay · click a property for its termination legend.
      </p>
    </div>
  </section>
</PortalLayout>

<!-- ═══════ Slide-over drawer (property termination legend) ═══════ -->
<div id="overlay" class="fixed inset-0 bg-black/40 z-40 opacity-0 pointer-events-none transition-opacity"></div>

<aside id="drawer" role="dialog" aria-modal="true" aria-labelledby="drawer-title" tabindex="-1" class="fixed top-0 right-0 h-full w-full max-w-[520px] bg-white z-50 shadow-2xl translate-x-full transition-transform flex flex-col outline-none">
  <header class="px-5 py-4 bg-[var(--color-navy)] text-white flex items-start justify-between gap-3">
    <div>
      <h2 id="drawer-title" class="text-lg font-bold" style="font-family: var(--font-display);"></h2>
      <p id="drawer-sub" class="text-sm text-white/70 mt-0.5"></p>
    </div>
    <button type="button" id="drawer-close" class="text-white/80 hover:text-white text-2xl leading-none">×</button>
  </header>
  <div class="px-5 py-3 border-b border-[var(--color-hairline)] flex gap-2 flex-wrap">
    <button type="button" id="drawer-add" class="pill pill-statement text-sm font-semibold">+ Add system here</button>
    <button type="button" id="drawer-print" class="btn-ghost text-sm">Print</button>
    <button type="button" id="drawer-csv" class="btn-ghost text-sm">Export CSV</button>
  </div>
  <div id="drawer-body" class="flex-1 overflow-y-auto p-5"></div>
</aside>

<!-- ═══════ Add / Edit modal ═══════ -->
<div id="modal-overlay" class="fixed inset-0 bg-black/40 z-[60] opacity-0 pointer-events-none transition-opacity grid place-items-center p-4">
  <div id="modal-card" role="dialog" aria-modal="true" aria-labelledby="modal-title" class="bg-white rounded-2xl w-full max-w-[660px] max-h-[88vh] overflow-auto shadow-2xl scale-95 transition-transform">
    <header class="px-5 py-4 border-b border-[var(--color-hairline)] flex items-center justify-between sticky top-0 bg-white">
      <h2 id="modal-title" class="font-bold text-[var(--color-navy)]" style="font-family: var(--font-display);">Add a system</h2>
      <button type="button" id="modal-close" class="text-[var(--color-muted)] hover:text-[var(--color-navy)] text-2xl leading-none">×</button>
    </header>
    <form method="POST" id="system-form" class="p-5 grid grid-cols-1 md:grid-cols-2 gap-4">
      <input type="hidden" name="action" id="form-action-field" value="" />
      <div class="md:col-span-2" id="prop-select-wrap">
        <label class={lbl}>Property</label>
        <select name="_property" id="form-property" class={input}>
          <option value="">Choose…</option>
          {properties.map((p) => <option value={p.id}>{p.name}{p.address_state ? ` · ${p.address_state}` : ""}</option>)}
        </select>
      </div>
      <div><label class={lbl}>System type</label>
        <select name="service_type" id="form-type" class={input}>{SERVICE_TYPES.map((t) => <option value={t.value}>{t.label}</option>)}</select>
      </div>
      <div><label class={lbl}>Vendor</label><input name="vendor_name" id="form-vendor" required placeholder="e.g. Spectrum" class={input} /></div>
      <div><label class={lbl}>Account #</label><input name="account_number" id="form-account" class={input} /></div>
      <div><label class={lbl}>Monthly cost</label><input name="monthly_cost" id="form-cost" placeholder="$0.00" class={input} /></div>
      <div><label class={lbl}>Contact name</label><input name="contact_name" id="form-cname" class={input} /></div>
      <div><label class={lbl}>Contact phone</label><input name="contact_phone" id="form-cphone" class={input} /></div>
      <div><label class={lbl}>Contact email</label><input name="contact_email" id="form-cemail" class={input} /></div>
      <div><label class={lbl}>Contract end</label><input type="date" name="contract_end" id="form-contract" class={input} /></div>
      <div class="md:col-span-2"><label class={lbl}>Cancellation notice</label><input name="cancel_notice" id="form-cancel" placeholder="e.g. 30 days written notice to billing@vendor.com" class={input} /></div>
      <div><label class={lbl}>Status</label><select name="status" id="form-status" class={input}><option value="active">Active</option><option value="cancelled">Cancelled</option></select></div>
      <div class="md:col-span-2"><label class={lbl}>Notes</label><input name="notes" id="form-notes" class={input} /></div>
      <div class="md:col-span-2 flex gap-2 pt-1">
        <button type="submit" class="pill pill-statement text-sm font-semibold">Save</button>
        <button type="button" id="modal-cancel" class="btn-ghost text-sm">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script type="application/json" id="systems-data" set:html={JSON.stringify(payload)}></script>

<style>
  .sys-table{border-collapse:separate;border-spacing:0;font-size:13px;}
  .sys-table thead th{position:sticky;top:0;z-index:3;background:var(--color-cream);text-align:left;padding:10px 14px;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:var(--color-muted);white-space:nowrap;border-bottom:1px solid var(--color-hairline);}
  .sys-table th[data-sort]{cursor:pointer;user-select:none;}
  .sys-table th[data-sort]:hover{color:var(--color-navy);background:#f3efe5;}
  .sys-table th .arw{color:var(--color-brass);margin-left:3px;font-size:10px;opacity:.55;}
  .sys-table th[data-dir] .arw{opacity:1;}
  .sys-table tbody td{padding:10px 14px;border-bottom:1px solid var(--color-hairline);vertical-align:middle;color:var(--color-navy);}
  .sys-table tbody tr:last-child td{border-bottom:none;}
  .sys-list tbody tr:hover td{background:#fcfbf8;}
  .sys-matrix th.sticky-col,.sys-matrix td.sticky-col{position:sticky;left:0;z-index:2;background:#fff;min-width:200px;}
  .sys-matrix thead th.sticky-col{z-index:4;background:var(--color-cream);}
  .sys-matrix tbody tr:hover td{background:#fcfbf8;}
  .sys-matrix tbody tr:hover td.sticky-col{background:#fcfbf8;}
  .sys-matrix th.col-head{min-width:116px;}
  .pname{font-weight:700;color:var(--color-navy);}
  .pname:hover{color:var(--color-brass-dark);text-decoration:underline;}
  .pst{color:var(--color-muted);font-size:11px;margin-left:5px;}
  .cell-gap{background:rgba(254,243,199,.3);color:#c59a52;text-align:center;}
  .cell-dbl{background:#FEF3F2;}
  .dbl-flag{display:block;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.03em;color:#B42318;}
  .dbl-v{display:block;font-size:12px;color:#912018;line-height:1.3;}
  .num{text-align:right;font-variant-numeric:tabular-nums;}
  .acct{font-family:ui-monospace,Menlo,monospace;font-size:12px;color:var(--color-muted);}
  .badge-active{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:600;padding:2px 9px;border-radius:999px;background:#ECFDF3;color:#067647;border:1px solid #ABEFC6;}
  .badge-neutral{display:inline-flex;font-size:12px;font-weight:600;padding:2px 9px;border-radius:999px;background:var(--color-cream);color:var(--color-muted);border:1px solid var(--color-hairline);}
  .empty{padding:40px;text-align:center;color:var(--color-muted);}
  .key{font-size:12px;color:var(--color-muted);margin-top:10px;}
  .sw{display:inline-block;width:12px;height:12px;border-radius:3px;vertical-align:middle;}
  .sw.gap{background:#fef0c7;border:1px solid #FEDF89;}
  .sw.dbl{background:#fee4e2;border:1px solid #FECDCA;}
  .view-btn{color:var(--color-muted);background:#fff;}
  .view-btn.is-active{background:var(--color-navy);color:#fff;}
  #overlay.show,#modal-overlay.show{opacity:1;pointer-events:auto;}
  #drawer.show{transform:translateX(0);}
  #modal-overlay.show #modal-card{transform:scale(1);}
  /* motion — natural deceleration, transform/opacity only */
  #overlay,#modal-overlay{transition:opacity .2s ease;}
  #drawer{transition:transform .34s cubic-bezier(.16,1,.3,1);}
  #modal-card{transition:transform .24s cubic-bezier(.16,1,.3,1);}
  :focus-visible{outline:2px solid var(--color-brass);outline-offset:2px;border-radius:3px;}
  @media (prefers-reduced-motion: reduce){#overlay,#modal-overlay,#drawer,#modal-card{transition:none;}}
  /* drawer legend rows */
  .lg-row{border:1px solid var(--color-hairline);border-radius:12px;padding:12px 14px;margin-bottom:10px;}
  .lg-row.cancelled{opacity:.55;}
  .lg-svc{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--color-brass-dark);}
  .lg-vendor{font-weight:700;color:var(--color-navy);font-size:15px;}
  .lg-meta{font-size:12px;color:var(--color-muted);margin-top:2px;}
  .lg-field{font-size:12px;margin-top:6px;}
  .lg-field b{color:var(--color-muted);font-weight:600;}
  .lg-actions{margin-top:8px;display:flex;gap:12px;}
  .lg-actions button{font-size:12px;font-weight:600;}
</style>

<script is:inline>
(function () {
  var D = JSON.parse(document.getElementById("systems-data").textContent || "{}");
  var typeLabel = {}; D.types.forEach(function (t) { typeLabel[t.value] = t.label; });
  var propName = {}; D.properties.forEach(function (p) { propName[p.id] = p; });
  function money(c) { return c == null ? "—" : "$" + (c / 100).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
  function esc(s) { return (s == null ? "" : String(s)).replace(/[&<>"]/g, function (m) { return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[m]; }); }

  // ── View toggle ──
  var current = "list";
  var lastFocus = null, modalReturn = null; // return focus when overlays close (a11y)
  var els = {
    search: document.getElementById("sys-search"), type: document.getElementById("type-filter"),
    msort: document.getElementById("matrix-sort"), mbody: document.getElementById("matrix-body"),
    lbody: document.getElementById("list-body"), count: document.getElementById("result-count"),
    vList: document.getElementById("view-list"), vMatrix: document.getElementById("view-matrix"),
    bList: document.getElementById("view-list-btn"), bMatrix: document.getElementById("view-matrix-btn"),
  };
  function setView(v) {
    current = v;
    els.vList.classList.toggle("hidden", v !== "list");
    els.vMatrix.classList.toggle("hidden", v !== "matrix");
    els.bList.classList.toggle("is-active", v === "list");
    els.bMatrix.classList.toggle("is-active", v === "matrix");
    els.msort.style.display = v === "matrix" ? "" : "none";
    apply();
  }
  els.bList.addEventListener("click", function () { setView("list"); });
  els.bMatrix.addEventListener("click", function () { setView("matrix"); });

  function apply() {
    var q = (els.search.value || "").trim().toLowerCase(), type = els.type.value;
    var mShown = 0, mRows = els.mbody.querySelectorAll("tr.m-row");
    Array.prototype.forEach.call(mRows, function (tr) {
      var hit = !q || tr.getAttribute("data-search").indexOf(q) > -1;
      tr.style.display = hit ? "" : "none"; if (hit) mShown++;
    });
    document.querySelectorAll(".sys-matrix [data-col]").forEach(function (c) {
      c.style.display = (type === "all" || c.getAttribute("data-col") === type) ? "" : "none";
    });
    var lShown = 0, lRows = els.lbody.querySelectorAll("tr.l-row");
    Array.prototype.forEach.call(lRows, function (tr) {
      var hit = (!q || tr.getAttribute("data-search").indexOf(q) > -1) && (type === "all" || tr.getAttribute("data-type-key") === type);
      tr.style.display = hit ? "" : "none"; if (hit) lShown++;
    });
    els.count.textContent = current === "matrix"
      ? mShown + " of " + mRows.length + " properties"
      : lShown + " of " + lRows.length + " systems";
  }
  els.search.addEventListener("input", apply);
  els.type.addEventListener("change", apply);

  els.msort.addEventListener("change", function () {
    var key = els.msort.value, rows = Array.prototype.slice.call(els.mbody.querySelectorAll("tr.m-row"));
    rows.sort(function (a, b) {
      if (key === "name") return a.getAttribute("data-name").localeCompare(b.getAttribute("data-name"));
      return (parseFloat(b.getAttribute("data-" + key)) || 0) - (parseFloat(a.getAttribute("data-" + key)) || 0);
    });
    rows.forEach(function (r) { els.mbody.appendChild(r); });
  });

  // ── Generic header sort (list + matrix property col) ──
  function wireSort(table, body, rowSel) {
    if (!table) return;
    var heads = table.tHead.rows[0].cells;
    Array.prototype.forEach.call(heads, function (th, idx) {
      if (!th.hasAttribute("data-sort")) return;
      th.addEventListener("click", function () {
        var type = th.getAttribute("data-type") || "text";
        var dir = th.getAttribute("data-dir") === "asc" ? "desc" : "asc";
        Array.prototype.forEach.call(heads, function (h) { if (h !== th) { h.removeAttribute("data-dir"); var a = h.querySelector(".arw"); if (a) a.textContent = "⇅"; } });
        th.setAttribute("data-dir", dir);
        var a = th.querySelector(".arw"); if (a) a.textContent = dir === "asc" ? "▲" : "▼";
        var rows = Array.prototype.slice.call(body.querySelectorAll(rowSel));
        rows.sort(function (r1, r2) {
          function val(tr) { var td = tr.cells[idx]; var v = td.getAttribute("data-sort-value"); if (v == null) v = td.textContent.trim(); return type === "num" ? (parseFloat(String(v).replace(/[^0-9.\-]/g, "")) || 0) : String(v).toLowerCase(); }
          var x = val(r1), y = val(r2); return (x < y ? -1 : x > y ? 1 : 0) * (dir === "asc" ? 1 : -1);
        });
        rows.forEach(function (r) { body.appendChild(r); });
      });
    });
  }
  wireSort(document.getElementById("list-table"), els.lbody, "tr.l-row");
  wireSort(document.querySelector(".sys-matrix"), els.mbody, "tr.m-row");

  // ── Drawer (property termination legend) ──
  var overlay = document.getElementById("overlay"), drawer = document.getElementById("drawer");
  var curProp = null;
  function openDrawer(pid) {
    var p = propName[pid]; if (!p) return;
    if (!drawer.classList.contains("show")) lastFocus = document.activeElement;
    curProp = pid;
    var rows = D.systems.filter(function (s) { return s.property_id === pid; })
      .sort(function (a, b) { return (typeLabel[a.service_type] || "").localeCompare(typeLabel[b.service_type] || ""); });
    var active = rows.filter(function (s) { return s.status === "active"; });
    var mo = active.reduce(function (s, x) { return s + (x.monthly_cents || 0); }, 0);
    document.getElementById("drawer-title").textContent = p.name + (p.state ? " · " + p.state : "");
    document.getElementById("drawer-sub").textContent = "Who to notify to cancel accounts · " + rows.length + " system" + (rows.length === 1 ? "" : "s") + " · " + money(mo) + "/mo active";
    var body = document.getElementById("drawer-body");
    if (!rows.length) { body.innerHTML = '<div class="empty">No systems recorded yet. Click “+ Add system here”.</div>'; }
    else body.innerHTML = rows.map(function (s) {
      var who = [s.contact_name, s.contact_phone, s.contact_email].filter(Boolean).map(esc).join(" · ") || "—";
      return '<div class="lg-row ' + (s.status === "cancelled" ? "cancelled" : "") + '">' +
        '<div class="lg-svc">' + esc(typeLabel[s.service_type] || s.service_type) + (s.status === "cancelled" ? " · cancelled" : "") + '</div>' +
        '<div class="lg-vendor">' + esc(s.vendor_name) + '</div>' +
        '<div class="lg-meta">' + money(s.monthly_cents) + '/mo' + (s.account_number ? ' · acct ' + esc(s.account_number) : "") + '</div>' +
        '<div class="lg-field"><b>Who to call:</b> ' + who + '</div>' +
        (s.cancel_notice ? '<div class="lg-field"><b>Cancel:</b> ' + esc(s.cancel_notice) + '</div>' : "") +
        (s.contract_end ? '<div class="lg-field"><b>Term ends:</b> ' + esc(s.contract_end) + '</div>' : "") +
        (s.notes ? '<div class="lg-field"><b>Notes:</b> ' + esc(s.notes) + '</div>' : "") +
        '<div class="lg-actions"><button type="button" class="text-[var(--color-brass-dark)] hover:underline edit-sys" data-id="' + s.id + '">Edit</button>' +
        '<button type="button" class="text-red-600 hover:underline del-sys" data-id="' + s.id + '">Delete</button></div></div>';
    }).join("");
    overlay.classList.add("show"); drawer.classList.add("show");
    drawer.focus();
    history.replaceState(null, "", location.pathname + "?property=" + encodeURIComponent(pid));
  }
  function closeDrawer() {
    overlay.classList.remove("show"); drawer.classList.remove("show"); curProp = null;
    history.replaceState(null, "", location.pathname);
    if (lastFocus && lastFocus.focus) { lastFocus.focus(); lastFocus = null; }
  }
  document.getElementById("drawer-close").addEventListener("click", closeDrawer);
  overlay.addEventListener("click", closeDrawer);
  document.addEventListener("click", function (e) {
    var op = e.target.closest(".open-prop, .l-row"); if (op) { openDrawer(op.getAttribute("data-prop")); }
    var ed = e.target.closest(".edit-sys"); if (ed) openModalEdit(ed.getAttribute("data-id"));
    var dl = e.target.closest(".del-sys"); if (dl) deleteSystem(dl.getAttribute("data-id"));
  });

  // ── Add / Edit modal ──
  var mOverlay = document.getElementById("modal-overlay"), form = document.getElementById("system-form");
  function setField(id, v) { document.getElementById(id).value = v == null ? "" : v; }
  function openModal(focusId) {
    modalReturn = document.activeElement;
    mOverlay.classList.add("show");
    setTimeout(function () { var f = document.getElementById(focusId); if (f) f.focus(); }, 60);
  }
  function closeModal() {
    mOverlay.classList.remove("show");
    if (modalReturn && modalReturn.focus) { modalReturn.focus(); modalReturn = null; }
  }
  function openModalAdd(pid) {
    form.reset();
    document.getElementById("modal-title").textContent = "Add a system";
    document.getElementById("form-action-field").value = "";
    document.getElementById("prop-select-wrap").style.display = "";
    document.getElementById("form-property").value = pid || "";
    form.setAttribute("data-mode", "add");
    openModal(pid ? "form-type" : "form-property");
  }
  function openModalEdit(id) {
    var s = D.systems.filter(function (x) { return x.id === id; })[0]; if (!s) return;
    document.getElementById("modal-title").textContent = "Edit system";
    document.getElementById("form-action-field").value = "update";
    document.getElementById("prop-select-wrap").style.display = "none";
    setField("form-type", s.service_type); setField("form-vendor", s.vendor_name); setField("form-account", s.account_number);
    setField("form-cost", s.monthly_cents != null ? (s.monthly_cents / 100).toFixed(2) : "");
    setField("form-cname", s.contact_name); setField("form-cphone", s.contact_phone); setField("form-cemail", s.contact_email);
    setField("form-contract", s.contract_end); setField("form-cancel", s.cancel_notice); setField("form-notes", s.notes);
    setField("form-status", s.status);
    form.setAttribute("data-mode", "edit"); form.setAttribute("data-id", id);
    openModal("form-vendor");
  }
  form.addEventListener("submit", function (e) {
    if (form.getAttribute("data-mode") === "edit") { form.action = "/api/systems/" + form.getAttribute("data-id"); return; }
    var pid = document.getElementById("form-property").value;
    if (!pid) { e.preventDefault(); alert("Choose a property first."); return; }
    form.action = "/api/properties/" + pid + "/systems";
  });
  document.getElementById("add-btn").addEventListener("click", function () { openModalAdd(""); });
  var emptyAdd = document.getElementById("empty-add-btn");
  if (emptyAdd) emptyAdd.addEventListener("click", function () { openModalAdd(""); });
  document.getElementById("drawer-add").addEventListener("click", function () { openModalAdd(curProp); });
  document.getElementById("modal-close").addEventListener("click", closeModal);
  document.getElementById("modal-cancel").addEventListener("click", closeModal);
  mOverlay.addEventListener("click", function (e) { if (e.target === mOverlay) closeModal(); });

  function deleteSystem(id) {
    if (!confirm("Delete this system?")) return;
    var f = document.createElement("form"); f.method = "POST"; f.action = "/api/systems/" + id;
    var i = document.createElement("input"); i.name = "action"; i.value = "delete"; f.appendChild(i);
    document.body.appendChild(f); f.submit();
  }

  document.addEventListener("keydown", function (e) {
    if (e.key !== "Escape") return;
    if (mOverlay.classList.contains("show")) closeModal();
    else if (drawer.classList.contains("show")) closeDrawer();
  });

  // ── CSV ──
  function csvCell(v) { if (v == null) return ""; var s = String(v); return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s; }
  function download(name, rows) { var a = document.createElement("a"); a.href = URL.createObjectURL(new Blob([rows.map(function (r) { return r.map(csvCell).join(","); }).join("\n")], { type: "text/csv" })); a.download = name; a.click(); URL.revokeObjectURL(a.href); }
  document.getElementById("export-btn").addEventListener("click", function () {
    var head = ["Property", "Code", "State"].concat(D.types.map(function (t) { return t.label; }));
    var rows = [head];
    D.properties.forEach(function (p) {
      var row = [p.name, p.code, p.state];
      D.types.forEach(function (t) { row.push(D.systems.filter(function (s) { return s.property_id === p.id && s.service_type === t.value && s.status === "active"; }).map(function (s) { return s.vendor_name; }).join(" | ")); });
      rows.push(row);
    });
    download("systems-matrix.csv", rows);
  });
  document.getElementById("drawer-csv").addEventListener("click", function () {
    if (!curProp) return;
    var rows = [["Service", "Vendor", "Account #", "Contact name", "Contact phone", "Contact email", "Monthly", "Contract end", "Cancellation notice", "Status", "Notes"]];
    D.systems.filter(function (s) { return s.property_id === curProp; }).forEach(function (s) { rows.push([typeLabel[s.service_type] || s.service_type, s.vendor_name, s.account_number, s.contact_name, s.contact_phone, s.contact_email, s.monthly_cents != null ? s.monthly_cents / 100 : "", s.contract_end, s.cancel_notice, s.status, s.notes]); });
    download((propName[curProp].name || "property").replace(/[^a-z0-9]+/gi, "-").toLowerCase() + "-systems.csv", rows);
  });
  document.getElementById("drawer-print").addEventListener("click", function () { window.print(); });

  // Auto-dismiss the "Saved" confirmation.
  var sb = document.getElementById("saved-banner");
  if (sb) setTimeout(function () { sb.style.transition = "opacity .4s ease"; sb.style.opacity = "0"; setTimeout(function () { sb.remove(); }, 420); }, 2600);

  // ── On load: reopen drawer if ?property present (survives save reload) ──
  var qp = new URLSearchParams(location.search).get("property");
  if (qp && propName[qp]) openDrawer(qp);
  setView("list");
})();
</script>
