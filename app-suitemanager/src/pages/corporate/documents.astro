---
import PortalLayout from "../../layouts/PortalLayout.astro";
import CorporateNav from "../../components/CorporateNav.astro";
export const prerender = false;

const env = Astro.locals.runtime.env;
const url = new URL(Astro.request.url);
const uploaded = url.searchParams.get("uploaded") === "1";
const error = url.searchParams.get("error");

// Corporate docs are property_id IS NULL. Visible only to admin + strand —
// middleware gates the page; the queries below also can't accidentally surface
// these to a GM because GM dashboards always filter by their own property_id.
const docs = await env.DB
  .prepare(
    `SELECT d.id, d.filename, d.category, d.vendor, d.amount_cents, d.note,
            d.status, d.payment_status, d.check_number, d.check_date,
            d.approval_status, d.created_at, u.name AS uploader_name
     FROM documents d
     LEFT JOIN users u ON u.id = d.uploaded_by
     WHERE d.property_id IS NULL
     ORDER BY d.created_at DESC LIMIT 30`
  )
  .all<{
    id: string; filename: string; category: string;
    vendor: string | null; amount_cents: number | null; note: string | null;
    status: string;
    payment_status: string; check_number: string | null; check_date: string | null;
    approval_status: string;
    created_at: string; uploader_name: string | null;
  }>();

const stats = await env.DB
  .prepare(
    `SELECT
       (SELECT COUNT(*) FROM documents WHERE property_id IS NULL) AS total,
       (SELECT COUNT(*) FROM documents WHERE property_id IS NULL AND category = 'invoice' AND payment_status = 'unpaid') AS unpaid_count,
       (SELECT COALESCE(SUM(amount_cents), 0) FROM documents WHERE property_id IS NULL AND category = 'invoice' AND payment_status = 'unpaid') AS unpaid_total,
       (SELECT COUNT(*) FROM documents WHERE property_id IS NULL AND approval_status = 'pending') AS pending_approval`
  )
  .first<{ total: number; unpaid_count: number; unpaid_total: number; pending_approval: number }>();

const fmtMoney = (cents: number | null) =>
  cents != null ? `$${(cents / 100).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "—";
const fmtRel = (iso: string) => {
  const d = new Date(iso + "Z");
  const diff = (Date.now() - d.getTime()) / 60000;
  if (diff < 1) return "just now";
  if (diff < 60) return `${Math.round(diff)} min ago`;
  if (diff < 1440) return `${Math.round(diff / 60)} hr ago`;
  if (diff < 1440 * 30) return `${Math.round(diff / 1440)} d ago`;
  return d.toLocaleDateString();
};
const pillClass = (cat: string) =>
  cat === "invoice" ? "pill-invoice" :
  cat === "expense" ? "pill-other" :
  cat === "mileage" ? "pill-other" :
  "pill-other";
---

<PortalLayout title="Corporate · Documents" context="Suite Manager">
  <CorporateNav
    active="documents"
    documentsCount={stats?.total ?? 0}
    description="Personal expense reports, mileage, and special invoices to be paid. Goes to Strand's queue. Not visible to property GMs."
  />

  <!-- Stats strip -->
  <div class="bg-white border border-[var(--color-hairline)] rounded-2xl p-6 mb-6">
    <div class="grid grid-cols-3 gap-3">
      <div>
        <div class="text-xs text-[var(--color-muted)] uppercase tracking-widest font-semibold">Documents</div>
        <div class="text-xl font-bold text-[var(--color-navy)] mt-0.5">{stats?.total ?? 0}</div>
      </div>
      <div class={(stats?.unpaid_count ?? 0) > 0 ? "rounded-lg bg-[var(--color-brass-light)]/20 px-3 -mx-3" : ""}>
        <div class={`text-xs uppercase tracking-widest font-semibold ${(stats?.unpaid_count ?? 0) > 0 ? "text-[var(--color-brass-dark)]" : "text-[var(--color-muted)]"}`}>Unpaid invoices</div>
        <div class="text-xl font-bold text-[var(--color-navy)] mt-0.5">
          {stats?.unpaid_count ?? 0}
          {(stats?.unpaid_total ?? 0) > 0 && (
            <span class="text-xs text-[var(--color-muted)] font-normal ml-2 tabular-nums">{fmtMoney(stats?.unpaid_total ?? 0)}</span>
          )}
        </div>
      </div>
      <div class={(stats?.pending_approval ?? 0) > 0 ? "rounded-lg bg-amber-50 px-3 -mx-3" : ""}>
        <div class={`text-xs uppercase tracking-widest font-semibold ${(stats?.pending_approval ?? 0) > 0 ? "text-amber-800" : "text-[var(--color-muted)]"}`}>Awaiting approval</div>
        <div class="text-xl font-bold text-[var(--color-navy)] mt-0.5">{stats?.pending_approval ?? 0}</div>
      </div>
    </div>
  </div>

  {uploaded && (
    <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-5 py-4 text-sm text-green-800">
      Uploaded. Strand has it in their queue.
    </div>
  )}
  {error && (
    <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700">
      {error}
    </div>
  )}

  <!-- Upload + recent docs -->
  <div class="grid lg:grid-cols-[1fr_1fr] gap-6">
    <section>
      <h2 class="text-lg font-bold text-[var(--color-navy)] mb-2" style="font-family: var(--font-display);">
        Upload a Corporate document
      </h2>
      <p class="text-sm text-[var(--color-muted)] mb-4">
        Expense report, mileage log, invoice to pay, or other.
      </p>

      <form
        method="POST"
        action="/api/upload-corporate"
        enctype="multipart/form-data"
        class="bg-white border border-[var(--color-hairline)] rounded-2xl p-5 space-y-5"
      >
        <label data-dropzone class="block border-2 border-dashed border-[var(--color-brass)] rounded-xl bg-[var(--color-brass-light)]/15 px-6 py-8 text-center cursor-pointer hover:bg-[var(--color-brass-light)]/25 transition-colors">
          <input type="file" name="file" class="sr-only" required
            accept="application/pdf,image/jpeg,image/png,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel" />
          <div data-dropzone-label class="text-[var(--color-brass-dark)] font-semibold text-sm">
            Drag a file here, or click to browse
          </div>
          <div class="text-xs text-[var(--color-muted)] mt-1">
            PDF, JPG, PNG, or Excel · up to 25 MB
          </div>
        </label>

        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-2">Category</div>
          <div class="grid grid-cols-2 gap-2">
            {[
              { value: "invoice", label: "Invoice" },
              { value: "expense", label: "Expense report" },
              { value: "mileage", label: "Mileage" },
              { value: "other", label: "Other" },
            ].map((opt, i) => (
              <label class="flex items-center justify-center cursor-pointer rounded-lg border border-[var(--color-hairline)] bg-white px-4 py-2.5 has-[:checked]:bg-[var(--color-navy)] has-[:checked]:text-white has-[:checked]:border-[var(--color-navy)] transition-colors">
                <input type="radio" name="category" value={opt.value} class="sr-only" required checked={i === 0} />
                <span class="font-semibold text-sm">{opt.label}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="amount" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Amount</label>
            <input id="amount" name="amount" type="number" step="0.01" min="0" placeholder="$ 0.00"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          </div>
          <div>
            <label for="vendor" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Vendor / Payee</label>
            <input id="vendor" name="vendor" type="text" placeholder="Vendor or person to reimburse"
              class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
          </div>
        </div>

        <div>
          <label for="invoice_number" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
            Invoice / reference number <span class="text-[var(--color-muted)] font-normal normal-case tracking-normal">(optional)</span>
          </label>
          <input id="invoice_number" name="invoice_number" type="text" placeholder="e.g. INV-10472 or trip-1234"
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm" />
        </div>

        <div>
          <label for="note" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Note (optional)</label>
          <textarea id="note" name="note" rows="2" placeholder="Context for Strand"
            class="w-full rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-sm"></textarea>
        </div>

        <button type="submit" class="btn-primary w-full">Send to Strand</button>
      </form>
    </section>

    <section>
      <h2 class="text-lg font-bold text-[var(--color-navy)] mb-2" style="font-family: var(--font-display);">
        Recent Corporate documents
      </h2>
      <p class="text-sm text-[var(--color-muted)] mb-4">
        Click any document for details and payment status.
      </p>

      <div class="bg-white border border-[var(--color-hairline)] rounded-2xl overflow-hidden">
        {docs.results.length === 0 ? (
          <div class="px-5 py-10 text-center text-[var(--color-muted)] text-sm">
            Nothing yet. Use the form on the left to send the first one.
          </div>
        ) : (
          <ul class="divide-y divide-[var(--color-hairline)]">
            {docs.results.map((d) => (
              <li>
                <a href={`/dashboard/${d.id}`} class="block px-5 py-3 hover:bg-[var(--color-cream)]">
                  <div class="flex items-center justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                        <span class={`pill ${pillClass(d.category)} capitalize`}>{d.category}</span>
                        {d.approval_status === "pending" && (
                          <span class="pill bg-amber-100 text-amber-800 border border-amber-300">Awaiting approval</span>
                        )}
                        {d.approval_status === "approved" && (
                          <span class="pill bg-green-100 text-green-800 border border-green-200">Approved</span>
                        )}
                        {d.approval_status === "denied" && (
                          <span class="pill bg-red-100 text-red-700 border border-red-200">Denied</span>
                        )}
                        {d.category === "invoice" && (
                          d.payment_status === "paid" ? (
                            <span class="pill bg-green-100 text-green-800 border border-green-200">Paid</span>
                          ) : (
                            <span class="pill bg-[var(--color-brass-light)]/30 text-[var(--color-brass-dark)] border border-[var(--color-brass)]">Unpaid</span>
                          )
                        )}
                      </div>
                      <div class="text-sm text-[var(--color-navy)] truncate">{d.filename}</div>
                      <div class="text-xs text-[var(--color-muted)] mt-0.5">
                        {d.vendor || "—"} · {fmtRel(d.created_at)}
                        {d.uploader_name && <span class="text-[var(--color-muted)]"> · {d.uploader_name}</span>}
                        {d.payment_status === "paid" && d.check_number && (
                          <span class="ml-2 text-green-700">· Check #{d.check_number} {d.check_date}</span>
                        )}
                      </div>
                    </div>
                    <div class="text-right shrink-0">
                      <div class="text-sm font-semibold text-[var(--color-navy)] tabular-nums">{fmtMoney(d.amount_cents)}</div>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </div>

  <!-- Dropzone interactivity — mirrors the GM upload form. -->
  <script is:inline>
    document.querySelectorAll("[data-dropzone]").forEach((dz) => {
      const input = dz.querySelector('input[type="file"]');
      const label = dz.querySelector("[data-dropzone-label]");
      const setName = (name) => { if (label && name) label.textContent = name; };
      input?.addEventListener("change", () => setName(input.files?.[0]?.name));
      ["dragenter", "dragover"].forEach((ev) =>
        dz.addEventListener(ev, (e) => { e.preventDefault(); dz.classList.add("ring-2","ring-[var(--color-brass)]"); })
      );
      ["dragleave", "drop"].forEach((ev) =>
        dz.addEventListener(ev, (e) => { e.preventDefault(); dz.classList.remove("ring-2","ring-[var(--color-brass)]"); })
      );
      dz.addEventListener("drop", (e) => {
        const f = e.dataTransfer?.files?.[0];
        if (f && input) {
          const dt = new DataTransfer();
          dt.items.add(f);
          input.files = dt.files;
          setName(f.name);
        }
      });
    });
  </script>
</PortalLayout>
