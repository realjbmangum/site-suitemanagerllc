---
import PortalLayout from "../../layouts/PortalLayout.astro";
import CorporateNav from "../../components/CorporateNav.astro";
export const prerender = false;

const env = Astro.locals.runtime.env;
const me = Astro.locals.user!;
const url = new URL(Astro.request.url);
const errorMsg = url.searchParams.get("error");
const created = url.searchParams.get("created") === "1";
const decided = url.searchParams.get("decided") === "1";
const deleted = url.searchParams.get("deleted") === "1";

// ── Today ──────────────────────────────────────────────
const todayLocal = new Date();
const todayY = todayLocal.getFullYear();
const todayM = todayLocal.getMonth() + 1;
const todayD = todayLocal.getDate();
const todayIso = `${todayY}-${String(todayM).padStart(2, "0")}-${String(todayD).padStart(2, "0")}`;

const toIso = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
function isoAdd(iso: string, days: number) {
  const [y, m, d] = iso.split("-").map(Number);
  return toIso(new Date(y, m - 1, d + days));
}
function dateRange(startIso: string, endIso: string): string[] {
  const out: string[] = [];
  let cur = startIso;
  while (cur <= endIso) { out.push(cur); cur = isoAdd(cur, 1); }
  return out;
}
function isoToDate(iso: string): Date {
  const [y, m, d] = iso.split("-").map(Number);
  return new Date(y, m - 1, d);
}
const ISO_DATE = /^\d{4}-\d{2}-\d{2}$/;

// ── View + anchor + filters ────────────────────────────
const viewParam = url.searchParams.get("view") || "month";
const view = ["day", "week", "month"].includes(viewParam) ? viewParam : "month";

const dParam = url.searchParams.get("d");
const anchorIso = dParam && ISO_DATE.test(dParam) ? dParam : todayIso;
const monthParam = url.searchParams.get("m") || anchorIso.slice(0, 7);
const [mY, mM] = monthParam.split("-").map(Number);
const viewYear = Number.isFinite(mY) ? mY : todayY;
const viewMonth = Number.isFinite(mM) && mM >= 1 && mM <= 12 ? mM : todayM;

const personFilter = url.searchParams.get("person") || "";
const propertyFilter = url.searchParams.get("property") || "";
const showPto = url.searchParams.get("pto") !== "off"; // default ON

// ── Compute the visible window + grid cells per view ────
type Cell = { iso: string; day: number; inMonth: boolean; isToday: boolean };
let windowStartIso = "";
let windowEndIso = "";
let cells: Cell[] = [];
let label = "";
let prevHref = "";
let nextHref = "";

const buildHref = (overrides: Record<string, string | null>) => {
  const u = new URL(url);
  for (const [k, v] of Object.entries(overrides)) {
    if (v === null || v === "") u.searchParams.delete(k);
    else u.searchParams.set(k, v);
  }
  return u.pathname + (u.search || "");
};

function weekStart(iso: string) {
  const [y, m, d] = iso.split("-").map(Number);
  const dt = new Date(y, m - 1, d);
  dt.setDate(dt.getDate() - dt.getDay()); // back to Sunday
  return toIso(dt);
}

if (view === "month") {
  const monthFirst = new Date(viewYear, viewMonth - 1, 1);
  const monthLast = new Date(viewYear, viewMonth, 0);
  const monthLastDay = monthLast.getDate();
  const gridStart = new Date(viewYear, viewMonth - 1, 1 - monthFirst.getDay());
  const gridEnd = new Date(viewYear, viewMonth - 1, monthLastDay + (6 - monthLast.getDay()));
  windowStartIso = toIso(gridStart);
  windowEndIso = toIso(gridEnd);
  for (let d = new Date(gridStart); d <= gridEnd; d.setDate(d.getDate() + 1)) {
    const iso = toIso(d);
    cells.push({ iso, day: d.getDate(), inMonth: d.getMonth() + 1 === viewMonth, isToday: iso === todayIso });
  }
  label = new Date(viewYear, viewMonth - 1, 1).toLocaleDateString(undefined, { month: "long", year: "numeric" });
  const prevM = viewMonth === 1 ? `${viewYear - 1}-12` : `${viewYear}-${String(viewMonth - 1).padStart(2, "0")}`;
  const nextM = viewMonth === 12 ? `${viewYear + 1}-01` : `${viewYear}-${String(viewMonth + 1).padStart(2, "0")}`;
  prevHref = buildHref({ m: prevM, d: null });
  nextHref = buildHref({ m: nextM, d: null });
} else if (view === "week") {
  const ws = weekStart(anchorIso);
  windowStartIso = ws;
  windowEndIso = isoAdd(ws, 6);
  for (const iso of dateRange(ws, windowEndIso)) {
    const [, , dd] = iso.split("-").map(Number);
    cells.push({ iso, day: dd, inMonth: true, isToday: iso === todayIso });
  }
  const a = isoToDate(ws);
  const b = isoToDate(windowEndIso);
  label = `${a.toLocaleDateString(undefined, { month: "short", day: "numeric" })} – ${b.toLocaleDateString(undefined, { month: "short", day: "numeric", year: "numeric" })}`;
  prevHref = buildHref({ d: isoAdd(ws, -7), m: null });
  nextHref = buildHref({ d: isoAdd(ws, 7), m: null });
} else {
  // day
  windowStartIso = anchorIso;
  windowEndIso = anchorIso;
  const [ay, am, ad] = anchorIso.split("-").map(Number);
  label = new Date(ay, am - 1, ad).toLocaleDateString(undefined, { weekday: "long", month: "long", day: "numeric", year: "numeric" });
  prevHref = buildHref({ d: isoAdd(anchorIso, -1), m: null });
  nextHref = buildHref({ d: isoAdd(anchorIso, 1), m: null });
}

// ── Reference data: properties + people for the filters ─
const propertiesRes = await env.DB
  .prepare("SELECT id, name FROM properties WHERE active = 1 ORDER BY name")
  .all<{ id: string; name: string }>();
const properties = propertiesRes.results;

const peopleRes = await env.DB
  .prepare(
    `SELECT DISTINCT u.id, u.name
     FROM calendar_events e JOIN users u ON u.id = e.owner_user_id
     WHERE e.source = 'regional' AND u.name IS NOT NULL
     ORDER BY u.name`
  )
  .all<{ id: string; name: string }>();
const people = peopleRes.results;

// ── Events in window (with person/property filters) ────
let where =
  "e.ends_at >= ? AND e.starts_at <= ? AND (e.source = 'regional' OR (e.source = 'gm_pto' AND e.approval_status = 'approved'))";
const binds: (string)[] = [windowStartIso, windowEndIso];
if (personFilter) { where += " AND e.owner_user_id = ?"; binds.push(personFilter); }
if (propertyFilter) { where += " AND e.property_id = ?"; binds.push(propertyFilter); }

const events = await env.DB
  .prepare(
    `SELECT e.id, e.owner_user_id, e.source, e.title, e.kind,
            e.starts_at, e.ends_at, e.notes,
            e.approval_status, e.property_id,
            u.name AS owner_name, u.role AS owner_role,
            p.name AS property_name
     FROM calendar_events e
     LEFT JOIN users u ON u.id = e.owner_user_id
     LEFT JOIN properties p ON p.id = e.property_id
     WHERE ${where}
     ORDER BY e.starts_at, e.title`
  )
  .bind(...binds)
  .all<{
    id: string; owner_user_id: string; source: string; title: string; kind: string;
    starts_at: string; ends_at: string; notes: string | null;
    approval_status: string; property_id: string | null;
    owner_name: string | null; owner_role: string | null; property_name: string | null;
  }>();

// Pending PTO inbox — always visible regardless of window.
const pending = await env.DB
  .prepare(
    `SELECT e.id, e.owner_user_id, e.kind, e.starts_at, e.ends_at, e.notes,
            e.created_at, e.property_id,
            u.name AS owner_name, u.email AS owner_email, p.name AS property_name
     FROM calendar_events e
     LEFT JOIN users u ON u.id = e.owner_user_id
     LEFT JOIN properties p ON p.id = e.property_id
     WHERE e.source = 'gm_pto' AND e.approval_status = 'pending'
     ORDER BY e.starts_at`
  )
  .all<{
    id: string; owner_user_id: string; kind: string;
    starts_at: string; ends_at: string; notes: string | null;
    created_at: string; property_id: string | null;
    owner_name: string | null; owner_email: string | null; property_name: string | null;
  }>();

// Index events by day for grid rendering.
const eventsByDay: Record<string, typeof events.results> = {};
for (const e of events.results) {
  if (e.source === "gm_pto" && !showPto) continue;
  const a = e.starts_at < windowStartIso ? windowStartIso : e.starts_at;
  const b = e.ends_at > windowEndIso ? windowEndIso : e.ends_at;
  for (const d of dateRange(a, b)) (eventsByDay[d] ||= []).push(e);
}
// Day-view list (events overlapping the anchor day, sorted).
const dayEventsList = view === "day" ? (eventsByDay[anchorIso] || []) : [];

// ── Spanning-bar layout for month / week grids ──────────
// Split the visible cells into week rows (7 columns each). For each week,
// clip every event to that week, then greedily assign lanes so overlapping
// events stack vertically without colliding. Each segment carries the grid
// column it starts at (1–7) and how many days it spans within the week.
type EventRow = (typeof events.results)[number];
type Segment = {
  ev: EventRow;
  colStart: number;   // 1-based column within the week (Sunday = 1)
  span: number;       // number of day columns covered in this week
  lane: number;       // 0-based stacked row
  clipLeft: boolean;  // event began before this week (continues from left)
  clipRight: boolean; // event continues past this week (to the right)
};
type WeekRow = {
  cells: Cell[];
  segments: Segment[];
  laneCount: number;
};

// Per-cell overflow tracking: how many segments in a cell got dropped past the cap.
const maxLanes = view === "week" ? 12 : 3; // month cells are short; week cells are tall
const overflowByDay: Record<string, number> = {};

const weeks: WeekRow[] = [];
if (view === "month" || view === "week") {
  // Chunk cells into rows of 7 (month grid is already aligned to Sunday;
  // week view is a single 7-cell row).
  for (let i = 0; i < cells.length; i += 7) {
    const weekCells = cells.slice(i, i + 7);
    if (weekCells.length === 0) continue;
    const wStartIso = weekCells[0].iso;
    const wEndIso = weekCells[weekCells.length - 1].iso;

    // Collect this week's clipped segments. Use the already day-indexed,
    // filtered event list so PTO toggle + person/property filters apply.
    // Dedupe by event id (an event spanning the week appears in many days).
    const seen = new Set<string>();
    const raw: { ev: EventRow; colStart: number; span: number; clipLeft: boolean; clipRight: boolean }[] = [];
    for (const cell of weekCells) {
      for (const e of eventsByDay[cell.iso] || []) {
        if (seen.has(e.id)) continue;
        seen.add(e.id);
        const segStart = e.starts_at < wStartIso ? wStartIso : e.starts_at;
        const segEnd = e.ends_at > wEndIso ? wEndIso : e.ends_at;
        const colStart = weekCells.findIndex((c) => c.iso === segStart) + 1;
        const colEnd = weekCells.findIndex((c) => c.iso === segEnd) + 1;
        if (colStart < 1 || colEnd < 1) continue; // shouldn't happen, defensive
        raw.push({
          ev: e,
          colStart,
          span: colEnd - colStart + 1,
          clipLeft: e.starts_at < wStartIso,
          clipRight: e.ends_at > wEndIso,
        });
      }
    }

    // Lane assignment: longest-running first, then earliest start, so wide
    // multi-day bars settle into the top lanes (Google-Calendar style).
    raw.sort((a, b) => {
      if (b.span !== a.span) return b.span - a.span;
      if (a.colStart !== b.colStart) return a.colStart - b.colStart;
      return a.ev.starts_at < b.ev.starts_at ? -1 : a.ev.starts_at > b.ev.starts_at ? 1 : 0;
    });

    const laneEnds: number[] = []; // laneEnds[lane] = last occupied column in that lane
    const segments: Segment[] = [];
    for (const r of raw) {
      const segEndCol = r.colStart + r.span - 1;
      // Find the first lane whose last occupied column is before this segment.
      let lane = laneEnds.findIndex((end) => end < r.colStart);
      if (lane === -1) { lane = laneEnds.length; laneEnds.push(segEndCol); }
      else laneEnds[lane] = segEndCol;

      if (lane >= maxLanes) {
        // Overflow: count it against every day this segment would have covered.
        for (let c = r.colStart; c <= segEndCol; c++) {
          overflowByDay[weekCells[c - 1].iso] = (overflowByDay[weekCells[c - 1].iso] || 0) + 1;
        }
        continue;
      }
      segments.push({ ev: r.ev, colStart: r.colStart, span: r.span, lane, clipLeft: r.clipLeft, clipRight: r.clipRight });
    }

    weeks.push({
      cells: weekCells,
      segments,
      laneCount: Math.min(laneEnds.length, maxLanes),
    });
  }
}
const LANE_PX = 20; // height reserved per lane (bar height + gap)

const WEEKDAYS = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

function kindLabel(k: string): string {
  switch (k) {
    case "travel": return "Travel";
    case "ooo": return "OOO";
    case "other": return "Schedule";
    case "vacation": return "Vacation";
    case "sick": return "Sick";
    case "personal": return "Personal";
    default: return k;
  }
}
function eventPillClass(source: string, kind: string): string {
  if (source === "gm_pto") {
    if (kind === "sick") return "bg-amber-100 text-amber-900 border border-amber-300";
    if (kind === "personal") return "bg-violet-100 text-violet-900 border border-violet-300";
    return "bg-green-100 text-green-900 border border-green-300";
  }
  if (kind === "travel") return "bg-sky-100 text-sky-900 border border-sky-300";
  if (kind === "ooo") return "bg-rose-100 text-rose-900 border border-rose-300";
  return "bg-slate-100 text-slate-800 border border-slate-300";
}

const isAdmin = me.role === "admin";
const filtersActive = personFilter || propertyFilter;
const personName = personFilter ? people.find((p) => p.id === personFilter)?.name : "";
const cellMin = view === "week" ? "min-h-[420px]" : "min-h-[110px]";

// data-* attributes that make any event element clickable → opens the detail
// modal. Spread onto the day-view rows and the spanning bars.
const evtAttrs = (e: EventRow) => ({
  "data-evt": "1",
  "data-id": e.id,
  "data-kindlabel": kindLabel(e.kind),
  "data-pill": eventPillClass(e.source, e.kind),
  "data-source": e.source,
  "data-status": e.approval_status || "",
  "data-owner": e.owner_name || "",
  "data-property": e.property_name || "",
  "data-start": e.starts_at,
  "data-end": e.ends_at,
  "data-title": e.title || "",
  "data-notes": e.notes || "",
  "data-candelete": (isAdmin || e.owner_user_id === me.id) ? "1" : "",
});
---

<PortalLayout title="Corporate · Calendar" context="Suite Manager">
  <CorporateNav
    active="calendar"
    calendarCount={pending.results.length}
    description={`Regional schedules and approved GM time off. ${isAdmin ? "You can approve PTO requests below." : "Strand-only view."}`}
  />

  <!-- ── Controls bar ─────────────────────────────────── -->
  <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
    <!-- Left: view toggle + nav -->
    <div class="flex items-center gap-2 flex-wrap">
      <div class="flex items-center bg-white border border-[var(--color-hairline)] rounded-lg overflow-hidden">
        {["day", "week", "month"].map((v) => (
          <a
            href={buildHref({ view: v })}
            class={`px-3 py-2 text-sm font-semibold capitalize transition-colors ${
              view === v
                ? "bg-[var(--color-navy)] text-white"
                : "text-[var(--color-navy)] hover:bg-[var(--color-cream)]"
            }`}
          >{v}</a>
        ))}
      </div>

      <div class="flex items-center bg-white border border-[var(--color-hairline)] rounded-lg overflow-hidden">
        <a href={prevHref} class="px-3 py-2 text-sm text-[var(--color-navy)] hover:bg-[var(--color-cream)]" aria-label="Previous">←</a>
        <span class="px-4 py-2 text-sm font-semibold text-[var(--color-navy)] border-x border-[var(--color-hairline)] whitespace-nowrap">{label}</span>
        <a href={nextHref} class="px-3 py-2 text-sm text-[var(--color-navy)] hover:bg-[var(--color-cream)]" aria-label="Next">→</a>
      </div>
      <a href={buildHref({ m: null, d: null })} class="btn-ghost text-sm">Today</a>
    </div>

    <!-- Right: filters -->
    <div class="flex items-center gap-2 flex-wrap">
      <select data-filter="person" aria-label="Filter by person"
        class="text-sm rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-[var(--color-navy)]">
        <option value="">All people</option>
        {people.map((p) => (
          <option value={p.id} selected={p.id === personFilter}>{p.name}</option>
        ))}
      </select>

      <select data-filter="property" aria-label="Filter by property"
        class="text-sm rounded-lg border border-[var(--color-hairline)] bg-white px-3 py-2 text-[var(--color-navy)]">
        <option value="">All properties</option>
        {properties.map((p) => (
          <option value={p.id} selected={p.id === propertyFilter}>{p.name}</option>
        ))}
      </select>

      <a
        href={buildHref({ pto: showPto ? "off" : null })}
        class={`text-sm font-semibold px-3 py-2 rounded-lg border transition-colors ${
          showPto
            ? "bg-[var(--color-navy)] text-white border-[var(--color-navy)]"
            : "bg-white text-[var(--color-navy)] border-[var(--color-hairline)] hover:bg-[var(--color-cream)]"
        }`}
        title="Show or hide approved GM PTO"
      >{showPto ? "✓ " : ""}PTO</a>

      {filtersActive && (
        <a href={buildHref({ person: null, property: null })} class="text-sm text-[var(--color-muted)] underline hover:text-[var(--color-navy)]">Clear filters</a>
      )}
    </div>
  </div>

  {filtersActive && (
    <div class="mb-4 text-sm text-[var(--color-navy)] bg-[var(--color-cream)] border border-[var(--color-hairline)] rounded-lg px-4 py-2">
      Showing{personName && <> <strong>{personName}</strong></>}{propertyFilter && <> at <strong>{properties.find((p) => p.id === propertyFilter)?.name}</strong></>}.
    </div>
  )}

  {created && (<div class="mb-4 rounded-xl border border-green-200 bg-green-50 px-4 py-2.5 text-sm text-green-800">Saved.</div>)}
  {decided && (<div class="mb-4 rounded-xl border border-green-200 bg-green-50 px-4 py-2.5 text-sm text-green-800">Decision recorded — the GM has been notified by email.</div>)}
  {deleted && (<div class="mb-4 rounded-xl border border-green-200 bg-green-50 px-4 py-2.5 text-sm text-green-800">Entry deleted.</div>)}
  {errorMsg && (<div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-2.5 text-sm text-red-700">{errorMsg}</div>)}

  <div class="grid lg:grid-cols-[1fr_320px] gap-6">

    <!-- ── Calendar surface ─────────────────────────────── -->
    <section class="bg-white border border-[var(--color-hairline)] rounded-2xl overflow-hidden">

      {view === "day" ? (
        <!-- Day view: vertical list -->
        <div>
          <div class="px-5 py-3 bg-[var(--color-cream)] border-b border-[var(--color-hairline)] text-sm font-semibold text-[var(--color-navy)]">{label}</div>
          {dayEventsList.length === 0 ? (
            <div class="px-5 py-12 text-center text-sm text-[var(--color-muted)]">Nothing scheduled.</div>
          ) : (
            <ul class="divide-y divide-[var(--color-hairline)]">
              {dayEventsList.map((e) => (
                <li {...evtAttrs(e)} class="px-5 py-3 flex items-start gap-3 cursor-pointer hover:bg-[var(--color-cream)] transition-colors">
                  <span class={`mt-0.5 inline-block w-2.5 h-2.5 rounded-full ${eventPillClass(e.source, e.kind)}`}></span>
                  <div class="min-w-0">
                    <div class="text-sm font-semibold text-[var(--color-navy)]">
                      {kindLabel(e.kind)} · {e.owner_name?.split(" ")[0] || "?"}
                      {e.property_name && <span class="text-[var(--color-brass)]"> · {e.property_name}</span>}
                    </div>
                    <div class="text-xs text-[var(--color-muted)]">
                      {e.starts_at}{e.starts_at !== e.ends_at && <> → {e.ends_at}</>}{e.title && <> — {e.title}</>}
                    </div>
                    {e.notes && <p class="text-xs italic text-[var(--color-muted)] mt-0.5">"{e.notes}"</p>}
                  </div>
                </li>
              ))}
            </ul>
          )}
        </div>
      ) : (
        <!-- Month / Week grid: spanning bars (Google-Calendar style) -->
        <div>
          <div class="grid grid-cols-7 bg-[var(--color-cream)] border-b border-[var(--color-hairline)]">
            {(view === "week" ? cells : WEEKDAYS.map((d) => ({ label: d }))).map((c: any) => (
              <div class="px-2 py-2 text-[10px] uppercase tracking-widest font-semibold text-[var(--color-muted)] text-center">
                {view === "week" ? `${WEEKDAYS[isoToDate(c.iso).getDay()]} ${c.day}` : c.label}
              </div>
            ))}
          </div>

          {weeks.map((wk) => {
            // Vertical room the bars need: lanes stacked + a little breathing room.
            const lanesPx = wk.laneCount * LANE_PX;
            // Day-number row height (month only) the bars must sit below.
            const headerPx = view === "month" ? 24 : 8;
            return (
              <div class="relative">
                <!-- Background day cells: borders, shading, day numbers -->
                <div class="grid grid-cols-7">
                  {wk.cells.map((cell) => (
                    <div
                      class={`relative ${cellMin} border-r border-b border-[var(--color-hairline)] last:border-r-0 px-2 py-1.5 ${!cell.inMonth ? "bg-[var(--color-cream)]/40" : ""}`}
                      style={`padding-bottom: ${lanesPx + 4}px`}
                    >
                      {view === "month" && (
                        <div class="flex items-center justify-between">
                          <span class={`text-xs font-semibold ${cell.isToday ? "bg-[var(--color-brass)] text-white rounded-full w-6 h-6 inline-flex items-center justify-center" : "text-[var(--color-muted)] px-1"}`}>{cell.day}</span>
                        </div>
                      )}
                      {(overflowByDay[cell.iso] || 0) > 0 && (
                        <div
                          class="absolute left-2 text-[10px] text-[var(--color-muted)]"
                          style={`top: ${headerPx + lanesPx + 2}px`}
                        >+{overflowByDay[cell.iso]} more</div>
                      )}
                    </div>
                  ))}
                </div>

                <!-- Overlay: spanning event bars positioned by column + lane -->
                <div
                  class="absolute inset-x-0 grid grid-cols-7 gap-x-1 pointer-events-none px-1"
                  style={`top: ${headerPx}px`}
                >
                  {wk.segments.map((s) => (
                    <div
                      {...evtAttrs(s.ev)}
                      class="pointer-events-auto cursor-pointer"
                      style={`grid-column: ${s.colStart} / span ${s.span}; transform: translateY(${s.lane * LANE_PX}px);`}
                    >
                      <span
                        class={`block truncate text-[10.5px] leading-tight px-1.5 py-0.5 ${eventPillClass(s.ev.source, s.ev.kind)} ${s.clipLeft ? "rounded-l-none" : "rounded-l"} ${s.clipRight ? "rounded-r-none" : "rounded-r"}`}
                        title={`${kindLabel(s.ev.kind)} · ${s.ev.owner_name || "?"}${s.ev.property_name ? " · " + s.ev.property_name : ""}\n${s.ev.starts_at}${s.ev.starts_at !== s.ev.ends_at ? " → " + s.ev.ends_at : ""}${s.ev.title ? "\n" + s.ev.title : ""}${s.ev.notes ? "\n\n" + s.ev.notes : ""}`}
                      >
                        {s.clipLeft && <span class="opacity-60">‹ </span>}
                        <span class="font-semibold">{kindLabel(s.ev.kind)}</span>
                        <span class="opacity-75"> · {s.ev.owner_name?.split(" ")[0] || "?"}</span>
                        {s.ev.property_name && <span class="font-semibold"> · {s.ev.property_name}</span>}
                        {s.clipRight && <span class="opacity-60"> ›</span>}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      )}
    </section>

    <!-- ── Sidebar ──────────────────────────────────────── -->
    <aside class="space-y-6">

      {isAdmin && (
        <section class="bg-white border border-[var(--color-hairline)] rounded-2xl overflow-hidden">
          <header class="px-5 py-3 border-b border-[var(--color-hairline)] flex items-center justify-between">
            <h2 class="font-semibold text-[var(--color-navy)]">Pending PTO requests</h2>
            <span class="text-xs text-[var(--color-muted)] tabular-nums">{pending.results.length}</span>
          </header>
          {pending.results.length === 0 ? (
            <div class="px-5 py-6 text-center text-sm text-[var(--color-muted)]">No requests waiting.</div>
          ) : (
            <ul class="divide-y divide-[var(--color-hairline)]">
              {pending.results.map((r) => (
                <li class="px-5 py-4 space-y-2">
                  <div>
                    <div class="text-sm font-semibold text-[var(--color-navy)]">{r.owner_name}</div>
                    {r.property_name && (<div class="text-xs text-[var(--color-muted)]">{r.property_name}</div>)}
                  </div>
                  <div class="flex items-center gap-2 flex-wrap text-xs">
                    <span class={`pill ${eventPillClass("gm_pto", r.kind)} capitalize`}>{kindLabel(r.kind)}</span>
                    <span class="text-[var(--color-navy)] font-medium">{r.starts_at}{r.starts_at !== r.ends_at && <> → {r.ends_at}</>}</span>
                  </div>
                  {r.notes && (<p class="text-xs italic text-[var(--color-muted)] bg-[var(--color-cream)] rounded-md px-2 py-1.5">"{r.notes}"</p>)}
                  <form method="POST" action={`/api/calendar/events/${r.id}`} class="grid grid-cols-[1fr_auto_auto] gap-2 items-center pt-1">
                    <input type="text" name="reason" placeholder="Reason (required to deny)" class="text-xs rounded-md border border-[var(--color-hairline)] bg-white px-2 py-1.5 text-[var(--color-navy)]" />
                    <button type="submit" name="action" value="deny" class="text-xs font-semibold px-2.5 py-1.5 rounded-md border border-red-300 text-red-600 hover:bg-red-50">Deny</button>
                    <button type="submit" name="action" value="approve" class="text-xs font-semibold px-2.5 py-1.5 rounded-md bg-[var(--color-navy)] text-white hover:bg-[var(--color-navy-700)]">Approve</button>
                  </form>
                </li>
              ))}
            </ul>
          )}
        </section>
      )}

      {isAdmin && (
        <section class="bg-white border border-[var(--color-hairline)] rounded-2xl p-5 space-y-4">
          <h2 class="font-semibold text-[var(--color-navy)]">Add to my schedule</h2>
          <p class="text-xs text-[var(--color-muted)]">Post your own travel or out-of-office. Visible to other admins and Strand — never GMs.</p>
          <form method="POST" action="/api/calendar/events" class="space-y-3">
            <input type="hidden" name="source" value="regional" />

            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Type</label>
              <div class="grid grid-cols-3 gap-2">
                {[{ value: "travel", label: "Travel" }, { value: "ooo", label: "OOO" }, { value: "other", label: "Other" }].map((opt, i) => (
                  <label class="flex items-center justify-center cursor-pointer rounded-lg border border-[var(--color-hairline)] bg-white px-2 py-2 has-[:checked]:bg-[var(--color-navy)] has-[:checked]:text-white has-[:checked]:border-[var(--color-navy)] transition-colors text-xs">
                    <input type="radio" name="kind" value={opt.value} class="hidden" required checked={i === 0} />
                    <span class="font-semibold">{opt.label}</span>
                  </label>
                ))}
              </div>
            </div>

            <div>
              <label for="reg_property" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
                Property <span class="font-normal normal-case tracking-normal text-[var(--color-muted)]">(optional — which hotel)</span>
              </label>
              <select id="reg_property" name="property_id" class="w-full rounded-md border border-[var(--color-hairline)] bg-white px-2 py-1.5 text-sm">
                <option value="">— none —</option>
                {properties.map((p) => (<option value={p.id}>{p.name}</option>))}
              </select>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label for="reg_start" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">Start</label>
                <input id="reg_start" name="starts_at" type="date" required value={todayIso} class="w-full rounded-md border border-[var(--color-hairline)] bg-white px-2 py-1.5 text-sm" />
              </div>
              <div>
                <label for="reg_end" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">End</label>
                <input id="reg_end" name="ends_at" type="date" required value={todayIso} class="w-full rounded-md border border-[var(--color-hairline)] bg-white px-2 py-1.5 text-sm" />
              </div>
            </div>

            <div>
              <label for="reg_title" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
                Title <span class="font-normal normal-case tracking-normal text-[var(--color-muted)]">(optional)</span>
              </label>
              <input id="reg_title" name="title" type="text" placeholder="e.g. Charlotte conference" class="w-full rounded-md border border-[var(--color-hairline)] bg-white px-2 py-1.5 text-sm" />
            </div>

            <div>
              <label for="reg_notes" class="block text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-1.5">
                Notes <span class="font-normal normal-case tracking-normal text-[var(--color-muted)]">(optional)</span>
              </label>
              <textarea id="reg_notes" name="notes" rows="2" class="w-full rounded-md border border-[var(--color-hairline)] bg-white px-2 py-1.5 text-sm"></textarea>
            </div>

            <button type="submit" class="btn-primary w-full text-sm">Add to calendar</button>
          </form>
        </section>
      )}

      <section class="bg-white border border-[var(--color-hairline)] rounded-2xl p-5 text-xs">
        <h2 class="text-xs font-bold uppercase tracking-widest text-[var(--color-muted)] mb-3">Legend</h2>
        <ul class="space-y-2">
          <li class="flex items-center gap-2"><span class={`w-3 h-3 rounded ${eventPillClass("regional", "travel")}`}></span> Regional · Travel</li>
          <li class="flex items-center gap-2"><span class={`w-3 h-3 rounded ${eventPillClass("regional", "ooo")}`}></span> Regional · OOO</li>
          <li class="flex items-center gap-2"><span class={`w-3 h-3 rounded ${eventPillClass("regional", "other")}`}></span> Regional · Other</li>
          <li class="flex items-center gap-2"><span class={`w-3 h-3 rounded ${eventPillClass("gm_pto", "vacation")}`}></span> GM PTO · Vacation</li>
          <li class="flex items-center gap-2"><span class={`w-3 h-3 rounded ${eventPillClass("gm_pto", "sick")}`}></span> GM PTO · Sick</li>
          <li class="flex items-center gap-2"><span class={`w-3 h-3 rounded ${eventPillClass("gm_pto", "personal")}`}></span> GM PTO · Personal</li>
        </ul>
      </section>
    </aside>
  </div>

  <!-- ── Event detail modal ───────────────────────────── -->
  <dialog id="evtModal" class="rounded-2xl border border-[var(--color-hairline)] p-0 w-[min(92vw,440px)] backdrop:bg-black/30">
    <div class="p-5 space-y-3">
      <div class="flex items-start justify-between gap-3">
        <div class="flex items-center gap-2 flex-wrap">
          <span id="evtChip" class="text-xs font-semibold px-2 py-0.5 rounded"></span>
          <span id="evtStatus" class="text-[10px] uppercase tracking-widest text-[var(--color-muted)]"></span>
        </div>
        <button type="button" data-evt-close class="text-[var(--color-muted)] hover:text-[var(--color-navy)] text-2xl leading-none" aria-label="Close">&times;</button>
      </div>
      <h3 id="evtTitle" class="text-lg font-bold text-[var(--color-navy)]"></h3>
      <dl class="text-sm space-y-1.5">
        <div class="flex gap-3"><dt class="text-[var(--color-muted)] w-20 shrink-0">Who</dt><dd id="evtOwner" class="text-[var(--color-navy)] font-medium"></dd></div>
        <div id="evtPropertyRow" class="flex gap-3"><dt class="text-[var(--color-muted)] w-20 shrink-0">Property</dt><dd id="evtProperty" class="text-[var(--color-navy)] font-medium"></dd></div>
        <div class="flex gap-3"><dt class="text-[var(--color-muted)] w-20 shrink-0">Dates</dt><dd id="evtDates" class="text-[var(--color-navy)] font-medium"></dd></div>
        <div id="evtNotesRow" class="flex gap-3"><dt class="text-[var(--color-muted)] w-20 shrink-0">Notes</dt><dd id="evtNotes" class="text-[var(--color-navy)] italic"></dd></div>
      </dl>
      <div class="flex items-center justify-between pt-2 border-t border-[var(--color-hairline)] mt-2">
        <form id="evtDeleteForm" method="POST" class="hidden">
          <input type="hidden" name="action" value="delete" />
          <button type="submit" class="text-xs font-semibold text-red-600 hover:text-red-700">Delete entry</button>
        </form>
        <button type="button" data-evt-close class="ml-auto text-sm font-semibold px-4 py-2 rounded-lg border border-[var(--color-hairline)] text-[var(--color-navy)] hover:bg-[var(--color-cream)]">Close</button>
      </div>
    </div>
  </dialog>

  <script is:inline>
    // Filter dropdowns → reload with the param set.
    document.querySelectorAll("select[data-filter]").forEach((sel) => {
      sel.addEventListener("change", () => {
        const u = new URL(location.href);
        const key = sel.getAttribute("data-filter");
        if (sel.value) u.searchParams.set(key, sel.value);
        else u.searchParams.delete(key);
        location.href = u.pathname + u.search;
      });
    });

    // Click any event (day-list row or spanning bar) → detail modal.
    const modal = document.getElementById("evtModal");
    const delForm = document.getElementById("evtDeleteForm");
    const setRow = (rowId, valId, val) => {
      document.getElementById(rowId).style.display = val ? "" : "none";
      document.getElementById(valId).textContent = val;
    };
    function openEvt(el) {
      const g = (k) => el.getAttribute(k) || "";
      const chip = document.getElementById("evtChip");
      chip.textContent = g("data-kindlabel");
      chip.className = "text-xs font-semibold px-2 py-0.5 rounded " + g("data-pill");
      const status = g("data-status");
      document.getElementById("evtStatus").textContent =
        status && status !== "not_required" ? status : "";
      document.getElementById("evtTitle").textContent = g("data-title") || g("data-kindlabel");
      document.getElementById("evtOwner").textContent = g("data-owner") || "—";
      setRow("evtPropertyRow", "evtProperty", g("data-property"));
      const s = g("data-start"), e = g("data-end");
      document.getElementById("evtDates").textContent = s === e ? s : s + " → " + e;
      setRow("evtNotesRow", "evtNotes", g("data-notes"));
      if (g("data-candelete")) {
        delForm.action = "/api/calendar/events/" + g("data-id");
        delForm.classList.remove("hidden");
      } else {
        delForm.classList.add("hidden");
      }
      if (typeof modal.showModal === "function") modal.showModal();
    }
    document.querySelectorAll("[data-evt]").forEach((el) => {
      el.addEventListener("click", () => openEvt(el));
    });
    document.querySelectorAll("[data-evt-close]").forEach((b) =>
      b.addEventListener("click", () => modal.close())
    );
    modal.addEventListener("click", (ev) => { if (ev.target === modal) modal.close(); });
    delForm.addEventListener("submit", (ev) => {
      if (!confirm("Delete this entry? This cannot be undone.")) ev.preventDefault();
    });
  </script>
</PortalLayout>
