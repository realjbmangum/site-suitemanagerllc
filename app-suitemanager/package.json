{
  "name": "suitemanager-portal",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist --d1=DB --r2=FILES --port 8788",
    "deploy": "npm run build && wrangler pages deploy ./dist",
    "astro": "astro",
    "db:apply:remote": "wrangler d1 execute suitemanager-portal --remote --file=./worker/db/schema.sql",
    "db:apply:local": "wrangler d1 execute suitemanager-portal --local --file=./worker/db/schema.sql",
    "seed:properties": "node scripts/seed-properties.mjs",
    "seed:properties:local": "node scripts/seed-properties.mjs -- --local"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.85.0",
    "xlsx": "^0.18.5"
  }
}
